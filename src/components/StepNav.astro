---
import { navItems } from "../lib/cip/data";

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";

function isCurrent(href: string) {
  return currentPath === href;
}
---

<nav class="border-b border-[var(--line)] bg-[var(--panel)]" aria-label="Career journey steps">
  <div class="mx-auto flex w-full max-w-7xl items-center gap-1 overflow-x-auto px-5 py-2 text-sm">
    {navItems.map((item) => (
      <a
        href={item.href}
        aria-current={isCurrent(item.href) ? "page" : undefined}
        class:list={[
          "flex shrink-0 items-center gap-1.5 rounded-md px-3 py-1.5 font-semibold",
          isCurrent(item.href)
            ? "bg-[rgba(126,217,87,0.18)] text-[var(--accent-strong)]"
            : "text-[var(--muted)] hover:bg-black/5 hover:text-[var(--foreground)] dark:hover:bg-white/10",
        ]}
      >
        {item.step ? (
          <span
            class:list={[
              "flex h-5 w-5 items-center justify-center rounded-full border text-[11px] font-bold",
              isCurrent(item.href)
                ? "border-[var(--accent-strong)] text-[var(--accent-strong)]"
                : "border-[var(--line)] text-[var(--muted)]",
            ]}
          >
            {item.step}
          </span>
        ) : null}
        <span>{item.label}</span>
      </a>
    ))}
    <span class="ml-2 hidden shrink-0 items-center gap-1 text-xs font-semibold text-[var(--muted)] lg:flex" title="Network, Follow Up, Employers, Roles, and Briefing repeat as a weekly cycle: advisor conversations feed the next research pass.">
      <span aria-hidden="true">&#8635;</span>
      Steps 4&ndash;8 repeat weekly
    </span>
  </div>
</nav>
