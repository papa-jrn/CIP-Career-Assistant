---
import "../styles/global.css";
import { createServer } from "../lib/supabase/server";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Career Intelligence Platform",
  description = "A trust-first career strategist and job search intelligence workspace.",
} = Astro.props;

let signedInEmail = "";

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();
    signedInEmail = user?.email ?? "";
  } catch {
    signedInEmail = "";
  }
}
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script>
      import "htmx.org";
    </script>
  </head>
  <body class="min-h-full flex flex-col font-sans">
    <div class="border-b border-[var(--line)] bg-[var(--background)]">
      <div class="mx-auto flex w-full max-w-7xl flex-wrap items-center justify-between gap-3 px-5 py-2 text-sm">
        <a href="/" class="font-semibold text-[var(--foreground)]">Career Intelligence Platform</a>
        {signedInEmail ? (
          <div class="flex flex-wrap items-center gap-3">
            <span class="text-[var(--muted)]">
              Signed in as <span class="font-semibold text-[var(--foreground)]">{signedInEmail}</span>
            </span>
            <form hx-post="/api/auth/logout" hx-swap="none">
              <button class="rounded-md border border-[var(--line)] px-3 py-1.5 text-sm font-semibold text-[var(--foreground)] hover:bg-black/5 dark:hover:bg-white/10" type="submit">
                Sign out
              </button>
            </form>
          </div>
        ) : (
          <a class="rounded-md border border-[var(--line)] px-3 py-1.5 text-sm font-semibold text-[var(--foreground)] hover:bg-black/5 dark:hover:bg-white/10" href="/login">
            Sign in
          </a>
        )}
      </div>
    </div>
    <slot />
    <div class="cip-route-loader" data-asset-route-loader hidden role="status" aria-live="polite" aria-label="Preparing career assets">
      <div class="cip-route-loader-panel">
        <div class="cip-thinking-orbit" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Preparing career assets</p>
          <p class="cip-route-loader-line" data-asset-loader-line>Loading the latest career analysis...</p>
          <div class="cip-thinking-bar" aria-hidden="true"><span></span></div>
        </div>
      </div>
    </div>
    <script>
      const assetLoaderMessages = [
        "Loading the latest career analysis...",
        "Pulling verified evidence and source notes...",
        "Finding the strongest target lane...",
        "Asking the career strategist to synthesize the resume...",
        "Checking for duplicate claims and education entries...",
        "Preparing the master resume editor...",
      ];
      const assetLoader = document.querySelector("[data-asset-route-loader]");
      const assetLoaderLine = document.querySelector("[data-asset-loader-line]");
      let assetLoaderTimer;

      document.querySelectorAll("[data-asset-loader]").forEach((link) => {
        link.addEventListener("click", () => {
          if (!assetLoader || !assetLoaderLine) return;
          let index = 0;
          assetLoader.hidden = false;
          assetLoaderLine.textContent = assetLoaderMessages[index];
          clearInterval(assetLoaderTimer);
          assetLoaderTimer = setInterval(() => {
            index = (index + 1) % assetLoaderMessages.length;
            assetLoaderLine.textContent = assetLoaderMessages[index];
          }, 1900);
        });
      });
    </script>
  </body>
</html>
