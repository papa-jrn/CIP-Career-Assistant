---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import { navItems } from "../lib/cip/data";
import type { AdvisorAnalysis } from "../lib/cip/advisor";
import { createServer } from "../lib/supabase/server";

type IntakeSource = {
  intake?: Record<string, unknown>;
  draft?: {
    strengths?: string[];
    possibleRoles?: string[];
    evidenceChecklist?: string[];
    nextQuestions?: string[];
  };
  advisor?: Partial<AdvisorAnalysis>;
};

let latestSource: IntakeSource | null = null;
let latestAdvisor: Partial<AdvisorAnalysis> | null = null;
let latestAnalysisAt: string | null = null;
let workbenchState: "ready" | "signin" | "empty" | "local" | "error" = "local";

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();

    if (user) {
      const { data: intakeData } = await supabase
        .from("career_sources")
        .select("extracted_text, created_at")
        .eq("user_id", user.id)
        .eq("source_type", "resume_intake")
        .order("created_at", { ascending: false })
        .limit(1)
        .maybeSingle();

      const { data: analysisData } = await supabase
        .from("career_sources")
        .select("extracted_text, created_at")
        .eq("user_id", user.id)
        .eq("source_type", "evidence_analysis")
        .order("created_at", { ascending: false })
        .limit(1)
        .maybeSingle();

      latestSource = parseIntakeSource(intakeData?.extracted_text ?? null);
      latestAdvisor = parseAnalysisAdvisor(analysisData?.extracted_text ?? null) ?? latestSource?.advisor ?? null;
      latestAnalysisAt = analysisData?.created_at ?? intakeData?.created_at ?? null;
      workbenchState = latestSource ? "ready" : "empty";
    } else {
      workbenchState = "signin";
    }
  } catch {
    workbenchState = "error";
  }
}

const hasPersonalizedWorkbench = workbenchState === "ready" && Boolean(latestAdvisor || latestSource);

// --- How-CIP-works infographic: derived from navItems (single source of truth) ---
const setupSteps = navItems.filter((n) => typeof n.step === "number" && n.step >= 1 && n.step <= 3);
const loopSteps = navItems.filter((n) => n.cycle);
const reportStep = navItems.find((n) => n.step === 9);

// --- Hero secondary CTA: state-aware ---
const heroSecondary =
  workbenchState === "signin"
    ? { href: "/login", label: "Sign in to start" }
    : hasPersonalizedWorkbench
      ? { href: "/report", label: "Generate your report" }
      : { href: "/evidence", label: "Check analysis readiness" };

// --- "Your next move": the real next step in the 1→8 sequence, based on what data exists ---
const nextMove = computeNextMove();

// --- "Your model at a glance": real fields from saved analysis. Null unless personalized. ---
const modelAtGlance = hasPersonalizedWorkbench && latestAdvisor ? buildModelAtGlance(latestAdvisor) : null;

function parseIntakeSource(value: string | null): IntakeSource | null {
  if (!value) return null;
  try {
    return JSON.parse(value) as IntakeSource;
  } catch {
    return null;
  }
}

function parseAnalysisAdvisor(value: string | null): Partial<AdvisorAnalysis> | null {
  if (!value) return null;
  try {
    const parsed = JSON.parse(value);
    return parsed?.advisor ?? null;
  } catch {
    return null;
  }
}

function computeNextMove() {
  if (workbenchState === "signin") {
    return {
      href: "/login",
      label: "Sign in to start your workspace",
      detail: "CIP stores resumes, salary targets, and private network context, so the work begins behind a sign-in.",
      icon: "arrow-right",
    };
  }
  if (workbenchState === "error") {
    return {
      href: "/intake",
      label: "Start with intake",
      detail: "We could not load saved analysis. You can still begin a fresh intake.",
      icon: "intake",
    };
  }
  if (workbenchState === "empty" || workbenchState === "local") {
    return {
      href: "/intake",
      label: "Start with intake",
      detail: "Capture your career story, constraints, and proof sources. Everything else builds on this.",
      icon: "intake",
    };
  }
  // ready
  if (!latestAdvisor) {
    return {
      href: "/evidence",
      label: "Run evidence analysis",
      detail: "Your intake is saved. Separate verified claims from inferred strengths before acting on them.",
      icon: "evidence",
    };
  }
  return {
    href: "/assets",
    label: "Prepare your assets",
    detail: "Your analysis is ready. Turn the verified evidence into resume, LinkedIn, and outreach language.",
    icon: "assets",
  };
}

function buildModelAtGlance(advisor: Partial<AdvisorAnalysis>) {
  const roleBriefs = Array.isArray(advisor.roleBriefs) ? advisor.roleBriefs : [];
  const positioning = Array.isArray(advisor.positioning) ? advisor.positioning : [];
  const ledger = Array.isArray(advisor.evidenceLedger) ? advisor.evidenceLedger : [];
  const verifiedCount = ledger.filter((item) => item.status === "verified_from_resume").length;

  return {
    primaryRole: roleBriefs[0]?.role ?? null,
    positioning: positioning[0] ?? null,
    verifiedClaims: verifiedCount,
    totalClaims: ledger.length,
    summary: typeof advisor.summary === "string" && advisor.summary ? advisor.summary : null,
    analyzedAt: latestAnalysisAt,
  };
}

function buildRoleHypotheses(source: IntakeSource | null, advisor: Partial<AdvisorAnalysis> | null) {
  const briefs = Array.isArray(advisor?.roleBriefs) ? advisor.roleBriefs : [];
  if (briefs.length) {
    return briefs.slice(0, 4).map((brief, index) => ({
      role: brief.role,
      match: `${index === 0 ? "Primary" : index === 1 ? "Strong" : "Research"} lane`,
      evidence: brief.whyItFits,
      nextGap: brief.evidenceNeeded,
    }));
  }

  const draftRoles = source?.draft?.possibleRoles ?? [];
  return draftRoles.slice(0, 4).map((role, index) => ({
    role,
    match: `${index === 0 ? "Primary" : "Research"} lane`,
    evidence: "Generated from the saved intake draft. Run evidence re-analysis for stronger user-specific rationale.",
    nextGap: "Add proof, salary fit, target industries, and real posting comparison before treating this as a recommendation.",
  }));
}

function buildAssetGuidance(source: IntakeSource | null, advisor: Partial<AdvisorAnalysis> | null) {
  const positioning = Array.isArray(advisor?.positioning) ? advisor.positioning : [];
  const safetyNotes = Array.isArray(advisor?.claimSafetyNotes) ? advisor.claimSafetyNotes : [];
  const ledger = Array.isArray(advisor?.evidenceLedger) ? advisor.evidenceLedger : [];
  const strongestLedgerItems = ledger
    .filter((item) => item.status === "verified_from_resume" || item.status === "stated_by_user")
    .slice(0, 3);

  if (positioning.length || strongestLedgerItems.length) {
    return [
      {
        area: "Resume",
        action: positioning[0] ?? strongestLedgerItems[0]?.whyItMatters ?? "Use the latest advisor analysis to choose the strongest verified story.",
        guardrail: safetyNotes[0] ?? "Only use claims backed by resume text, saved evidence, or public source material.",
      },
      {
        area: "LinkedIn",
        action: positioning[1] ?? strongestLedgerItems[1]?.claim ?? "Translate the strongest positioning point into profile language.",
        guardrail: safetyNotes[1] ?? "Do not imply private metrics, titles, tools, or outcomes that have not been verified.",
      },
      {
        area: "Portfolio / outreach",
        action: positioning[2] ?? strongestLedgerItems[2]?.nextValidationStep ?? "Choose one proof-backed story to anchor outreach and interviews.",
        guardrail: safetyNotes[2] ?? "Separate shipped work, prototypes, learning projects, and aspirations.",
      },
    ];
  }

  const strengths = source?.draft?.strengths ?? [];
  return strengths.slice(0, 3).map((strength, index) => ({
    area: index === 0 ? "Resume" : index === 1 ? "LinkedIn" : "Portfolio / outreach",
    action: `Use "${strength}" as a draft positioning signal, then verify it with evidence before publishing.`,
    guardrail: "Run evidence analysis before turning this into public-facing career copy.",
  }));
}

function buildBriefingActions(source: IntakeSource | null, advisor: Partial<AdvisorAnalysis> | null) {
  const questions = Array.isArray(advisor?.followUpQuestions) ? advisor.followUpQuestions : [];
  const gaps = Array.isArray(advisor?.skillGaps) ? advisor.skillGaps : [];
  const experiments = Array.isArray(advisor?.explorationAreas)
    ? advisor.explorationAreas.map((area) => area.firstExperiment).filter(Boolean)
    : [];
  const actions = [...gaps, ...questions, ...experiments]
    .filter(Boolean)
    .slice(0, 5);

  if (actions.length) return actions;

  return [
    ...(source?.draft?.evidenceChecklist ?? []).slice(0, 3),
    ...(source?.draft?.nextQuestions ?? []).slice(0, 2),
  ].filter(Boolean);
}

const userRoleHypotheses = buildRoleHypotheses(latestSource, latestAdvisor);
const userAssetGuidance = buildAssetGuidance(latestSource, latestAdvisor);
const userBriefingActions = buildBriefingActions(latestSource, latestAdvisor);
---

<Layout
  title="Workbench - Career Intelligence Platform"
  description="The signed-in Career Intelligence Platform workbench for status, next actions, and module summaries."
>
  <main class="cip-page-shell">
    <!-- ============ HERO (2–3× the weight of everything below) ============ -->
    <section class="mx-auto w-full max-w-7xl px-5 pt-8 pb-2 md:pt-12">
      <div class="grid items-stretch gap-0 overflow-hidden rounded-xl border border-[var(--line)] bg-[var(--panel)] shadow-[0_1px_2px_rgba(30,36,32,0.04),0_18px_48px_rgba(30,36,32,0.10)] md:grid-cols-[1.05fr_0.95fr]">
        <!-- Hero copy -->
        <div class="flex flex-col justify-center gap-5 p-7 md:p-10 lg:p-12">
          <span class="inline-flex w-fit items-center gap-2 rounded-full bg-[var(--accent-soft)] px-3 py-1 text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">
            <Icon name="spark" class="h-3.5 w-3.5" strokeWidth={2} />
            Career Intelligence Platform
          </span>
          <h1 class="text-4xl leading-[1.08] md:text-5xl lg:text-[3.4rem]" style="font-family: var(--headline-font); font-weight: 620; letter-spacing: -0.025em;">
            Career intelligence<br />before application volume.
          </h1>
          <p class="max-w-xl text-base leading-7 text-[var(--muted)] md:text-lg md:leading-8">
            CIP works less like an apply bot and more like a career strategist. It models who you are, researches the market, and recommends source-backed moves across roles, resume, LinkedIn, portfolio, and weekly strategy.
          </p>
          <div class="flex flex-wrap items-center gap-3 pt-1">
            <a class="cip-fancy-button" href="/intake">
              <span class="flex items-center gap-2">
                <Icon name="arrow-right" class="h-4 w-4" strokeWidth={2.2} />
                Start intake
              </span>
            </a>
            <a class="cip-fancy-button cip-fancy-button-secondary" href={heroSecondary.href}>
              <span>{heroSecondary.label}</span>
            </a>
          </div>
          <p class="text-xs leading-5 text-[var(--muted)]">
            Every recommendation is meant to carry evidence, confidence, and a user approval state before it changes a public career asset.
          </p>
        </div>
        <!-- Hero image slot: warm human moment. Drop optimized image at /images/hero-workspace.jpg (provenance in public/images/PROVENANCE.md). -->
        <div class="relative min-h-[260px] overflow-hidden border-t border-[var(--line)] bg-[var(--surface-wash)] md:border-l md:border-t-0">
          <img
            src="/images/hero-workspace.jpg"
            alt="A welcoming conversation in a bright workspace"
            class="h-full w-full object-cover"
            onerror="this.style.display='none';this.parentElement.classList.add('cip-hero-fallback')"
            width="900"
            height="700"
          />
          <!-- Overlay gradient for text legibility (image independent) -->
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[rgba(31,68,56,0.45)] via-transparent to-transparent"></div>
        </div>
      </div>
    </section>

    <!-- ============ ERROR BANNER ============ -->
    {workbenchState === "error" && (
      <div class="mx-auto mt-4 w-full max-w-7xl px-5">
        <p class="rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-800 dark:border-red-900/50 dark:bg-red-950/30 dark:text-red-200">
          We could not load your saved analysis right now. Check Supabase configuration, then refresh. You can still start a fresh intake below.
        </p>
      </div>
    )}

    <!-- ============ HOW CIP WORKS (the real 1–8 infographic) ============ -->
    <section class="mx-auto mt-8 w-full max-w-7xl px-5">
      <div class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6 shadow-[var(--shadow-card)] md:p-8">
        <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">How CIP works</p>
        <h2 class="mt-2 max-w-3xl text-3xl" style="font-family: var(--headline-font);">
          From first intake to a weekly intelligence loop.
        </h2>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
          The process runs once to build the model, then repeats weekly to turn conversations and research into the next move. The Report is generated fresh each pass.
        </p>

        <!-- Phase 1: Build the model once (steps 1–3) -->
        <div class="mt-7">
          <div class="flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--accent-soft)] text-xs font-bold text-[var(--accent-strong)]">1</span>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-[var(--foreground)]">Build the model once</h3>
            <span class="text-xs text-[var(--muted)]">Steps 1–3</span>
          </div>
          <div class="mt-3 grid gap-3 sm:grid-cols-3">
            {setupSteps.map((item) => (
              <a
                href={item.href}
                class="group flex flex-col rounded-lg border border-[var(--line)] bg-[var(--background)] p-4 transition-shadow hover:shadow-[var(--shadow-card)]"
              >
                <div class="flex items-center justify-between">
                  <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--accent-soft)] text-[var(--accent-strong)]">
                    <Icon name={item.icon ?? "file"} class="h-4.5 w-4.5" strokeWidth={1.9} />
                  </span>
                  <span class="text-xs font-bold text-[var(--brass)]">{String(item.step).padStart(2, "0")}</span>
                </div>
                <h4 class="mt-3 text-sm font-semibold">{item.label}</h4>
                <p class="mt-1.5 text-xs leading-5 text-[var(--muted)]">{item.blurb}</p>
              </a>
            ))}
          </div>
        </div>

        <!-- Phase 2: Repeat weekly (steps 4–8) -->
        <div class="mt-7 rounded-lg border border-dashed border-[var(--brass)]/50 bg-[var(--surface-wash)] p-4 md:p-5">
          <div class="flex flex-wrap items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--brass-soft)] text-xs font-bold text-[var(--warning)]" title="Network, Follow Up, Employers, Opportunities, and Briefing repeat as a weekly cycle.">
              <span aria-hidden="true">&#8635;</span>
            </span>
            <h3 class="text-sm font-semibold uppercase tracking-wide text-[var(--foreground)]">Repeat weekly</h3>
            <span class="text-xs text-[var(--muted)]">Steps 4–8</span>
            <span class="text-xs font-medium text-[var(--muted)]">— advisor conversations feed the next research pass.</span>
          </div>
          <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
            {loopSteps.map((item) => (
              <a
                href={item.href}
                class="group flex flex-col rounded-lg border border-[var(--line)] bg-[var(--panel)] p-4 transition-shadow hover:shadow-[var(--shadow-card)]"
              >
                <div class="flex items-center justify-between">
                  <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--accent-soft)] text-[var(--accent-strong)]">
                    <Icon name={item.icon ?? "file"} class="h-4.5 w-4.5" strokeWidth={1.9} />
                  </span>
                  <span class="text-xs font-bold text-[var(--brass)]">{String(item.step).padStart(2, "0")}</span>
                </div>
                <h4 class="mt-3 text-sm font-semibold">{item.label}</h4>
                <p class="mt-1.5 text-xs leading-5 text-[var(--muted)]">{item.blurb}</p>
              </a>
            ))}
          </div>
        </div>

        <!-- Phase 3: Capstone (step 9) -->
        {reportStep && (
          <div class="mt-7">
            <div class="flex items-center gap-2">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--accent-soft)] text-xs font-bold text-[var(--accent-strong)]">3</span>
              <h3 class="text-sm font-semibold uppercase tracking-wide text-[var(--foreground)]">Capstone</h3>
              <span class="text-xs text-[var(--muted)]">Step {reportStep.step}</span>
            </div>
            <div class="mt-3 grid gap-3 sm:grid-cols-3">
              <a
                href={reportStep.href}
                class="group flex flex-col rounded-lg border border-[var(--line)] bg-[var(--background)] p-4 transition-shadow hover:shadow-[var(--shadow-card)] sm:col-span-1"
              >
                <div class="flex items-center justify-between">
                  <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--accent-soft)] text-[var(--accent-strong)]">
                    <Icon name={reportStep.icon ?? "file"} class="h-4.5 w-4.5" strokeWidth={1.9} />
                  </span>
                  <span class="text-xs font-bold text-[var(--brass)]">{String(reportStep.step).padStart(2, "0")}</span>
                </div>
                <h4 class="mt-3 text-sm font-semibold">{reportStep.label}</h4>
                <p class="mt-1.5 text-xs leading-5 text-[var(--muted)]">{reportStep.blurb}</p>
              </a>
              <p class="self-center text-xs leading-5 text-[var(--muted)] sm:col-span-2">
                After each weekly loop, generate a fresh report. It carries the current model, the evidence behind it, what still needs validation, and the next practical moves.
              </p>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- ============ YOUR NEXT MOVE (auth-aware, replaces broken pathway) ============ -->
    <section class="mx-auto mt-6 w-full max-w-7xl px-5">
      <div class="flex flex-col gap-4 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6 shadow-[var(--shadow-card)] sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-start gap-4">
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[var(--accent-soft)] text-[var(--accent-strong)]">
            <Icon name={nextMove.icon} class="h-6 w-6" strokeWidth={1.9} />
          </span>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">Your next move</p>
            <h2 class="mt-1 text-xl" style="font-family: var(--headline-font);">{nextMove.label}</h2>
            <p class="mt-1 max-w-2xl text-sm leading-6 text-[var(--muted)]">{nextMove.detail}</p>
          </div>
        </div>
        <a
          class="cip-fancy-button shrink-0 self-start sm:self-center"
          href={nextMove.href}
          data-asset-loader={nextMove.href === "/assets" ? "true" : undefined}
        >
          <span class="flex items-center gap-2">
            {nextMove.label}
            <Icon name="arrow-right" class="h-4 w-4" strokeWidth={2.2} />
          </span>
        </a>
      </div>
    </section>

    <div class="mx-auto grid w-full max-w-7xl gap-6 px-5 py-8 lg:grid-cols-[1.15fr_0.85fr]">
      <!-- ============ YOUR MODEL AT A GLANCE (auth-gated; absent when not personalized) ============ -->
      {modelAtGlance && (
        <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6 shadow-[var(--shadow-card)]">
          <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">Your model at a glance</p>
          <h2 class="mt-2 text-2xl" style="font-family: var(--headline-font);">What CIP is modeling about you</h2>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-[var(--muted)]">
            {modelAtGlance.analyzedAt
              ? `Built from your latest saved analysis${modelAtGlance.analyzedAt ? ` from ${new Date(modelAtGlance.analyzedAt).toLocaleString()}` : ""}.`
              : "Built from your latest saved analysis."}
          </p>
          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            {modelAtGlance.primaryRole && (
              <article class="rounded-lg border border-[var(--line)] bg-[var(--background)] p-4">
                <h3 class="text-sm font-semibold">Primary role lane</h3>
                <p class="mt-2 text-sm font-semibold text-[var(--accent-strong)]">{modelAtGlance.primaryRole}</p>
              </article>
            )}
            {modelAtGlance.positioning && (
              <article class="rounded-lg border border-[var(--line)] bg-[var(--background)] p-4">
                <h3 class="text-sm font-semibold">Top positioning point</h3>
                <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{modelAtGlance.positioning}</p>
              </article>
            )}
            <article class="rounded-lg border border-[var(--line)] bg-[var(--background)] p-4">
              <h3 class="text-sm font-semibold">Evidence status</h3>
              <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
                <span class="font-semibold text-[var(--positive)]">{modelAtGlance.verifiedClaims} verified</span>
                {modelAtGlance.totalClaims ? ` of ${modelAtGlance.totalClaims} tracked claims` : " tracked claims"}.
              </p>
            </article>
            {modelAtGlance.summary && (
              <article class="rounded-lg border border-[var(--line)] bg-[var(--background)] p-4 sm:col-span-2">
                <h3 class="text-sm font-semibold">Analyst summary</h3>
                <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{modelAtGlance.summary}</p>
              </article>
            )}
          </div>
        </section>
      )}

      <!-- ============ OPPORTUNITY RADAR ============ -->
      <section class={`rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6 shadow-[var(--shadow-card)] ${modelAtGlance ? "" : "lg:col-span-2"}`}>
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">Opportunity Radar</p>
            <h2 class="mt-2 text-2xl" style="font-family: var(--headline-font);">User-matched role hypotheses</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-[var(--muted)]">
              {hasPersonalizedWorkbench
                ? `Built from the latest saved analysis${latestAnalysisAt ? ` from ${new Date(latestAnalysisAt).toLocaleString()}` : ""}.`
                : workbenchState === "signin"
                  ? "Sign in and save an intake to replace this empty state with user-specific role hypotheses."
                  : "Save and analyze an intake to generate role hypotheses from the user's actual background."}
            </p>
          </div>
          <a class="inline-flex items-center gap-1.5 rounded-md border border-[var(--line)] px-4 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href="/opportunities">
            Open research queue
            <Icon name="arrow-up-right" class="h-3.5 w-3.5" strokeWidth={2.1} />
          </a>
        </div>
        {userRoleHypotheses.length ? (
        <div class="mt-5 overflow-hidden rounded-lg border border-[var(--line)]">
          <table class="w-full border-collapse text-left text-sm">
            <thead class="bg-[var(--surface-wash)] text-[var(--muted)]">
              <tr>
                <th class="px-4 py-3 font-semibold">Role</th>
                <th class="px-4 py-3 font-semibold">Lane</th>
                <th class="px-4 py-3 font-semibold">Evidence</th>
                <th class="px-4 py-3 font-semibold">Next Gap</th>
              </tr>
            </thead>
            <tbody>
              {userRoleHypotheses.map((item) => (
                <tr class="border-t border-[var(--line)]">
                  <td class="px-4 py-4">
                    <div class="font-semibold">{item.role}</div>
                  </td>
                  <td class="px-4 py-4 font-semibold text-[var(--accent-strong)]">{item.match}</td>
                  <td class="max-w-md px-4 py-4 text-[var(--muted)]">{item.evidence}</td>
                  <td class="max-w-xs px-4 py-4 text-[var(--muted)]">{item.nextGap}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        ) : (
        <div class="mt-5 overflow-hidden rounded-lg border border-[var(--line)] bg-[var(--background)]">
          <div class="grid gap-0 sm:grid-cols-[120px_1fr]">
            <div class="hidden min-h-[120px] bg-[var(--surface-wash)] sm:block">
              <img src="/images/empty-state.jpg" alt="" aria-hidden="true" class="h-full w-full object-cover" width="600" height="450" />
            </div>
            <div class="p-5">
              <h3 class="text-lg font-semibold" style="font-family: var(--headline-font);">No user analysis loaded yet</h3>
              <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
                Complete intake and evidence analysis first. This area will then show role lanes from <code class="rounded bg-[var(--surface-wash)] px-1 py-0.5 text-xs">advisor.roleBriefs</code> instead of demo examples.
              </p>
              <a class="mt-4 inline-flex items-center gap-1.5 rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href="/intake">
                Start intake
                <Icon name="arrow-right" class="h-3.5 w-3.5" strokeWidth={2.1} />
              </a>
            </div>
          </div>
        </div>
        )}
      </section>

      <!-- ============ CAREER ASSET NEXT MOVES ============ -->
      <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6 shadow-[var(--shadow-card)]">
        <div class="flex items-center gap-2">
          <Icon name="assets" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
          <h2 class="text-xl" style="font-family: var(--headline-font);">Career asset next moves</h2>
        </div>
        <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
          {hasPersonalizedWorkbench
            ? "These are derived from the latest positioning, evidence ledger, and claim-safety notes."
            : "This will populate after the user saves an intake and runs analysis."}
        </p>
        <div class="mt-5 space-y-4">
          {userAssetGuidance.length ? userAssetGuidance.map((item) => (
            <article class="border-l-[3px] border-[var(--brass)] pl-4">
              <h3 class="font-semibold">{item.area}</h3>
              <p class="mt-1 text-sm leading-6 text-[var(--muted)]">{item.action}</p>
              <p class="mt-2 text-xs font-semibold text-[var(--warning)]">{item.guardrail}</p>
            </article>
          )) : (
            <p class="text-sm leading-6 text-[var(--muted)]">No asset guidance is available yet.</p>
          )}
        </div>
      </section>

      <!-- ============ PERSONAL ACTION BRIEFING ============ -->
      <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6 shadow-[var(--shadow-card)]">
        <div class="flex items-center gap-2">
          <Icon name="briefing" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
          <h2 class="text-xl" style="font-family: var(--headline-font);">Personal action briefing</h2>
        </div>
        <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
          {hasPersonalizedWorkbench
            ? "Pulled from remaining gaps, opportunity-mapping questions, and exploration experiments."
            : "This will become a weekly action list once the user has saved analysis data."}
        </p>
        <ol class="mt-5 space-y-3">
          {userBriefingActions.length ? userBriefingActions.map((item, index) => (
            <li class="flex gap-3 text-sm leading-6 text-[var(--muted)]">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--accent-soft)] text-xs font-semibold text-[var(--accent-strong)]">{index + 1}</span>
              <span class="pt-0.5">{item}</span>
            </li>
          )) : (
            <li class="text-sm leading-6 text-[var(--muted)]">No briefing actions are available yet.</li>
          )}
        </ol>
      </section>
    </div>
  </main>
</Layout>
