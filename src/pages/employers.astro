---
import Layout from "../layouts/Layout.astro";
import { navItems } from "../lib/cip/data";
import { watchedEmployerPresets } from "../lib/cip/watched-employers";
import { createServer } from "../lib/supabase/server";

type EmployerRow = {
  id: string;
  name: string;
  region: string;
  category: string;
  location: string | null;
  estimated_size: string | null;
  priority: string;
  fit_score: number;
  fit_summary: string;
  target_roles: string[];
  source_url: string | null;
  careers_url: string | null;
  adapter_status: string;
  confidence: string;
  source_notes: Array<{ label: string; value: string; url: string }>;
  last_reviewed_at: string | null;
};

let signedIn = false;
let employers: EmployerRow[] = [];
let loadError = "";

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();
    signedIn = Boolean(user);

    if (user) {
      const { data, error } = await supabase
        .from("watched_employers")
        .select("*")
        .eq("user_id", user.id)
        .order("fit_score", { ascending: false });

      if (error) loadError = error.message;
      else employers = (data ?? []) as EmployerRow[];
    }
  } catch (error) {
    loadError = error instanceof Error ? error.message : "Unable to load watched employers.";
  }
}

const presetCounts = watchedEmployerPresets.reduce(
  (acc, employer) => {
    acc[employer.region] = (acc[employer.region] ?? 0) + 1;
    return acc;
  },
  {} as Record<string, number>,
);
---

<Layout title="CIP Watched Employers">
  <main class="mx-auto w-full max-w-6xl px-5 py-8">
    <nav class="mb-8 flex flex-wrap gap-2">
      {navItems.map((item) => (
        <a class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold text-[var(--muted)] hover:text-[var(--foreground)]" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Watched Employer Assistant</p>
          <h1 class="mt-2 text-3xl font-semibold">Build a trusted target-employer map before chasing postings.</h1>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
            Seed region-specific employers, score them against your saved intake, then use the list to drive weekly research, adapter work, and outreach.
          </p>
        </div>
      </div>

      <form class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-5" hx-post="/api/employers/seed" hx-target="#employer-seed-result" hx-swap="innerHTML" hx-indicator="#employer-loading">
        <div class="flex flex-wrap items-center gap-3">
          <label class="inline-flex items-center gap-2 rounded-md border border-[var(--line)] bg-[var(--panel)] px-3 py-2 text-sm">
            <input class="h-4 w-4 accent-[var(--accent)]" type="checkbox" name="regions" value="upper_valley" checked />
            <span>Upper Valley ({presetCounts.upper_valley ?? 0})</span>
          </label>
          <label class="inline-flex items-center gap-2 rounded-md border border-[var(--line)] bg-[var(--panel)] px-3 py-2 text-sm">
            <input class="h-4 w-4 accent-[var(--accent)]" type="checkbox" name="regions" value="northeast_kingdom" checked />
            <span>Northeast Kingdom ({presetCounts.northeast_kingdom ?? 0})</span>
          </label>
          <button class="rounded-md bg-[var(--foreground)] px-4 py-2 text-sm font-semibold text-[var(--background)] htmx-request:opacity-60" type="submit" disabled={!signedIn}>
            Build watched-employer map
          </button>
        </div>
        <div id="employer-loading" class="htmx-indicator mt-4">
          <div class="flex items-center gap-3 text-sm font-semibold text-[var(--accent-strong)]">
            <span class="h-4 w-4 animate-spin rounded-full border-2 border-[var(--line)] border-t-[var(--accent)]"></span>
            Scoring employers against your saved career profile...
          </div>
        </div>
        <div id="employer-seed-result" class="mt-4"></div>
      </form>

      {loadError ? (
        <p class="mt-5 rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-800">{loadError}</p>
      ) : null}

      <div class="mt-6 grid gap-3 md:grid-cols-4">
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Watched</p>
          <p class="mt-2 text-2xl font-semibold">{employers.length}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">High priority</p>
          <p class="mt-2 text-2xl font-semibold">{employers.filter((item) => ["critical", "high"].includes(item.priority)).length}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Needs adapter</p>
          <p class="mt-2 text-2xl font-semibold">{employers.filter((item) => item.adapter_status === "needs_adapter").length}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Manual review</p>
          <p class="mt-2 text-2xl font-semibold">{employers.filter((item) => item.adapter_status === "manual_review").length}</p>
        </div>
      </div>

      <div class="mt-6 grid gap-4">
        {employers.length ? employers.map((employer) => (
          <article class="grid gap-4 rounded-md border border-[var(--line)] bg-[var(--background)] p-5 lg:grid-cols-[1fr_auto]">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <h2 class="text-xl font-semibold">{employer.name}</h2>
                <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{employer.region.replace("_", " ")}</span>
                <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{employer.category}</span>
              </div>
              <p class="mt-2 text-sm text-[var(--muted)]">{employer.location} - {employer.estimated_size}</p>
              <p class="mt-4 text-sm leading-6 text-[var(--muted)]">{employer.fit_summary}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {employer.target_roles.map((role) => (
                  <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--foreground)]">{role}</span>
                ))}
              </div>
              {employer.source_notes?.length ? (
                <div class="mt-4 space-y-1 text-xs text-[var(--muted)]">
                  {employer.source_notes.map((note) => (
                    <p><span class="font-semibold">{note.label}:</span> {note.value}</p>
                  ))}
                </div>
              ) : null}
            </div>
            <div class="flex min-w-40 flex-col items-start gap-2 lg:items-end">
              <span class="text-3xl font-semibold text-[var(--accent-strong)]">{employer.fit_score}%</span>
              <span class="rounded-md bg-[rgba(14,124,134,0.12)] px-2 py-1 text-xs font-semibold">{employer.priority} priority</span>
              <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{employer.adapter_status.replace("_", " ")}</span>
              <div class="mt-2 flex flex-wrap gap-2 lg:justify-end">
                {employer.source_url ? <a class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href={employer.source_url} target="_blank" rel="noreferrer">Source</a> : null}
                {employer.careers_url ? <a class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href={employer.careers_url} target="_blank" rel="noreferrer">Careers</a> : null}
              </div>
            </div>
          </article>
        )) : (
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
            <h2 class="text-xl font-semibold">No watched employers yet</h2>
            <p class="mt-3 text-sm leading-6 text-[var(--muted)]">Save your intake, then build the watched-employer map for Upper Valley and Northeast Kingdom.</p>
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>
