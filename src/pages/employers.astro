---
import Layout from "../layouts/Layout.astro";
import { canRunLiveBusinessSearch } from "../lib/cip/business-search-engine";
import { createServer } from "../lib/supabase/server";

type EmployerRow = {
  id: string;
  name: string;
  region: string;
  category: string;
  location: string | null;
  estimated_size: string | null;
  priority: string;
  fit_score: number;
  fit_summary: string;
  target_roles: string[];
  source_url: string | null;
  careers_url: string | null;
  adapter_status: string;
  confidence: string;
  source_notes: Array<{ label: string; value: string; url: string }>;
  last_reviewed_at: string | null;
};

type CandidateRow = EmployerRow & {
  discovery_channel: string;
  discovery_source_names: string[];
  review_state: string;
};

type SourceRow = {
  id: string;
  name: string;
  region: string;
  source_type: string;
  url: string;
  access_type: string;
  usefulness_score: number;
  notes: string;
};

const regionFocus = {
  lake_sunapee: {
    label: "Lake Sunapee",
    center: "Sunapee, NH",
    radius: "50 miles",
    municipalities: ["Sunapee", "New London", "Newport", "Claremont", "Sutton", "Warner"],
  },
  upper_valley: {
    label: "Upper Valley",
    center: "Hanover / Lebanon, NH",
    radius: "50 miles",
    municipalities: ["Hanover", "Lebanon", "Norwich", "Hartford", "Claremont", "Windsor"],
  },
  northeast_kingdom: {
    label: "Northeast Kingdom",
    center: "St. Johnsbury / Newport, VT",
    radius: "regional",
    municipalities: ["St. Johnsbury", "Newport", "Lyndon", "Burke", "Derby", "Barton"],
  },
  burlington_area: {
    label: "Burlington Area",
    center: "Burlington, VT",
    radius: "50 miles",
    municipalities: ["Burlington", "South Burlington", "Winooski", "Colchester", "Essex", "Williston"],
  },
} as const;

let signedIn = false;
let employers: EmployerRow[] = [];
let candidates: CandidateRow[] = [];
let sources: SourceRow[] = [];
let loadError = "";

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();
    signedIn = Boolean(user);

    if (user) {
      const { data, error } = await supabase
        .from("watched_employers")
        .select("*")
        .eq("user_id", user.id)
        .order("fit_score", { ascending: false });

      if (error) loadError = error.message;
      else employers = (data ?? []) as EmployerRow[];

      const { data: candidateData } = await supabase
        .from("employer_candidates")
        .select("*")
        .eq("user_id", user.id)
        .order("fit_score", { ascending: false });
      candidates = (candidateData ?? []) as CandidateRow[];

      const { data: sourceData } = await supabase
        .from("discovery_sources")
        .select("*")
        .eq("user_id", user.id)
        .order("usefulness_score", { ascending: false });
      sources = (sourceData ?? []) as SourceRow[];
    }
  } catch (error) {
    loadError = error instanceof Error ? error.message : "Unable to load watched employers.";
  }
}

const savedRegionKeys = [...new Set([...sources.map((source) => source.region), ...candidates.map((candidate) => candidate.region)])];
const focusRegions = savedRegionKeys;
const liveBusinessSearchEnabled = canRunLiveBusinessSearch();
const geocodioEnabled = Boolean(import.meta.env.GEOCODIO_API_KEY);
const savedEmployerNames = new Set(employers.map((employer) => normalizeEmployerName(employer.name)));
const visibleCandidates = candidates.filter((candidate) => {
  const alreadySaved = savedEmployerNames.has(normalizeEmployerName(candidate.name));
  return candidate.review_state !== "promoted" && !alreadySaved;
});

function normalizeEmployerName(name: string) {
  return name.trim().toLowerCase().replace(/\s+/g, " ");
}
---

<Layout title="CIP Watched Employers">
  <main class="cip-page-shell min-h-screen">
  <div class="mx-auto w-full max-w-6xl px-5 py-8">
    <section class="cip-card rounded-lg p-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Watched Employer Assistant</p>
          <h1 class="mt-2 max-w-4xl text-4xl font-semibold tracking-tight">Find credible employers before chasing postings.</h1>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
            Start with a place, expand it into a real labor-market area, then save source-backed businesses worth watching.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <p class={`inline-flex rounded-md px-2 py-1 text-xs font-semibold ${liveBusinessSearchEnabled ? "cip-pill" : "bg-yellow-50 text-yellow-800"}`}>
              {liveBusinessSearchEnabled ? "Live AI web search enabled" : "Live business search not configured: add OPENAI_API_KEY"}
            </p>
            <p class={`inline-flex rounded-md px-2 py-1 text-xs font-semibold ${geocodioEnabled ? "cip-pill" : "bg-[var(--background)] text-[var(--muted)]"}`}>
              {geocodioEnabled ? "GeoCodio primary geocoder active" : "GeoCodio not configured; fallback geocoder will be used"}
            </p>
          </div>
        </div>
      </div>

      <form class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-5 shadow-sm" hx-post="/api/employers/discover" hx-target="#employer-discovery-result" hx-swap="innerHTML" hx-indicator="#employer-discovery-loading">
        <div>
          <h2 class="text-lg font-semibold">Find businesses by geography</h2>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
            Runs a live web-backed employer discovery pass. It should find chambers, economic development groups, municipalities, school systems, business directories, and employer-owned career pages for the geography you enter.
          </p>
        </div>
        <div class="mt-4 grid gap-4 lg:grid-cols-[1fr_1.2fr_0.8fr]">
          <label class="grid gap-2 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <span class="text-sm font-semibold">Geography</span>
            <input name="custom_geography" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm" placeholder="Sunapee, NH; Burlington, VT; Portland, ME..." />
            <span class="text-xs text-[var(--muted)]">Start here. The search uses the exact place you enter; fixture/preset employers are not returned as normal search results.</span>
            {signedIn && (sources.length > 0 || candidates.length > 0) ? (
            <details class="mt-3">
              <summary class="cursor-pointer text-sm font-semibold text-[var(--muted)]">Reuse saved search areas</summary>
              <div class="mt-3 grid gap-2 text-sm">
                {savedRegionKeys.map((region) => (
                  <label class="inline-flex items-center gap-2">
                    <input class="h-4 w-4 accent-[var(--accent)]" type="checkbox" name="regions" value={region} />
                    <span>{region}</span>
                  </label>
                ))}
            </div>
            </details>
            ) : null}
          </label>

          <fieldset class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <legend class="px-1 text-sm font-semibold">Sectors</legend>
            <div class="mt-3 grid gap-2 text-sm">
              {["healthcare", "education", "municipality", "technology", "manufacturing", "communications", "operations", "community"].map((sector) => (
                <label class="inline-flex items-center gap-2">
                  <input class="h-4 w-4 accent-[var(--accent)]" type="checkbox" name="sectors" value={sector} />
                  <span>{sector}</span>
                </label>
              ))}
            </div>
          </fieldset>

          <label class="grid gap-2 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <span class="text-sm font-semibold">Minimum employer size</span>
            <select name="minimum_size" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm">
              <option value="100" selected>100+ or likely 100+</option>
              <option value="500">500+ or large regional anchor</option>
              <option value="any">Any strategic size</option>
            </select>
            <span class="text-sm font-semibold">Search radius</span>
            <select name="radius_miles" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm">
              <option value="25">25 miles</option>
              <option value="50" selected>50 miles</option>
              <option value="100">100 miles</option>
              <option value="150">150 miles</option>
            </select>
            <button class="cip-fancy-button mt-2" type="submit">
              <span>Search businesses</span>
            </button>
            {!signedIn ? (
              <span class="text-xs font-semibold text-[var(--warning)]">Sign in to save search results.</span>
            ) : null}
          </label>
        </div>
        <div id="employer-discovery-loading" class="htmx-indicator mt-4">
          <div class="flex items-center gap-3 text-sm font-semibold text-[var(--accent-strong)]">
            <span class="h-4 w-4 animate-spin rounded-full border-2 border-[var(--line)] border-t-[var(--accent)]"></span>
            <span class="loading-phrases">
              <span>Geocoding the search center...</span>
              <span>Expanding the radius into nearby towns...</span>
              <span>Searching chambers and regional directories...</span>
              <span>Checking anchor employers and career pages...</span>
              <span>Preparing source-backed candidates...</span>
            </span>
          </div>
        </div>
        <div id="employer-discovery-result" class="mt-4"></div>
      </form>

      {loadError ? (
        <p class="mt-5 rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-800">{loadError}</p>
      ) : null}

      <section class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
        <div>
          <h2 class="text-xl font-semibold">Saved business totals</h2>
          <p class="mt-2 text-sm text-[var(--muted)]">These totals are global saved records for your account, not the latest search result.</p>
        </div>
        <div class="mt-4 grid gap-3 md:grid-cols-4">
          <div class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
            <p class="text-xs font-semibold uppercase text-[var(--muted)]">Saved total</p>
            <p class="mt-2 text-2xl font-semibold">{employers.length}</p>
          </div>
          <div class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
            <p class="text-xs font-semibold uppercase text-[var(--muted)]">Critical/high saved</p>
            <p class="mt-2 text-2xl font-semibold">{employers.filter((item) => ["critical", "high"].includes(item.priority)).length}</p>
          </div>
          <div class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
            <p class="text-xs font-semibold uppercase text-[var(--muted)]">Saved needs adapter</p>
            <p class="mt-2 text-2xl font-semibold">{employers.filter((item) => item.adapter_status === "needs_adapter").length}</p>
          </div>
          <div class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
            <p class="text-xs font-semibold uppercase text-[var(--muted)]">Saved manual review</p>
            <p class="mt-2 text-2xl font-semibold">{employers.filter((item) => item.adapter_status === "manual_review").length}</p>
          </div>
        </div>
      </section>

      <section class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-xl font-semibold">Area focus</h2>
            <p class="mt-2 text-sm text-[var(--muted)]">The search expands from the geography into nearby municipalities and regional business ecosystems.</p>
          </div>
          <span class="cip-pill rounded-md px-2 py-1 text-xs font-semibold">{sources.length} source directories</span>
        </div>
        <div class="mt-4 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
          <div class="relative min-h-72 overflow-hidden rounded-md border border-[var(--line)] bg-[linear-gradient(135deg,rgba(126,217,87,0.18),transparent_55%),var(--panel)] p-5">
            <div class="absolute left-1/2 top-1/2 h-44 w-44 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[var(--accent)] opacity-30"></div>
            <div class="absolute left-1/2 top-1/2 h-28 w-28 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[var(--accent)] opacity-40"></div>
            <div class="absolute left-1/2 top-1/2 h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--accent)]"></div>
            <div class="relative z-10">
              <p class="text-xs font-semibold uppercase text-[var(--muted)]">Search radius model</p>
              <h3 class="mt-2 text-2xl font-semibold">Map layer not implemented yet</h3>
              <p class="mt-3 max-w-sm text-sm leading-6 text-[var(--muted)]">
                This placeholder will become the geography map layer. For now, the engine returns source pages and employer candidates as text results below the search form.
              </p>
            </div>
          </div>
          <div class="grid gap-3">
            {focusRegions.length ? focusRegions.map((region) => {
              const focus = regionFocus[region as keyof typeof regionFocus];
              return focus ? (
                <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
                  <div class="flex flex-wrap items-center justify-between gap-2">
                    <h3 class="font-semibold">{focus.label}</h3>
                    <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{focus.radius}</span>
                  </div>
                  <p class="mt-2 text-sm text-[var(--muted)]">Centered on {focus.center}</p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    {focus.municipalities.map((town) => (
                      <span class="rounded-md border border-[var(--line)] bg-[var(--background)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{town}</span>
                    ))}
                  </div>
                </article>
              ) : (
                <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
                  <h3 class="font-semibold">{region.replaceAll("_", " ")}</h3>
                  <p class="mt-2 text-sm text-[var(--muted)]">Saved search area from your live employer discovery results.</p>
                </article>
              );
            }) : (
              <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
                <h3 class="font-semibold">No active search area yet</h3>
                <p class="mt-2 text-sm text-[var(--muted)]">Run a geography search to populate source pages, employer candidates, and saved search areas.</p>
              </article>
            )}
          </div>
        </div>
        <details class="mt-4">
          <summary class="cursor-pointer text-sm font-semibold text-[var(--muted)]">View saved source pages</summary>
          <div class="mt-3 grid gap-3 md:grid-cols-2">
            {sources.length ? sources.map((source) => (
              <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="font-semibold">{source.name}</h3>
                  <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{source.source_type}</span>
                </div>
                <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{source.notes}</p>
                <a class="mt-3 inline-block text-sm font-semibold text-[var(--accent-strong)] hover:underline" href={source.url} target="_blank" rel="noreferrer">Open source</a>
              </article>
            )) : (
              <p class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4 text-sm text-[var(--muted)]">No source pages saved yet. Live search results will appear here after you run a search while signed in.</p>
            )}
          </div>
        </details>
      </section>

      <section class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-xl font-semibold">Employer candidates</h2>
            <p class="mt-2 text-sm text-[var(--muted)]">This is the saved candidate queue from previous searches. Current search results can now be saved directly from the result panel above.</p>
          </div>
          <span class="cip-pill rounded-md px-2 py-1 text-xs font-semibold">{visibleCandidates.length} candidates</span>
        </div>
        <form id="candidate-queue-form" class="mt-4" hx-post="/api/employers/promote" hx-target="#candidate-promote-result" hx-swap="innerHTML">
          <div class="grid gap-3">
            {visibleCandidates.length ? visibleCandidates.map((candidate) => (
              <label class="grid gap-3 rounded-md border border-[var(--line)] bg-[var(--panel)] p-4 md:grid-cols-[auto_1fr_auto]">
                <input class="mt-1 h-4 w-4 accent-[var(--accent)]" type="checkbox" name="candidate_ids" value={candidate.id} checked={candidate.review_state === "pending"} />
                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <h3 class="font-semibold">{candidate.name}</h3>
                    <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{candidate.region.replace("_", " ")}</span>
                    <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{candidate.discovery_channel.replace("_", " ")}</span>
                    <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{candidate.review_state}</span>
                  </div>
                  <p class="mt-2 text-sm text-[var(--muted)]">{candidate.location} - {candidate.estimated_size}</p>
                  <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{candidate.fit_summary}</p>
                  <p class="mt-2 text-xs text-[var(--muted)]">Sources: {candidate.discovery_source_names?.join(", ")}</p>
                </div>
                <div class="flex min-w-28 flex-col items-start gap-2 md:items-end">
                  <span class="text-2xl font-semibold text-[var(--accent-strong)]">{candidate.fit_score}%</span>
                  <span class="cip-pill rounded-md px-2 py-1 text-xs font-semibold">{candidate.priority}</span>
                </div>
              </label>
            )) : (
              <div class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
                <p class="text-sm text-[var(--muted)]">No unsaved candidates in the queue. Run employer discovery above to find more source-backed businesses.</p>
              </div>
            )}
          </div>
          {visibleCandidates.length ? (
            <div class="mt-4 flex flex-wrap gap-2">
              <button class="cip-fancy-button" type="submit">
                <span>Save selected businesses</span>
              </button>
              <button
                class="cip-fancy-button cip-fancy-button-secondary"
                type="button"
                data-clear-candidates="selected"
              >
                <span>Clear selected</span>
              </button>
              <button
                class="cip-fancy-button cip-fancy-button-warning"
                type="button"
                data-clear-candidates="all_unpromoted"
              >
                <span>Clear all unpromoted</span>
              </button>
            </div>
          ) : null}
          <div id="candidate-promote-result" class="mt-4"></div>
        </form>
      </section>

      <div class="mt-6 grid gap-4">
        <div>
          <h2 class="text-xl font-semibold">Saved businesses</h2>
          <p class="mt-2 text-sm text-[var(--muted)]">These are all watched businesses currently saved to your account, including older seeded/test records until you remove or archive them.</p>
        </div>
        {employers.length ? employers.map((employer) => (
          <article class="grid gap-4 rounded-md border border-[var(--line)] bg-[var(--background)] p-5 lg:grid-cols-[1fr_auto]">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <h2 class="text-xl font-semibold">{employer.name}</h2>
                <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{employer.region.replace("_", " ")}</span>
                <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{employer.category}</span>
              </div>
              <p class="mt-2 text-sm text-[var(--muted)]">{employer.location} - {employer.estimated_size}</p>
              <p class="mt-4 text-sm leading-6 text-[var(--muted)]">{employer.fit_summary}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {employer.target_roles.map((role) => (
                  <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--foreground)]">{role}</span>
                ))}
              </div>
              {employer.source_notes?.length ? (
                <div class="mt-4 space-y-1 text-xs text-[var(--muted)]">
                  {employer.source_notes.map((note) => (
                    <p><span class="font-semibold">{note.label}:</span> {note.value}</p>
                  ))}
                </div>
              ) : null}
            </div>
            <div class="flex min-w-40 flex-col items-start gap-2 lg:items-end">
              <span class="text-3xl font-semibold text-[var(--accent-strong)]">{employer.fit_score}%</span>
              <span class="cip-pill rounded-md px-2 py-1 text-xs font-semibold">{employer.priority} priority</span>
              <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{employer.adapter_status.replace("_", " ")}</span>
              <div class="mt-2 flex flex-wrap gap-2 lg:justify-end">
                {employer.source_url ? <a class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href={employer.source_url} target="_blank" rel="noreferrer">Source</a> : null}
                {employer.careers_url ? <a class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href={employer.careers_url} target="_blank" rel="noreferrer">Careers</a> : null}
              </div>
            </div>
          </article>
        )) : (
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
            <h2 class="text-xl font-semibold">No saved businesses yet</h2>
            <p class="mt-3 text-sm leading-6 text-[var(--muted)]">Search a geography, review employer candidates, then save the businesses you want to monitor.</p>
          </div>
        )}
      </div>
    </section>
  </div>
  </main>
  <style>
    .loading-phrases {
      display: inline-grid;
      min-width: min(100%, 24rem);
    }

    .loading-phrases span {
      animation: loading-phrase-cycle 10s infinite;
      grid-area: 1 / 1;
      opacity: 0;
    }

    .loading-phrases span:nth-child(2) {
      animation-delay: 2s;
    }

    .loading-phrases span:nth-child(3) {
      animation-delay: 4s;
    }

    .loading-phrases span:nth-child(4) {
      animation-delay: 6s;
    }

    .loading-phrases span:nth-child(5) {
      animation-delay: 8s;
    }

    @keyframes loading-phrase-cycle {
      0%, 100% {
        opacity: 0;
      }
      8%, 18% {
        opacity: 1;
      }
      26% {
        opacity: 0;
      }
    }
  </style>
  <script>
    document.addEventListener("click", async (event) => {
      const button = (event.target as Element | null)?.closest<HTMLButtonElement>("[data-clear-candidates]");
      if (!button) return;

      const mode = button.getAttribute("data-clear-candidates") || "selected";
      const form = document.getElementById("candidate-queue-form");
      const result = document.getElementById("candidate-promote-result");
      if (!form || !result) return;

      const payload = new FormData();
      payload.set("mode", mode);

      if (mode === "selected") {
        const checked = form.querySelectorAll('input[name="candidate_ids"]:checked');
        if (!checked.length) {
          result.innerHTML = '<p class="text-sm text-red-700">Select at least one candidate to clear.</p>';
          return;
        }
        checked.forEach((input) => payload.append("candidate_ids", input.value));
      }

      button.setAttribute("aria-disabled", "true");
      button.disabled = true;
      result.innerHTML = '<p class="text-sm font-semibold text-[var(--accent-strong)]">Updating candidate queue...</p>';

      try {
        const response = await fetch("/api/employers/candidates/clear", {
          method: "POST",
          body: payload,
          credentials: "same-origin",
        });
        const html = await response.text();
        result.innerHTML = html;
        if (response.ok) {
          window.setTimeout(() => window.location.reload(), 250);
        }
      } catch {
        result.innerHTML = '<p class="text-sm text-red-700">Unable to clear candidates. Try again.</p>';
      } finally {
        button.disabled = false;
        button.removeAttribute("aria-disabled");
      }
    });
  </script>
</Layout>
