---
import Layout from "../layouts/Layout.astro";
import type { NetworkAnalysis } from "../lib/cip/network-intelligence";
import { createServer } from "../lib/supabase/server";

let signedIn = false;
let networkCounts = {
  imports: 0,
  analyses: 0,
};
let latestNetworkAnalysis: NetworkAnalysis | null = null;
let latestNetworkAnalysisAt: string | null = null;
let loadError = "";
let recentConversationNotes: Array<{ title: string | null; created_at: string }> = [];
let conversationNoteCount = 0;

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();
    signedIn = Boolean(user);

    if (user) {
      const [{ count: importCount }, { count: analysisCount }, { data: analysisRow }] = await Promise.all([
        supabase
          .from("career_sources")
          .select("id", { count: "exact", head: true })
          .eq("user_id", user.id)
          .eq("source_type", "network_import"),
        supabase
          .from("career_sources")
          .select("id", { count: "exact", head: true })
          .eq("user_id", user.id)
          .eq("source_type", "network_analysis"),
        supabase
          .from("career_sources")
          .select("extracted_text, created_at")
          .eq("user_id", user.id)
          .eq("source_type", "network_analysis")
          .order("created_at", { ascending: false })
          .limit(1)
          .maybeSingle(),
      ]);

      networkCounts = {
        imports: importCount ?? 0,
        analyses: analysisCount ?? 0,
      };
      latestNetworkAnalysis = parseNetworkAnalysis(analysisRow?.extracted_text ?? null);
      latestNetworkAnalysisAt = analysisRow?.created_at ?? null;

      const [{ count: noteCount }, { data: noteRows }] = await Promise.all([
        supabase
          .from("career_sources")
          .select("id", { count: "exact", head: true })
          .eq("user_id", user.id)
          .eq("source_type", "conversation_outcome"),
        supabase
          .from("career_sources")
          .select("title, created_at")
          .eq("user_id", user.id)
          .eq("source_type", "conversation_outcome")
          .order("created_at", { ascending: false })
          .limit(5),
      ]);
      conversationNoteCount = noteCount ?? 0;
      recentConversationNotes = noteRows ?? [];
    }
  } catch (error) {
    loadError = error instanceof Error ? error.message : "Unable to load network intelligence state.";
  }
}

function parseNetworkAnalysis(value: string | null): NetworkAnalysis | null {
  if (!value) return null;
  try {
    const parsed = JSON.parse(value);
    return parsed?.analysis ?? null;
  } catch {
    return null;
  }
}

const linkedinSteps = [
  {
    title: "Download your LinkedIn connections archive",
    steps: [
      "Open LinkedIn on desktop.",
      "Click Me, then Settings & Privacy.",
      "Open Data privacy.",
      "Under How LinkedIn uses your data, choose Get a copy of your data.",
      "Request the larger archive that includes connections, contacts, account history, and inferred profile data.",
      "Watch your primary email for LinkedIn's download link, then save the ZIP file.",
    ],
    note: "LinkedIn may take up to 24 hours to prepare the archive. The connection export can include names, company, position, profile URL, connection date, and sometimes email. Emails may be missing because contacts control whether their email is exportable.",
  },
  {
    title: "Save your LinkedIn profile PDF",
    steps: [
      "Open LinkedIn on desktop.",
      "Click Me, then View profile.",
      "In the intro section, click More or Resources.",
      "Choose Save to PDF if the option is available.",
    ],
    note: "LinkedIn says this is desktop-only and may depend on profile language and account availability. If the option is missing, paste your headline, About section, Experience, Featured links, and Skills manually.",
  },
];

const dataTypes = [
  {
    label: "LinkedIn connections",
    value: "Best for finding people at target employers, adjacent companies, alumni paths, and former coworker routes.",
  },
  {
    label: "LinkedIn profile PDF",
    value: "Best for comparing the public profile against the new master resume and identifying profile gaps.",
  },
  {
    label: "Alumni and community lists",
    value: "Best for warm context through alumni portals, career-office mentoring platforms, regional clubs, affinity groups, and public event lists.",
  },
  {
    label: "Manual relationship notes",
    value: "Best for relationship strength, history, comfort level, and whether a request would feel appropriate.",
  },
];

const alumniSources = [
  {
    label: "Official alumni portals",
    value: "Use directories or mentoring platforms only when the user has legitimate member access.",
  },
  {
    label: "Career services platforms",
    value: "Some schools provide alumni mentoring databases, career communities, or school-approved networking tools.",
  },
  {
    label: "LinkedIn alumni search",
    value: "University pages can expose alumni search filters for geography, employer, field, and graduation era.",
  },
  {
    label: "Alumni clubs and affinity groups",
    value: "Regional chapters, professional groups, and identity-based communities often create warmer context than cold outreach.",
  },
  {
    label: "Public event and speaker lists",
    value: "Conference pages, newsletters, panels, and public chapter events can reveal people already active in the community.",
  },
  {
    label: "Manual notes",
    value: "The user can add people they know personally, classmates, faculty contacts, or introductions they would feel comfortable asking for.",
  },
];

const networkOutputs = [
  "Career lane validation: which proposed directions have named people, employer overlap, or useful weak ties.",
  "Employer-contact overlap: who is connected to saved or target employers.",
  "Warm-introduction paths: who could provide advice, context, or a respectful referral route.",
  "Context pools: groups like Rotary, BNI, alumni networks, and former employers held as context until tied to named people.",
  "Weekly relationship moves: a small prioritized list instead of a massive outreach chore.",
  "Outreach drafts by intent: reconnect, market read, informational interview, referral request, follow-up, and thank-you.",
  "Profile/content recommendations: what to update or post before reaching out.",
  "Relationship status tracking: contacted, replied, intro offered, follow-up due, or not a fit.",
];

const marketReadReasons = [
  "Job titles mean different things across employers, so people can help translate what to search for.",
  "Salary bands, remote policies, and management scope are often clearer in conversation than in postings.",
  "A familiar local employer can be useful context without being the right target.",
  "The user can test a lane before rewriting assets, applying heavily, or asking for a referral.",
];

const marketReadSteps = [
  {
    title: "Pick the weekly batch",
    detail: "Choose three to five people from the list. Do not turn the whole network readout into an outreach chore.",
  },
  {
    title: "Assign the intent",
    detail: "Mark each person as market read, reconnection, employer context, role translation, intro later, referral later, or park.",
  },
  {
    title: "Ask one useful question",
    detail: "Start with titles, teams, pay reality, proof points, hiring process, or employers worth studying.",
  },
  {
    title: "Record what changed",
    detail: "After the conversation, capture confirmed lanes, rejected lanes, salary evidence, new people, new employers, and asset gaps.",
  },
];

const relationshipSignals = [
  "Career lane relevance",
  "Current company or recent employer",
  "Title and seniority",
  "Target industry overlap",
  "Geography or remote-market relevance",
  "Alumni, coworker, community, or event overlap",
  "Context pool vs named person",
  "Connection date or relationship freshness",
  "User-rated relationship strength",
];

const idealWorkQuestions = [
  {
    id: "ideal_target_roles",
    label: "Target roles or lanes",
    placeholder: "Example: AI operations strategy, product enablement, customer education, workflow automation leadership",
    type: "textarea",
  },
  {
    id: "ideal_compensation_floor",
    label: "Compensation floor and seniority",
    placeholder: "Example: $120K+ base, senior IC or manager scope, no entry-level resets",
    type: "input",
  },
  {
    id: "ideal_work_model",
    label: "Work model",
    placeholder: "Example: remote-first preferred; hybrid possible for unusually strong fit",
    type: "input",
  },
  {
    id: "ideal_geography_scope",
    label: "Geography scope",
    placeholder: "Example: remote/national first, New England hybrid second, Upper Valley only if pay and scope are real",
    type: "textarea",
  },
  {
    id: "ideal_workplace",
    label: "Ideal workplace traits",
    placeholder: "Example: modern comp practices, clear decision-making, respectful of senior experience, practical AI adoption",
    type: "textarea",
  },
  {
    id: "ideal_stretch_goals",
    label: "Stretch goals",
    placeholder: "Example: grow into product strategy, lead AI adoption, move beyond local labor-market ceilings",
    type: "textarea",
  },
  {
    id: "ideal_dealbreakers",
    label: "Dealbreakers and caution flags",
    placeholder: "Example: low pay bands, vague management scope, mandatory onsite for work that can be remote, outdated tooling",
    type: "textarea",
  },
  {
    id: "ideal_local_anchor_notes",
    label: "Local anchor notes",
    placeholder: "Example: Dartmouth College is useful for market reads but should not be prioritized unless compensation and senior scope are proven.",
    type: "textarea",
  },
];
---

<Layout title="CIP Network Intelligence">
  <main class="mx-auto w-full max-w-6xl px-5 py-8">
    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Network Intelligence</p>
      <h1 class="mt-2 max-w-4xl text-3xl font-semibold">Turn relationship data into warm, respectful career moves.</h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        The next step after career assets is not sending a flood of messages. It is finding the people who can help you understand a market, identify hidden opportunities, and approach the right employers with context.
      </p>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h2 class="text-lg font-semibold">Why this matters</h2>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
            Many strong opportunities move through weak ties: former coworkers, alumni, community contacts, and people adjacent to target employers.
          </p>
        </article>
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h2 class="text-lg font-semibold">What good looks like</h2>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
            A short weekly list of high-quality conversations: advice, market reads, warm introductions, and thoughtful follow-ups.
          </p>
        </article>
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h2 class="text-lg font-semibold">What we avoid</h2>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
            No scraping, no private-network surveillance, no spam. CIP uses information you provide and asks for approval before outreach.
          </p>
        </article>
      </div>
    </section>

    <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Trust boundary</p>
      <h2 class="mt-1 text-2xl font-semibold">Why CIP cannot just scrape LinkedIn</h2>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        Scraping logged-in LinkedIn pages can violate platform rules, create privacy risk, break without warning, and gather data people did not knowingly provide for this use. It can also damage user trust. CIP uses only data you provide directly: exported files, pasted notes, profile PDFs, and relationship context you choose to add. That boundary keeps the workflow professional, transparent, and reviewable.
      </p>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h3 class="font-semibold">Allowed inputs</h3>
          <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
            <li>LinkedIn data archive or connections CSV supplied by the user.</li>
            <li>LinkedIn profile PDF or pasted profile sections.</li>
            <li>Alumni portal contacts, school mentoring data, alumni club lists, coworker, community, event, and personal contact lists the user chooses to provide.</li>
            <li>Manual notes about relationship strength, history, and comfort level.</li>
          </ul>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h3 class="font-semibold">Not allowed</h3>
          <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
            <li>Automated scraping of private LinkedIn pages.</li>
            <li>Scraping or bypassing gated alumni directories, career-office portals, or member-only databases.</li>
            <li>Bypassing access controls, rate limits, or login protections.</li>
            <li>Implying CIP can inspect private connections directly.</li>
            <li>Generating outreach without the user's contact-specific approval.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Lane validation</p>
      <h2 class="mt-1 text-2xl font-semibold">Test career directions before asking for referrals.</h2>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        CIP now treats networking data as a way to validate career lanes first. A former coworker, Rotary chapter, BNI group, or alumni affiliation can be useful context, but it is not a recommendation by itself. The app should identify named people who can help test whether a lane is real, reachable, and worth pursuing.
      </p>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h3 class="font-semibold">Career lane first</h3>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
            Start with the user's current role hypotheses, then ask which contacts can validate those directions through market reads or employer context.
          </p>
        </article>
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h3 class="font-semibold">Named people only</h3>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
            Groups and affiliations are context pools until they connect to a specific person, company, title, and respectful first ask.
          </p>
        </article>
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h3 class="font-semibold">Market read before referral</h3>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
            The safest early move is often a short conversation about titles, expectations, and employers before asking anyone for a job lead.
          </p>
        </article>
      </div>
    </section>

    <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Ideal work filter</p>
      <h2 class="mt-1 text-2xl font-semibold">Start with the work life worth aiming for.</h2>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        Network data should not trap the user inside whoever is nearby or familiar. CIP should combine the LinkedIn profile, resume evidence, and these preferences before deciding which relationships are actually useful for advice, market reads, or introductions.
      </p>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h3 class="font-semibold">Fit before geography</h3>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">Remote, hybrid, national, regional, and local paths should all stay open until the user chooses a constraint.</p>
        </article>
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h3 class="font-semibold">Pay and scope matter</h3>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">Local anchors need evidence of compensation, seniority, and modern work practices before they become priority targets.</p>
        </article>
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <h3 class="font-semibold">Network keeps expanding</h3>
          <p class="mt-2 text-sm leading-6 text-[var(--muted)]">The first import is a starting map. As better-fit businesses and roles appear, CIP should ask what new relationship data would make the map stronger.</p>
        </article>
      </div>
    </section>

    <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Alumni data</p>
      <h2 class="mt-1 text-2xl font-semibold">Use university networks as permissioned warm context.</h2>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        Alumni data can be valuable, but it follows the same rule as LinkedIn: CIP uses information the user is allowed to access, export, paste, or summarize. The goal is not to mine a university database. The goal is to find legitimate shared context for thoughtful conversations.
      </p>
      <div class="mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {alumniSources.map((item) => (
          <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="font-semibold">{item.label}</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{item.value}</p>
          </article>
        ))}
      </div>
      <div class="mt-5 rounded-md border border-[var(--line)] bg-[var(--accent-soft)] p-4">
        <h3 class="font-semibold">How CIP uses alumni signals</h3>
        <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
          CIP treats shared school, program, region, club, or event history as a warm-context signal. It can help prioritize who to ask for market advice, employer context, or an introduction, but it does not turn an alumni connection into automatic permission to request a referral.
        </p>
      </div>
    </section>

    <section class="mt-6 grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
        <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Step 1</p>
        <h2 class="mt-1 text-2xl font-semibold">Gather LinkedIn data</h2>
        <div class="mt-5 space-y-4">
          {linkedinSteps.map((group) => (
            <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
              <h3 class="font-semibold">{group.title}</h3>
              <ol class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
                {group.steps.map((step) => <li>{step}</li>)}
              </ol>
              <p class="mt-3 text-xs leading-5 text-[var(--warning)]">{group.note}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
        <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Step 2</p>
        <h2 class="mt-1 text-2xl font-semibold">Bring the data into CIP</h2>
        <p class="mt-3 text-sm leading-6 text-[var(--muted)]">
          Answer the ideal-work questions, then upload the LinkedIn archive ZIP, Connections.csv, Excel contact sheet, profile PDF, text notes, or pasted relationship data. CIP will parse reviewable contacts, compare them against saved employers and the latest career analysis, then save a network-intelligence readout as an additive source record.
        </p>
        <div class="mt-4 grid gap-3 md:grid-cols-2">
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <p class="text-xs font-semibold uppercase text-[var(--muted)]">Saved network imports</p>
            <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{networkCounts.imports}</p>
          </div>
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <p class="text-xs font-semibold uppercase text-[var(--muted)]">Saved analyses</p>
            <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{networkCounts.analyses}</p>
          </div>
        </div>
        {loadError ? (
          <p class="mt-4 rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-800">{loadError}</p>
        ) : null}
        {!signedIn ? (
          <p class="mt-4 rounded-md border border-[var(--line)] bg-[var(--accent-soft)] p-3 text-sm font-semibold text-[var(--accent-strong)]">
            Sign in before importing network data so CIP can save the import and analysis.
          </p>
        ) : null}
        <form
          id="network-import-form"
          class="mt-5 grid gap-4"
          enctype="multipart/form-data"
          hx-encoding="multipart/form-data"
          hx-post="/api/network/import"
          hx-target="#network-import-result"
          hx-swap="innerHTML"
          hx-indicator="#network-import-loading"
        >
          <fieldset class="grid gap-4 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <legend class="px-1 text-sm font-semibold">Before CIP analyzes the network</legend>
            <p class="text-sm leading-6 text-[var(--muted)]">
              These answers tell CIP what a good opportunity looks like before it ranks contacts. Leave unknowns blank; uncertainty is useful signal too.
            </p>
            <div class="grid gap-4 md:grid-cols-2">
              {idealWorkQuestions.map((question) => (
                <label class="grid gap-2">
                  <span class="text-sm font-semibold">{question.label}</span>
                  {question.type === "textarea" ? (
                    <textarea
                      name={question.id}
                      class="min-h-24 rounded-md border border-[var(--line)] bg-[var(--panel)] p-3 text-sm"
                      placeholder={question.placeholder}
                    ></textarea>
                  ) : (
                    <input
                      name={question.id}
                      class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-3 text-sm"
                      type="text"
                      placeholder={question.placeholder}
                    />
                  )}
                </label>
              ))}
            </div>
          </fieldset>
          <label class="grid gap-2">
            <span class="text-sm font-semibold">LinkedIn archive, connections CSV, Excel sheet, or profile PDF</span>
            <input name="network_files" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm" type="file" accept=".zip,.csv,.xlsx,.pdf,.txt" multiple />
          </label>
          <label class="grid gap-2">
            <span class="text-sm font-semibold">Paste contacts, alumni lists, or relationship notes</span>
            <textarea
              name="relationship_notes"
              class="min-h-44 rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm"
              placeholder={`Example:\nName | Company | Title | LinkedIn URL | School/source | Relationship notes\nMorgan Lee | Dartmouth Health | Director of Product | https://linkedin.com/in/... | Dartmouth alumni portal | Former coworker, warm relationship`}
            ></textarea>
          </label>
          <label class="grid gap-2">
            <span class="text-sm font-semibold">Recommendation feedback or exclusions</span>
            <textarea
              name="network_feedback"
              class="min-h-28 rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm"
              placeholder={`Examples:\nRemove Christof Daetwyler - deceased / sensitive.\nRotary - Claremont Sugar River is my current club; do not treat it as a reconnection.\nExclude BNI as a Dartmouth Health path unless tied to a named person.`}
            ></textarea>
          </label>
          <button class="cip-fancy-button" type="submit" disabled={!signedIn}>
            <span>Import and analyze network</span>
          </button>
          <p id="network-import-status" class="text-sm font-semibold text-[var(--accent-strong)]" aria-live="polite">
            Ready to import supplied relationship data.
          </p>
          <p class="text-sm leading-6 text-[var(--muted)]">
            The first pass parses ZIP, CSV, XLSX, and TXT contact data, records supplied PDFs, and creates a reviewable warm-introduction analysis. Outreach still requires user approval and relationship review.
          </p>
        </form>
        <div id="network-import-loading" class="htmx-indicator cip-thinking-panel mt-5" role="status" aria-live="polite">
          <div class="cip-thinking-orbit" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Network analysis in progress</p>
            <div class="cip-thinking-lines" aria-hidden="true">
              <span>Reading ideal work preferences and LinkedIn/profile evidence...</span>
              <span>Reading supplied LinkedIn and relationship data...</span>
              <span>Parsing contacts into reviewable records...</span>
              <span>Comparing contacts against fit, compensation, work model, and employer targets...</span>
              <span>Looking for warm context and market-read paths...</span>
              <span>Saving the network intelligence artifact...</span>
            </div>
            <p class="sr-only">Importing and analyzing supplied network data.</p>
            <div class="cip-thinking-bar" aria-hidden="true"><span></span></div>
          </div>
        </div>
        <script>
          const networkImportForm = document.querySelector("#network-import-form");
          const networkImportStatus = document.querySelector("#network-import-status");
          const networkImportLoading = document.querySelector("#network-import-loading");

          if (networkImportForm && networkImportStatus) {
            networkImportForm.addEventListener("submit", () => {
              networkImportStatus.textContent = "Uploading and analyzing the supplied network data...";
              if (networkImportLoading instanceof HTMLElement) {
                networkImportLoading.style.display = "flex";
              }
            });
            networkImportForm.addEventListener("htmx:beforeRequest", () => {
              networkImportStatus.textContent = "Uploading and analyzing the supplied network data...";
              if (networkImportLoading instanceof HTMLElement) {
                networkImportLoading.style.display = "flex";
              }
            });
            networkImportForm.addEventListener("htmx:afterRequest", (event) => {
              networkImportStatus.textContent = event.detail?.successful
                ? "Network analysis finished. Review the results below."
                : "Network analysis did not complete. Review the message below or try the LinkedIn Connections.csv directly.";
              if (networkImportLoading instanceof HTMLElement) {
                networkImportLoading.style.display = "";
              }
            });
            networkImportForm.addEventListener("htmx:sendError", () => {
              networkImportStatus.textContent = "The browser could not send the import request. Check the file and try again.";
              if (networkImportLoading instanceof HTMLElement) {
                networkImportLoading.style.display = "";
              }
            });
            networkImportForm.addEventListener("htmx:responseError", () => {
              networkImportStatus.textContent = "The server returned an import error. Review the message below.";
              if (networkImportLoading instanceof HTMLElement) {
                networkImportLoading.style.display = "";
              }
            });
          }
        </script>
      </div>
    </section>
    <section class="mt-6" aria-live="polite">
      <div id="network-import-result"></div>
    </section>

    <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Loop back: conversation notes</p>
      <h2 class="mt-1 text-2xl font-semibold">Bring back what your advisors told you</h2>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        After market-read conversations, save what you learned here. Things change week to week: new employers come up, pay-band reality gets clearer, and your geography or work-model preferences may shift. These notes are additive evidence; the next network analysis and the next evidence re-analysis both read them, so the cycle actually updates instead of repeating itself.
      </p>
      <div class="mt-4 grid gap-2 sm:grid-cols-2">
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Saved conversation notes</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{conversationNoteCount}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Most recent</p>
          {recentConversationNotes.length ? (
            <ul class="mt-2 space-y-1 text-sm text-[var(--muted)]">
              {recentConversationNotes.map((note) => (
                <li>
                  <span class="font-semibold text-[var(--foreground)]">{note.title ?? "Conversation notes"}</span>
                  <span class="ml-1 text-xs">{new Date(note.created_at).toLocaleDateString()}</span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-2 text-sm text-[var(--muted)]">No conversation notes saved yet.</p>
          )}
        </div>
      </div>
      <form
        id="loopback-form"
        class="mt-5 grid gap-4"
        enctype="multipart/form-data"
        hx-encoding="multipart/form-data"
        hx-post="/api/network/loopback"
        hx-target="#loopback-result"
        hx-swap="innerHTML"
      >
        <label class="grid gap-2">
          <span class="text-sm font-semibold">Upload notes files (.txt, .md, .docx, .rtf, .json)</span>
          <input name="note_files" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm" type="file" accept=".txt,.md,.docx,.rtf,.json,.doc" multiple />
        </label>
        <label class="grid gap-2">
          <span class="text-sm font-semibold">Or paste conversation notes</span>
          <textarea
            name="conversation_notes"
            class="min-h-36 rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm"
            placeholder={`Useful things to capture:\nWho you talked to, their company/role, and the date.\nWhat they confirmed or weakened about a career lane, employer, or pay band.\nNew employers, teams, titles, or people they mentioned.\nAnything that changes your targets: geography, remote/hybrid, compensation floor, dealbreakers.`}
          ></textarea>
        </label>
        <button class="cip-fancy-button" type="submit" disabled={!signedIn}>
          <span>Save conversation notes</span>
        </button>
        <p class="text-sm leading-6 text-[var(--muted)]">
          Notes are saved as additive records; nothing earlier is overwritten. After saving, re-run the network analysis above or the evidence re-analysis on the Evidence page to fold the learnings in.
        </p>
      </form>
      <div id="loopback-result" class="mt-4" aria-live="polite"></div>
    </section>

    {latestNetworkAnalysis ? (
      <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Latest saved network analysis</p>
            <h2 class="mt-1 text-2xl font-semibold">Most recent saved readout</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-[var(--muted)]">
              This section shows the newest analysis saved before this page loaded. After a fresh import, review the new full-width result above or reload the page to refresh this saved view.
            </p>
          </div>
          {latestNetworkAnalysisAt ? (
            <span class="rounded-md border border-[var(--line)] bg-[var(--background)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">
              {new Date(latestNetworkAnalysisAt).toLocaleString()}
            </span>
          ) : null}
        </div>
        <p class="mt-4 text-sm leading-6 text-[var(--muted)]">{latestNetworkAnalysis.summary}</p>
        {latestNetworkAnalysis.sourceInventory?.length ? (
          <div class="mt-5 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">What CIP saw</h3>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
              {latestNetworkAnalysis.sourceInventory.slice(0, 8).map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ) : null}
        {latestNetworkAnalysis.laneValidations?.length ? (
          <div class="mt-5 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">Career lane validation</h3>
            <div class="mt-3 grid gap-3">
              {latestNetworkAnalysis.laneValidations.slice(0, 6).map((lane) => (
                <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <h4 class="font-semibold">{lane.lane}</h4>
                      <p class="mt-1 text-sm leading-6 text-[var(--muted)]">{lane.recommendedValidationAsk}</p>
                    </div>
                    <span class="rounded-md border border-[var(--line)] bg-[var(--background)] px-2 py-1 text-xs font-semibold text-[var(--accent-strong)]">
                      {lane.score}% {lane.status.replace("_", " ")}
                    </span>
                  </div>
                  {lane.namedPeople.length ? (
                    <p class="mt-3 text-sm leading-6 text-[var(--muted)]">
                      <span class="font-semibold text-[var(--foreground)]">Named people:</span> {lane.namedPeople.join(", ")}
                    </p>
                  ) : null}
                  {lane.missingEvidence.length ? (
                    <p class="mt-2 text-sm leading-6 text-[var(--warning)]">{lane.missingEvidence[0]}</p>
                  ) : null}
                </article>
              ))}
            </div>
          </div>
        ) : null}
        {latestNetworkAnalysis.contextPools?.length ? (
          <div class="mt-4 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">Context pools, not contacts</h3>
            <div class="mt-3 grid gap-3 lg:grid-cols-2">
              {latestNetworkAnalysis.contextPools.slice(0, 6).map((pool) => (
                <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
                  <div class="flex flex-wrap items-center gap-2">
                    <h4 class="font-semibold">{pool.label}</h4>
                    <span class="rounded-md border border-[var(--line)] bg-[var(--background)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{pool.type.replace("_", " ")}</span>
                  </div>
                  <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{pool.reason}</p>
                  <p class="mt-2 text-sm leading-6 text-[var(--accent-strong)]">{pool.nextStep}</p>
                </article>
              ))}
            </div>
          </div>
        ) : null}
        {latestNetworkAnalysis.relationshipCoaching?.length ? (
          <div class="mt-5 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">How to use this list</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
              Treat the network readout as a coaching queue, not a send list. The goal is to learn which paths are real before applying heavily, rewriting assets, or asking for referrals.
            </p>
            <ol class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
              {latestNetworkAnalysis.relationshipCoaching.slice(0, 8).map((item) => <li>{item}</li>)}
            </ol>
          </div>
        ) : null}
        {latestNetworkAnalysis.reconnectCandidates?.length ? (
          <div class="mt-5 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">Five reconnection candidates</h3>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
              {latestNetworkAnalysis.reconnectCandidates.slice(0, 5).map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ) : null}
        {latestNetworkAnalysis.reconnectQuestions?.length ? (
          <div class="mt-4 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">Questions to deepen these picks</h3>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
              {latestNetworkAnalysis.reconnectQuestions.slice(0, 10).map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ) : null}
        <div class="mt-5 grid gap-4 lg:grid-cols-2">
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">Top relationship moves</h3>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
              {latestNetworkAnalysis.weeklyMoves.slice(0, 6).map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">Warm paths</h3>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
              {latestNetworkAnalysis.topPaths.slice(0, 6).map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
        <div class="mt-5 flex flex-wrap gap-3">
          <a class="cip-fancy-button cip-fancy-button-secondary" href="/api/network/export?format=html" target="_blank" rel="noreferrer">
            <span>Open printable report</span>
          </a>
          <a class="cip-fancy-button cip-fancy-button-secondary" href="/api/network/export" download>
            <span>Download latest network readout</span>
          </a>
        </div>
        <p class="mt-2 text-sm leading-6 text-[var(--muted)]">To save a PDF, open the printable report, choose Print, then select Save as PDF.</p>
      </section>
    ) : null}

    <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Market-read coaching</p>
      <h2 class="mt-1 text-2xl font-semibold">Use the five-person list to learn what is real.</h2>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        A market read is a short perspective conversation. The user is not asking for a job yet; they are asking someone with relevant proximity to help understand titles, teams, pay bands, hiring reality, work model, proof points, and better-fit employers.
      </p>
      <div class="mt-5 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
          <h3 class="font-semibold">Why this works</h3>
          <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
            {marketReadReasons.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
          <h3 class="font-semibold">What happens next</h3>
          <div class="mt-3 grid gap-3">
            {marketReadSteps.map((item) => (
              <div class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-3">
                <h4 class="text-sm font-semibold">{item.title}</h4>
                <p class="mt-1 text-sm leading-6 text-[var(--muted)]">{item.detail}</p>
              </div>
            ))}
          </div>
        </article>
      </div>
      <div class="mt-5 rounded-md border border-[var(--line)] bg-[var(--accent-soft)] p-4">
        <h3 class="font-semibold">The question CIP is helping the user answer</h3>
        <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
          Given the user's ideal work profile and current network, which three to five people can help test whether a lane, employer type, or role title is worth pursuing before the user spends time applying or asking for referrals?
        </p>
      </div>
    </section>

    <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Step 3</p>
      <h2 class="mt-1 text-2xl font-semibold">Convert contacts into useful strategy</h2>
      <div class="mt-5 grid gap-4 lg:grid-cols-2">
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
          <h3 class="font-semibold">CIP will score relationship signals</h3>
          <ul class="mt-3 grid gap-2 text-sm leading-6 text-[var(--muted)] sm:grid-cols-2">
            {relationshipSignals.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
          <h3 class="font-semibold">CIP will produce action outputs</h3>
          <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
            {networkOutputs.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--accent-soft)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Professional networking posture</p>
      <h2 class="mt-1 text-2xl font-semibold">The first ask is usually not a job.</h2>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        CIP coaches the user to reconnect, ask for advice, and learn how a market works before requesting a referral. The strongest outreach comes after the user has a clear resume story, a relevant reason for the conversation, and a respectful next step.
      </p>
      <div class="mt-5 grid gap-3 md:grid-cols-4">
        {["Reconnect", "Ask for a market read", "Request a warm intro", "Follow up with gratitude"].map((item) => (
          <div class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4 text-sm font-semibold text-[var(--foreground)]">{item}</div>
        ))}
      </div>
    </section>
  </main>
</Layout>
