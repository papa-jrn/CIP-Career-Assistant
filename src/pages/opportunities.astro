---
import Layout from "../layouts/Layout.astro";
import { opportunities as fallbackOpportunities } from "../lib/cip/data";
import { configuredMarketSources } from "../lib/cip/labor-market";
import { buildTargetLanes, parseAnalysisAdvisor, parseIntakeSource } from "../lib/cip/resume-asset-context";
import { createServer } from "../lib/supabase/server";

type OpportunityRow = {
  id: string;
  match_score: number;
  confidence: string;
  fit_summary: string;
  missing_skills: string[];
  evidence: Array<{ label: string; value: string }>;
  opportunities: {
    title: string;
    company: string;
    location: string | null;
    work_mode: string | null;
    salary_min: number | null;
    salary_max: number | null;
    source_url: string | null;
    source_provider: string | null;
    description: string | null;
    tags: string[] | null;
    last_seen_at: string | null;
  } | null;
};

type WatchedEmployerRow = {
  id: string;
  name: string;
  region: string;
  category: string;
  location: string | null;
  priority: string;
  fit_score: number;
  fit_summary: string;
  target_roles: string[] | null;
  careers_url: string | null;
  source_url: string | null;
  adapter_status: string;
  confidence: string;
};

let signedIn = false;
let rankedMatches: OpportunityRow[] = [];
let watchedEmployers: WatchedEmployerRow[] = [];
let loadError = "";
let suggestedTerms: string[] = [];
const sources = configuredMarketSources();
const sourceCount = sources.greenhouse.length + sources.lever.length;

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();

    signedIn = Boolean(user);

    if (user) {
      const { data, error } = await supabase
        .from("opportunity_matches")
        .select(`
          id,
          match_score,
          confidence,
          fit_summary,
          missing_skills,
          evidence,
          opportunities (
            title,
            company,
            location,
            work_mode,
            salary_min,
            salary_max,
            source_url,
            source_provider,
            description,
            tags,
            last_seen_at
          )
        `)
        .eq("user_id", user.id)
        .order("match_score", { ascending: false })
        .limit(30);

      if (error) {
        loadError = error.message;
      } else {
        rankedMatches = (data ?? []) as OpportunityRow[];
      }

      const { data: employerRows } = await supabase
        .from("watched_employers")
        .select("id,name,region,category,location,priority,fit_score,fit_summary,target_roles,careers_url,source_url,adapter_status,confidence")
        .eq("user_id", user.id)
        .order("fit_score", { ascending: false })
        .limit(12);
      watchedEmployers = (employerRows ?? []) as WatchedEmployerRow[];

      // Suggested search terms from the user's validated lanes, so the search
      // starts from "the work that fits you" instead of a blank box.
      const [{ data: intakeRow }, { data: analysisRow }] = await Promise.all([
        supabase
          .from("career_sources")
          .select("extracted_text")
          .eq("user_id", user.id)
          .eq("source_type", "resume_intake")
          .order("created_at", { ascending: false })
          .limit(1)
          .maybeSingle(),
        supabase
          .from("career_sources")
          .select("extracted_text")
          .eq("user_id", user.id)
          .eq("source_type", "evidence_analysis")
          .order("created_at", { ascending: false })
          .limit(1)
          .maybeSingle(),
      ]);

      const latestSource = parseIntakeSource(intakeRow?.extracted_text ?? null);
      const latestAdvisor = parseAnalysisAdvisor(analysisRow?.extracted_text ?? null) ?? latestSource?.advisor ?? null;
      const hasRealLanes = Boolean(latestAdvisor?.roleBriefs?.length || latestSource?.draft?.possibleRoles?.length);
      const targetTitle = typeof latestSource?.intake?.target_title === "string" ? latestSource.intake.target_title : "";
      const laneRoles = hasRealLanes ? buildTargetLanes(latestSource, latestAdvisor).map((lane) => lane.role) : [];
      suggestedTerms = [...new Set([targetTitle, ...laneRoles].map((term) => term.trim()).filter(Boolean))].slice(0, 6);
    }
  } catch (error) {
    loadError = error instanceof Error ? error.message : "Unable to load opportunities.";
  }
}

function salaryLabel(item: OpportunityRow["opportunities"]) {
  if (!item?.salary_min && !item?.salary_max) return "Salary not listed";
  if (item.salary_min && item.salary_max) return `$${item.salary_min.toLocaleString()}-${item.salary_max.toLocaleString()}`;
  if (item.salary_min) return `$${item.salary_min.toLocaleString()}+`;
  return `Up to $${item.salary_max?.toLocaleString()}`;
}

function employerSearchLocation(employer: WatchedEmployerRow) {
  return employer.location || employer.region.replaceAll("_", " ");
}

function hiringToolLabel(employer: WatchedEmployerRow) {
  const url = employer.careers_url || "";
  if (!url) return "Needs career-page check";
  if (/greenhouse\.io/i.test(url)) return "Greenhouse hiring tool";
  if (/lever\.co/i.test(url)) return "Lever hiring tool";
  if (/workdayjobs|myworkdayjobs/i.test(url)) return "Workday hiring tool";
  if (/icims/i.test(url)) return "iCIMS hiring tool";
  if (/smartrecruiters/i.test(url)) return "SmartRecruiters hiring tool";
  if (/jobs|careers|employment|join/i.test(url)) return "Career page";
  return "Hiring link";
}

function monitoringStatus(employer: WatchedEmployerRow) {
  if (employer.careers_url && employer.adapter_status === "supported") return "Adapter ready";
  if (employer.careers_url) return "Manual review ready";
  return "Find hiring page";
}
---

<Layout title="CIP Opportunities">
  <main class="mx-auto w-full max-w-6xl px-5 py-8">
    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Labor Market Engine</p>
          <h1 class="mt-2 text-3xl font-semibold">Rank real opportunities by strategic fit.</h1>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
            Ingest public Greenhouse and Lever job boards, normalize listings, dedupe by source, and score matches against the saved identity graph.
          </p>
        </div>
        <form hx-post="/api/labor-market/ingest" hx-target="#market-run-result" hx-swap="innerHTML" hx-indicator="#market-loading">
          <button class="cip-fancy-button" type="submit" disabled={!signedIn}>
            <span>Run market research</span>
          </button>
        </form>
      </div>

      <div class="mt-5 grid gap-3 md:grid-cols-3">
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Configured sources</p>
          <p class="mt-2 text-2xl font-semibold">{sourceCount}</p>
          <p class="mt-1 text-sm text-[var(--muted)]">Greenhouse: {sources.greenhouse.length}; Lever: {sources.lever.length}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Ranked matches</p>
          <p class="mt-2 text-2xl font-semibold">{rankedMatches.length}</p>
          <p class="mt-1 text-sm text-[var(--muted)]">Saved to your profile</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Status</p>
          <p class="mt-2 text-sm font-semibold text-[var(--accent-strong)]">{signedIn ? "Ready" : "Sign in required"}</p>
          <p class="mt-1 text-sm text-[var(--muted)]">Save intake first for personalized scoring</p>
        </div>
      </div>

      <div id="market-loading" class="htmx-indicator mt-5 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
        <div class="flex items-center gap-3 text-sm font-semibold text-[var(--accent-strong)]">
          <span class="h-4 w-4 animate-spin rounded-full border-2 border-[var(--line)] border-t-[var(--accent)]"></span>
          Researching configured job boards and refreshing match scores...
        </div>
      </div>
      <div id="market-run-result" class="mt-5"></div>

      {loadError ? (
        <p class="mt-5 rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-800">{loadError}</p>
      ) : null}

      <section id="networking" class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
        <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Search and networking strategy</p>
        <h2 class="mt-1 text-2xl font-semibold">Decide where to look before scaling applications.</h2>
        <div class="mt-4 grid gap-4 lg:grid-cols-2">
          <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
            <h3 class="text-lg font-semibold">Networking data lives in the Network step</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
              Import LinkedIn connection exports, alumni lists, and manual contacts on the Network page, then run lane validation there. Advisor conversations from that step are the market intelligence this page should be tested against.
            </p>
            <a class="mt-3 inline-flex rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href="/network">Open Network</a>
          </article>
          <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
            <div class="flex flex-wrap items-center gap-2">
              <h3 class="text-lg font-semibold">Job-board search lanes</h3>
              <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--warning)]">Planned, not built yet</span>
            </div>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
              The planned feature turns the analysis into LinkedIn, Indeed, Monster, Greenhouse, Lever, and company-careers searches with target titles, exclusion terms, salary filters, work model, geography, and review rules. Until it exists, this card is a description, not a tool.
            </p>
          </article>
        </div>
      </section>

      {suggestedTerms.length ? (
        <section class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-sm font-semibold">Search your validated lanes</p>
          <p class="mt-1 text-xs leading-5 text-[var(--muted)]">Pulled from your evidence analysis. Click one to load it into both searches below, then set a location.</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {suggestedTerms.map((term) => (
              <button type="button" class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-3 py-1.5 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" data-lane-term={term}>{term}</button>
            ))}
          </div>
        </section>
      ) : null}

      <section id="employer-role-bridge" class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Employer-to-role bridge</p>
            <h2 class="mt-1 text-2xl font-semibold">Search employer career pages first.</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-[var(--muted)]">
              Enter a search term once, then open the employer's own career page. The Adzuna check inside each row is secondary because broad job indexes can miss employer jobs or return unrelated similarly named results.
            </p>
          </div>
          <a class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href="/employers">Update employers</a>
        </div>

        {watchedEmployers.length ? (
          <div class="mt-4 rounded-md border border-[var(--accent)] bg-[var(--panel)] p-4">
            <label class="grid gap-1">
              <span class="text-xs font-semibold uppercase text-[var(--muted)]">Search term for employer career pages</span>
              <input id="employer-career-search-term" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm" placeholder="e.g. communications, program manager, analyst" />
            </label>
            <p class="mt-2 text-xs leading-5 text-[var(--muted)]">Leave blank to open each employer's main careers page. Add a term to send that search into supported career-page links and Adzuna cross-check forms.</p>
          </div>
        ) : null}

        {watchedEmployers.length ? (
          <div class="mt-4 overflow-hidden rounded-md border border-[var(--line)]">
            {watchedEmployers.map((employer) => (
              <details class="group border-b border-[var(--line)] bg-[var(--panel)] last:border-b-0">
                <summary class="grid cursor-pointer list-none gap-3 p-4 md:grid-cols-[1fr_auto] md:items-center">
                  <div>
                    <h3 class="text-base font-semibold text-[var(--foreground)]">{employer.name}</h3>
                    <p class="mt-1 text-xs text-[var(--muted)]">
                      {[employer.location || employer.region.replaceAll("_", " "), employer.category].filter(Boolean).join(" - ")}
                    </p>
                  </div>
                  <div class="flex flex-wrap items-center gap-2 md:justify-end">
                    <span class="rounded-md border border-[var(--line)] bg-[var(--background)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{monitoringStatus(employer)}</span>
                    {employer.careers_url ? (
                      <a
                        class="cip-fancy-button px-4 py-2 text-sm"
                        href={employer.careers_url}
                        data-careers-base={employer.careers_url}
                        target="_blank"
                        rel="noreferrer"
                      >
                        <span>Search career page</span>
                      </a>
                    ) : employer.source_url ? (
                      <a class="rounded-md border border-[var(--line)] bg-[var(--background)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href={employer.source_url} target="_blank" rel="noreferrer">Review source</a>
                    ) : null}
                    <span class="text-xs font-semibold text-[var(--muted)]">Details</span>
                  </div>
                </summary>

                <div class="grid gap-4 border-t border-[var(--line)] bg-[var(--background)] p-4 lg:grid-cols-[1fr_0.9fr]">
                  <div>
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-0.5 text-xs font-semibold text-[var(--muted)]">{employer.priority} priority</span>
                      <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-0.5 text-xs font-semibold text-[var(--muted)]">{hiringToolLabel(employer)}</span>
                      <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-0.5 text-xs font-semibold text-[var(--muted)]">{employer.confidence} confidence</span>
                    </div>
                    <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{employer.fit_summary}</p>
                    {employer.target_roles?.length ? (
                      <div class="mt-3 flex flex-wrap gap-1.5">
                        {employer.target_roles.slice(0, 6).map((role) => (
                          <span class="rounded-md border border-[var(--line)] bg-[var(--background)] px-2 py-0.5 text-xs font-semibold text-[var(--foreground)]">{role}</span>
                        ))}
                      </div>
                    ) : null}
                  </div>
                  <div>
                    <form class="grid gap-2 rounded-md border border-[var(--line)] bg-[var(--panel)] p-3" hx-post="/api/jobs/geographic" hx-target={`#employer-role-results-${employer.id}`} hx-swap="innerHTML" hx-indicator={`#employer-role-loading-${employer.id}`}>
                      <div class="grid gap-2 sm:grid-cols-[1fr_1fr_auto]">
                        <label class="grid gap-1">
                          <span class="text-xs font-semibold uppercase text-[var(--muted)]">Adzuna cross-check term</span>
                          <input name="q" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-2 text-sm" placeholder="Use the search term above or type here" data-employer-crosscheck-term />
                        </label>
                        <label class="grid gap-1">
                          <span class="text-xs font-semibold uppercase text-[var(--muted)]">Location</span>
                          <input name="where" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-2 text-sm" value={employerSearchLocation(employer)} />
                        </label>
                        <button class="self-end rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" type="submit">Cross-check</button>
                      </div>
                      <input type="hidden" name="radius" value="15" />
                      <input type="hidden" name="country" value="us" />
                      <input type="hidden" name="employer_name" value={employer.name} />
                      <span id={`employer-role-loading-${employer.id}`} class="htmx-indicator text-xs font-semibold text-[var(--accent-strong)]">Searching public listings...</span>
                    </form>
                    <p class="mt-2 text-xs leading-5 text-[var(--muted)]">
                      Adzuna is only a public-board cross-check. Trust the employer career page when the two disagree.
                    </p>
                    <div id={`employer-role-results-${employer.id}`} class="mt-3"></div>
                  </div>
                </div>
              </details>
            ))}
          </div>
        ) : (
          <div class="mt-4 rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
            <p class="text-sm font-semibold">No watched employers yet</p>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">Run geography-first employer discovery, save the employers worth watching, then return here to inspect hiring tools and search employer-specific role lanes.</p>
            <a class="mt-3 inline-flex rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href="/employers">Find employers</a>
          </div>
        )}
      </section>

      <section id="geographic-search" class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
        <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Geographic job search</p>
        <h2 class="mt-1 text-2xl font-semibold">Search real listings near a place.</h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-[var(--muted)]">
          Live results from Adzuna by location, radius, and salary floor. When you are signed in with a saved intake, listings are scored for fit. This is a live read — nothing is cached or invented. Jobs by Adzuna.
        </p>
        <form class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-4" hx-post="/api/jobs/geographic" hx-target="#geo-results" hx-swap="innerHTML" hx-indicator="#geo-loading">
          <label class="grid gap-1">
            <span class="text-xs font-semibold uppercase text-[var(--muted)]">Role or keyword</span>
            <input id="geo-q" name="q" class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" placeholder="e.g. operations manager" />
          </label>
          <label class="grid gap-1">
            <span class="text-xs font-semibold uppercase text-[var(--muted)]">Location</span>
            <input name="where" class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" placeholder="e.g. Lebanon, NH" />
          </label>
          <label class="grid gap-1">
            <span class="text-xs font-semibold uppercase text-[var(--muted)]">Radius (miles)</span>
            <input name="radius" type="number" min="0" max="200" value="25" class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" />
          </label>
          <label class="grid gap-1">
            <span class="text-xs font-semibold uppercase text-[var(--muted)]">Min salary (optional)</span>
            <input name="salary_min" type="number" min="0" class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" placeholder="e.g. 90000" />
          </label>
          <input type="hidden" name="country" value="us" />
          <div class="flex items-center gap-3 sm:col-span-2 lg:col-span-4">
            <button class="cip-fancy-button" type="submit"><span>Search by location</span></button>
            <span id="geo-loading" class="htmx-indicator text-sm font-semibold text-[var(--accent-strong)]">Searching Adzuna...</span>
          </div>
        </form>
        <div id="geo-results" class="mt-5"></div>
      </section>

      <section id="remote-search" class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
        <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Live remote job search</p>
        <h2 class="mt-1 text-2xl font-semibold">Search real remote listings right now.</h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-[var(--muted)]">
          Pulls live from open remote-job APIs (Remotive, RemoteOK, We Work Remotely). Results link to the original posting. When you are signed in with a saved intake, listings are scored for fit. This is a live read — nothing is cached or invented.
        </p>
        <form class="mt-4 flex flex-wrap items-end gap-2" hx-post="/api/jobs/remote" hx-target="#remote-results" hx-swap="innerHTML" hx-indicator="#remote-loading">
          <label class="grid gap-1">
            <span class="text-xs font-semibold uppercase text-[var(--muted)]">Role or keyword</span>
            <input id="remote-q" name="q" class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" placeholder="e.g. operations, AI, product, customer success" required />
          </label>
          <label class="grid gap-1">
            <span class="text-xs font-semibold uppercase text-[var(--muted)]">Region filter (optional)</span>
            <input name="region" class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" placeholder="e.g. USA" />
          </label>
          <button class="cip-fancy-button" type="submit"><span>Search remote jobs</span></button>
          <span id="remote-loading" class="htmx-indicator text-sm font-semibold text-[var(--accent-strong)]">Searching live sources...</span>
        </form>
        <div id="remote-results" class="mt-5"></div>
      </section>

      {rankedMatches.length ? (
        <div class="mt-6 grid gap-4">
          {rankedMatches.map((match) => match.opportunities ? (
            <article class="grid gap-4 rounded-md border border-[var(--line)] bg-[var(--background)] p-5 md:grid-cols-[1fr_auto]">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <h2 class="text-xl font-semibold">{match.opportunities.title}</h2>
                  {match.opportunities.source_provider ? (
                    <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{match.opportunities.source_provider}</span>
                  ) : null}
                </div>
                <p class="mt-1 text-sm text-[var(--muted)]">
                  {match.opportunities.company}
                  {match.opportunities.location ? ` - ${match.opportunities.location}` : ""}
                  {match.opportunities.work_mode ? ` - ${match.opportunities.work_mode}` : ""}
                </p>
                <p class="mt-4 text-sm leading-6 text-[var(--muted)]">{match.fit_summary}</p>
                {match.missing_skills?.length ? (
                  <p class="mt-3 text-sm font-semibold text-[var(--warning)]">Proof gaps: {match.missing_skills.join(", ")}</p>
                ) : null}
                {match.evidence?.length ? (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {match.evidence.map((item) => (
                      <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{item.label}: {item.value}</span>
                    ))}
                  </div>
                ) : null}
              </div>
              <div class="flex min-w-36 flex-col items-start gap-2 md:items-end">
                <span class="text-3xl font-semibold text-[var(--accent-strong)]">{match.match_score}%</span>
                <span class="rounded-md bg-[rgba(126,217,87,0.18)] px-2 py-1 text-xs font-semibold">{match.confidence} confidence</span>
                <span class="text-xs text-[var(--muted)]">{salaryLabel(match.opportunities)}</span>
                {match.opportunities.source_url ? (
                  <a class="mt-2 rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href={match.opportunities.source_url} target="_blank" rel="noreferrer">View source</a>
                ) : null}
              </div>
            </article>
          ) : null)}
        </div>
      ) : (
        <div class="mt-6 grid gap-4">
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
            <h2 class="text-xl font-semibold">No ranked matches yet</h2>
            <p class="mt-3 text-sm leading-6 text-[var(--muted)]">
              {sourceCount
                ? "Run market research above to ingest the configured job boards and score matches against your saved intake."
                : "No job boards are connected yet, so live research cannot run. Job-board sources are currently configured by the operator, not from this page; connecting saved employers to live monitoring is planned but not built."}
            </p>
            <p class="mt-2 text-xs font-semibold uppercase text-[var(--warning)]">The cards below are illustrative fixtures, not real listings.</p>
          </div>
          {fallbackOpportunities.map((item) => (
            <article class="grid gap-4 rounded-md border border-[var(--line)] bg-[var(--background)] p-5 opacity-80 md:grid-cols-[1fr_auto]">
              <div>
                <h2 class="text-xl font-semibold">{item.role}</h2>
                <p class="mt-1 text-sm text-[var(--muted)]">{item.company}</p>
                <p class="mt-4 text-sm leading-6 text-[var(--muted)]">{item.evidence}</p>
                <p class="mt-3 text-sm font-semibold text-[var(--warning)]">{item.gap}</p>
              </div>
              <div class="flex min-w-32 flex-col items-start gap-2 md:items-end">
                <span class="text-3xl font-semibold text-[var(--accent-strong)]">{item.match}%</span>
                <span class="rounded-md bg-[rgba(126,217,87,0.18)] px-2 py-1 text-xs font-semibold">{item.confidence} confidence</span>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </main>

  <script>
    function careerSearchUrl(rawUrl: string, query: string) {
      if (!query) return rawUrl;

      try {
        const url = new URL(rawUrl);
        const normalizedHost = url.hostname.replace(/^www\./, "");

        if (normalizedHost === "careers.dartmouth-health.org") {
          url.pathname = "/dartmouth-health/results";
          url.searchParams.set("keyword", query);
          return url.toString();
        }

        if (normalizedHost === "searchjobs.dartmouth.edu") {
          url.pathname = "/postings/search";
          url.searchParams.set("query", query);
          return url.toString();
        }

        if (normalizedHost === "usajobs.gov") {
          url.pathname = "/Search/Results";
          url.searchParams.set("k", query);
          return url.toString();
        }

        if (/greenhouse\.io$/.test(normalizedHost) || /myworkdayjobs\.com$/.test(normalizedHost)) {
          url.searchParams.set("keyword", query);
          return url.toString();
        }

        if (/icims\.com$/.test(normalizedHost)) {
          url.searchParams.set("ss", "1");
          url.searchParams.set("searchKeyword", query);
          return url.toString();
        }

        return url.toString();
      } catch {
        return rawUrl;
      }
    }

    let lastSharedEmployerTerm = "";
    function syncEmployerSearchTerm() {
      const input = document.getElementById("employer-career-search-term") as HTMLInputElement | null;
      const term = input?.value.trim() || "";

      document.querySelectorAll<HTMLAnchorElement>("[data-careers-base]").forEach((link) => {
        const base = link.getAttribute("data-careers-base") || link.href;
        link.href = careerSearchUrl(base, term);
      });

      document.querySelectorAll<HTMLInputElement>("[data-employer-crosscheck-term]").forEach((field) => {
        if (!field.value.trim() || field.value === lastSharedEmployerTerm) {
          field.value = term;
        }
      });

      lastSharedEmployerTerm = term;
    }

    document.getElementById("employer-career-search-term")?.addEventListener("input", syncEmployerSearchTerm);
    syncEmployerSearchTerm();

    document.querySelectorAll("#employer-role-bridge summary a").forEach((link) => {
      link.addEventListener("click", (event) => event.stopPropagation());
    });

    // Clicking a validated-lane chip loads that term into both job searches.
    document.querySelectorAll("[data-lane-term]").forEach((chip) => {
      chip.addEventListener("click", () => {
        const term = chip.getAttribute("data-lane-term") || "";
        const geo = document.getElementById("geo-q");
        const remote = document.getElementById("remote-q");
        if (geo) (geo as HTMLInputElement).value = term;
        if (remote) (remote as HTMLInputElement).value = term;
        document.getElementById("geographic-search")?.scrollIntoView({ behavior: "smooth", block: "start" });
        (geo as HTMLInputElement | null)?.focus();
      });
    });
  </script>
</Layout>
