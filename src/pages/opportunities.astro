---
import Layout from "../layouts/Layout.astro";
import { navItems, opportunities as fallbackOpportunities } from "../lib/cip/data";
import { configuredMarketSources } from "../lib/cip/labor-market";
import { createServer } from "../lib/supabase/server";

type OpportunityRow = {
  id: string;
  match_score: number;
  confidence: string;
  fit_summary: string;
  missing_skills: string[];
  evidence: Array<{ label: string; value: string }>;
  opportunities: {
    title: string;
    company: string;
    location: string | null;
    work_mode: string | null;
    salary_min: number | null;
    salary_max: number | null;
    source_url: string | null;
    source_provider: string | null;
    description: string | null;
    tags: string[] | null;
    last_seen_at: string | null;
  } | null;
};

let signedIn = false;
let rankedMatches: OpportunityRow[] = [];
let loadError = "";
const sources = configuredMarketSources();
const sourceCount = sources.greenhouse.length + sources.lever.length;

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();

    signedIn = Boolean(user);

    if (user) {
      const { data, error } = await supabase
        .from("opportunity_matches")
        .select(`
          id,
          match_score,
          confidence,
          fit_summary,
          missing_skills,
          evidence,
          opportunities (
            title,
            company,
            location,
            work_mode,
            salary_min,
            salary_max,
            source_url,
            source_provider,
            description,
            tags,
            last_seen_at
          )
        `)
        .eq("user_id", user.id)
        .order("match_score", { ascending: false })
        .limit(30);

      if (error) {
        loadError = error.message;
      } else {
        rankedMatches = (data ?? []) as OpportunityRow[];
      }
    }
  } catch (error) {
    loadError = error instanceof Error ? error.message : "Unable to load opportunities.";
  }
}

function salaryLabel(item: OpportunityRow["opportunities"]) {
  if (!item?.salary_min && !item?.salary_max) return "Salary not listed";
  if (item.salary_min && item.salary_max) return `$${item.salary_min.toLocaleString()}-${item.salary_max.toLocaleString()}`;
  if (item.salary_min) return `$${item.salary_min.toLocaleString()}+`;
  return `Up to $${item.salary_max?.toLocaleString()}`;
}
---

<Layout title="CIP Opportunities">
  <main class="mx-auto w-full max-w-6xl px-5 py-8">
    <nav class="mb-8 flex flex-wrap gap-2">
      {navItems.map((item) => (
        <a class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold text-[var(--muted)] hover:text-[var(--foreground)]" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Labor Market Engine</p>
          <h1 class="mt-2 text-3xl font-semibold">Rank real opportunities by strategic fit.</h1>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
            Ingest public Greenhouse and Lever job boards, normalize listings, dedupe by source, and score matches against the saved identity graph.
          </p>
        </div>
        <form hx-post="/api/labor-market/ingest" hx-target="#market-run-result" hx-swap="innerHTML" hx-indicator="#market-loading">
          <button class="cip-fancy-button" type="submit" disabled={!signedIn}>
            <span>Run market research</span>
          </button>
        </form>
      </div>

      <div class="mt-5 grid gap-3 md:grid-cols-3">
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Configured sources</p>
          <p class="mt-2 text-2xl font-semibold">{sourceCount}</p>
          <p class="mt-1 text-sm text-[var(--muted)]">Greenhouse: {sources.greenhouse.length}; Lever: {sources.lever.length}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Ranked matches</p>
          <p class="mt-2 text-2xl font-semibold">{rankedMatches.length}</p>
          <p class="mt-1 text-sm text-[var(--muted)]">Saved to your profile</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Status</p>
          <p class="mt-2 text-sm font-semibold text-[var(--accent-strong)]">{signedIn ? "Ready" : "Sign in required"}</p>
          <p class="mt-1 text-sm text-[var(--muted)]">Save intake first for personalized scoring</p>
        </div>
      </div>

      <div id="market-loading" class="htmx-indicator mt-5 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
        <div class="flex items-center gap-3 text-sm font-semibold text-[var(--accent-strong)]">
          <span class="h-4 w-4 animate-spin rounded-full border-2 border-[var(--line)] border-t-[var(--accent)]"></span>
          Researching configured job boards and refreshing match scores...
        </div>
      </div>
      <div id="market-run-result" class="mt-5"></div>

      {loadError ? (
        <p class="mt-5 rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-800">{loadError}</p>
      ) : null}

      <section id="networking" class="mt-6 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
        <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Search and networking strategy</p>
        <h2 class="mt-1 text-2xl font-semibold">Decide where to look before scaling applications.</h2>
        <div class="mt-4 grid gap-4 lg:grid-cols-2">
          <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
            <h3 class="text-lg font-semibold">Bring in networking data</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
              Add LinkedIn connections exports, alumni lists, manually entered contacts, or public profile links supplied by the user. CIP should use this to map warm-introduction paths, not scrape private LinkedIn data.
            </p>
          </article>
          <article class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-4">
            <h3 class="text-lg font-semibold">Create job-board lanes</h3>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
              Turn the analysis into LinkedIn, Indeed, Monster, Greenhouse, Lever, and company-careers searches with target titles, exclusion terms, salary filters, work model, geography, and review rules.
            </p>
          </article>
        </div>
      </section>

      {rankedMatches.length ? (
        <div class="mt-6 grid gap-4">
          {rankedMatches.map((match) => match.opportunities ? (
            <article class="grid gap-4 rounded-md border border-[var(--line)] bg-[var(--background)] p-5 md:grid-cols-[1fr_auto]">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <h2 class="text-xl font-semibold">{match.opportunities.title}</h2>
                  {match.opportunities.source_provider ? (
                    <span class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{match.opportunities.source_provider}</span>
                  ) : null}
                </div>
                <p class="mt-1 text-sm text-[var(--muted)]">
                  {match.opportunities.company}
                  {match.opportunities.location ? ` - ${match.opportunities.location}` : ""}
                  {match.opportunities.work_mode ? ` - ${match.opportunities.work_mode}` : ""}
                </p>
                <p class="mt-4 text-sm leading-6 text-[var(--muted)]">{match.fit_summary}</p>
                {match.missing_skills?.length ? (
                  <p class="mt-3 text-sm font-semibold text-[var(--warning)]">Proof gaps: {match.missing_skills.join(", ")}</p>
                ) : null}
                {match.evidence?.length ? (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {match.evidence.map((item) => (
                      <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{item.label}: {item.value}</span>
                    ))}
                  </div>
                ) : null}
              </div>
              <div class="flex min-w-36 flex-col items-start gap-2 md:items-end">
                <span class="text-3xl font-semibold text-[var(--accent-strong)]">{match.match_score}%</span>
                <span class="rounded-md bg-[rgba(126,217,87,0.18)] px-2 py-1 text-xs font-semibold">{match.confidence} confidence</span>
                <span class="text-xs text-[var(--muted)]">{salaryLabel(match.opportunities)}</span>
                {match.opportunities.source_url ? (
                  <a class="mt-2 rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href={match.opportunities.source_url} target="_blank" rel="noreferrer">View source</a>
                ) : null}
              </div>
            </article>
          ) : null)}
        </div>
      ) : (
        <div class="mt-6 grid gap-4">
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
            <h2 class="text-xl font-semibold">No ingested matches yet</h2>
            <p class="mt-3 text-sm leading-6 text-[var(--muted)]">
              Configure labor-market sources in `.env`, restart the dev server, then run market research. Until then, these examples show the intended scoring surface.
            </p>
          </div>
          {fallbackOpportunities.map((item) => (
            <article class="grid gap-4 rounded-md border border-[var(--line)] bg-[var(--background)] p-5 opacity-80 md:grid-cols-[1fr_auto]">
              <div>
                <h2 class="text-xl font-semibold">{item.role}</h2>
                <p class="mt-1 text-sm text-[var(--muted)]">{item.company}</p>
                <p class="mt-4 text-sm leading-6 text-[var(--muted)]">{item.evidence}</p>
                <p class="mt-3 text-sm font-semibold text-[var(--warning)]">{item.gap}</p>
              </div>
              <div class="flex min-w-32 flex-col items-start gap-2 md:items-end">
                <span class="text-3xl font-semibold text-[var(--accent-strong)]">{item.match}%</span>
                <span class="rounded-md bg-[rgba(126,217,87,0.18)] px-2 py-1 text-xs font-semibold">{item.confidence} confidence</span>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </main>
</Layout>
