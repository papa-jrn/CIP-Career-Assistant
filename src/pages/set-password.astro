---
import Layout from "../layouts/Layout.astro";
import { createServer } from "../lib/supabase/server";

const supabase = createServer(Astro.cookies);
const {
  data: { user },
} = await supabase.auth.getUser();

const email = user?.email ?? "";
---

<Layout title="Set password - Career Intelligence Platform">
  <div class="flex min-h-full flex-1 flex-col items-center justify-center px-4 py-16">
    <div class="w-full max-w-sm space-y-8">
      <div class="text-center">
        <h1 class="text-2xl font-semibold tracking-tight">Set password</h1>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
          {email ? `Choose a new password for ${email}.` : "Open your password setup email first, then choose a new password here."}
        </p>
      </div>

      {
        !user ? (
          <p class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-center text-sm text-amber-900 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-100">
            This page needs a valid password setup session. Request a new link from the sign-in page if yours expired.
          </p>
        ) : null
      }

      <form id="set-password-form" class="space-y-4">
        <div>
          <label for="password" class="sr-only">New password</label>
          <input
            id="password"
            name="password"
            type="password"
            required
            minlength="6"
            autocomplete="new-password"
            placeholder="New password"
            class="block w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-foreground shadow-sm placeholder:text-zinc-400 focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-zinc-400 dark:focus:ring-zinc-400"
          />
        </div>
        <div>
          <label for="confirm-password" class="sr-only">Confirm password</label>
          <input
            id="confirm-password"
            name="confirm-password"
            type="password"
            required
            minlength="6"
            autocomplete="new-password"
            placeholder="Confirm password"
            class="block w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-foreground shadow-sm placeholder:text-zinc-400 focus:border-zinc-500 focus:outline-none focus:ring-1 focus:ring-zinc-500 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-zinc-400 dark:focus:ring-zinc-400"
          />
        </div>
        <button
          id="set-password-submit"
          type="submit"
          class="flex w-full justify-center rounded-lg bg-foreground px-3 py-2 text-sm font-medium text-background transition hover:opacity-90 disabled:opacity-50"
          disabled={!user}
        >
          Save password
        </button>
      </form>

      <div id="set-password-result" class="text-center text-sm"></div>
      <p class="text-center text-sm text-zinc-500">
        <a href="/login" class="font-medium text-foreground underline-offset-4 hover:underline">Back to sign in</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  import { createBrowser } from "../lib/supabase/browser";

  const form = document.querySelector<HTMLFormElement>("#set-password-form");
  const submitButton =
    document.querySelector<HTMLButtonElement>("#set-password-submit");
  const result = document.querySelector<HTMLDivElement>("#set-password-result");
  let supabase: ReturnType<typeof createBrowser> | null = null;

  function showMessage(message: string, kind: "info" | "success" | "error") {
    if (!result) {
      return;
    }

    if (kind === "success") {
      result.className =
        "rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-center text-sm text-emerald-800 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-200";
    } else if (kind === "error") {
      result.className = "text-center text-sm text-red-700 dark:text-red-300";
    } else {
      result.className = "text-center text-sm text-zinc-500";
    }
    result.textContent = message;
  }

  try {
    supabase = createBrowser();
  } catch (error) {
    console.error(error);
    showMessage(
      "Supabase is not configured. Add PUBLIC_SUPABASE_ANON_KEY to .env and restart the app.",
      "error",
    );
    if (submitButton) submitButton.disabled = true;
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!supabase) {
      showMessage("Supabase is not configured.", "error");
      return;
    }

    const formData = new FormData(form);
    const password = String(formData.get("password") ?? "");
    const confirmPassword = String(formData.get("confirm-password") ?? "");

    if (password.length < 6) {
      showMessage("Password must be at least 6 characters.", "error");
      return;
    }

    if (password !== confirmPassword) {
      showMessage("Passwords do not match.", "error");
      return;
    }

    if (submitButton) submitButton.disabled = true;
    showMessage("Saving your password...", "info");

    const { error } = await supabase.auth.updateUser({ password });

    if (error) {
      showMessage(error.message, "error");
      if (submitButton) submitButton.disabled = false;
      return;
    }

    showMessage("Password updated. Sending you to the app...", "success");
    window.setTimeout(() => {
      window.location.href = "/intake";
    }, 900);
  });
</script>
