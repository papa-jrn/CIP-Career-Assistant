---
import Layout from "../layouts/Layout.astro";
import {
  briefingItems,
  navItems,
  opportunities,
  profileSignals,
  recommendations,
} from "../lib/cip/data";
---

<Layout
  title="Career Intelligence Platform"
  description="A trust-first career strategist workspace for job search intelligence."
>
  <header class="border-b border-[var(--line)] bg-[var(--panel)]">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4">
      <a href="/" class="text-base font-semibold text-[var(--foreground)]">CIP</a>
      <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
        {navItems.map((item) => (
          <a class="rounded-md px-3 py-2 text-sm font-medium text-[var(--muted)] hover:bg-black/5 hover:text-[var(--foreground)] dark:hover:bg-white/10" href={item.href}>
            {item.label}
          </a>
        ))}
      </nav>
      <div class="flex items-center gap-2">
        <a class="rounded-md border border-[var(--line)] px-4 py-2 text-sm font-semibold text-[var(--foreground)] hover:bg-black/5 dark:hover:bg-white/10" href="/login">
          Sign in
        </a>
        <a class="cip-fancy-button" href="/intake">
          <span>Start intake</span>
        </a>
      </div>
    </div>
  </header>

  <main class="mx-auto grid w-full max-w-7xl gap-6 px-5 py-6 lg:grid-cols-[1.2fr_0.8fr]">
    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Founder MVP</p>
      <h1 class="mt-3 max-w-3xl text-4xl font-semibold leading-tight text-[var(--foreground)] md:text-5xl">
        Career intelligence before job application volume.
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-[var(--muted)]">
        CIP models the person, researches the market, and recommends source-backed moves across roles, resume, LinkedIn, portfolio, and weekly strategy.
      </p>

      <div class="mt-8 grid gap-3 sm:grid-cols-2">
        {profileSignals.map((signal) => (
          <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <div class="flex items-center justify-between gap-3">
              <h2 class="text-sm font-semibold">{signal.label}</h2>
              <span class="rounded-md bg-[rgba(126,217,87,0.18)] px-2 py-1 text-xs font-semibold text-[var(--accent-strong)]">{signal.value}</span>
            </div>
            <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{signal.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <aside class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <h2 class="text-lg font-semibold">Trust Model</h2>
      <div class="mt-5 space-y-4">
        <div>
          <div class="flex items-center justify-between text-sm">
            <span>Verified claims</span>
            <span class="font-semibold text-[var(--positive)]">Required</span>
          </div>
          <div class="mt-2 h-2 rounded-full bg-black/10 dark:bg-white/10">
            <div class="h-2 w-[88%] rounded-full bg-[var(--positive)]"></div>
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between text-sm">
            <span>Source coverage</span>
            <span class="font-semibold text-[var(--accent-strong)]">Growing</span>
          </div>
          <div class="mt-2 h-2 rounded-full bg-black/10 dark:bg-white/10">
            <div class="h-2 w-[64%] rounded-full bg-[var(--accent)]"></div>
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between text-sm">
            <span>Unverified edits</span>
            <span class="font-semibold text-[var(--warning)]">Blocked</span>
          </div>
          <div class="mt-2 h-2 rounded-full bg-black/10 dark:bg-white/10">
            <div class="h-2 w-[18%] rounded-full bg-[var(--warning)]"></div>
          </div>
        </div>
      </div>
      <p class="mt-6 text-sm leading-6 text-[var(--muted)]">
        Every recommendation should carry evidence, confidence, and a user approval state before it changes public career assets.
      </p>
    </aside>

    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6 lg:col-span-2">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Opportunity Radar</p>
          <h2 class="mt-2 text-2xl font-semibold">Initial role hypotheses</h2>
        </div>
        <a class="rounded-md border border-[var(--line)] px-4 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href="/opportunities">Open research queue</a>
      </div>
      <div class="mt-5 overflow-hidden rounded-md border border-[var(--line)]">
        <table class="w-full border-collapse text-left text-sm">
          <thead class="bg-black/5 text-[var(--muted)] dark:bg-white/10">
            <tr>
              <th class="px-4 py-3 font-semibold">Role</th>
              <th class="px-4 py-3 font-semibold">Match</th>
              <th class="px-4 py-3 font-semibold">Evidence</th>
              <th class="px-4 py-3 font-semibold">Next Gap</th>
            </tr>
          </thead>
          <tbody>
            {opportunities.map((item) => (
              <tr class="border-t border-[var(--line)]">
                <td class="px-4 py-4">
                  <div class="font-semibold">{item.role}</div>
                  <div class="text-xs text-[var(--muted)]">{item.company} - {item.confidence} confidence</div>
                </td>
                <td class="px-4 py-4 font-semibold text-[var(--accent-strong)]">{item.match}%</td>
                <td class="max-w-md px-4 py-4 text-[var(--muted)]">{item.evidence}</td>
                <td class="max-w-xs px-4 py-4 text-[var(--muted)]">{item.gap}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <h2 class="text-2xl font-semibold">Asset guidance</h2>
      <div class="mt-5 space-y-4">
        {recommendations.map((item) => (
          <article class="border-l-4 border-[var(--accent)] pl-4">
            <h3 class="font-semibold">{item.area}</h3>
            <p class="mt-1 text-sm leading-6 text-[var(--muted)]">{item.action}</p>
            <p class="mt-2 text-xs font-semibold text-[var(--warning)]">{item.guardrail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <h2 class="text-2xl font-semibold">Weekly briefing draft</h2>
      <ol class="mt-5 space-y-3">
        {briefingItems.map((item, index) => (
          <li class="flex gap-3 text-sm leading-6 text-[var(--muted)]">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-[var(--foreground)] text-xs font-semibold text-[var(--background)]">{index + 1}</span>
            <span>{item}</span>
          </li>
        ))}
      </ol>
    </section>
  </main>
</Layout>
