---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";

// Canonical 8-step process. Keep these labels in sync with `navItems` in
// src/lib/cip/data.ts — that array is the single source of truth for the
// step order and names used across the nav, the Workbench, and this page.
const processSteps = [
  {
    title: "Intake",
    body: "Capture the career story, constraints, target compensation, work model, and public proof sources.",
  },
  {
    title: "Evidence",
    body: "Separate verified claims, user-supplied context, inferred strengths, and gaps that need confirmation.",
  },
  {
    title: "Career Lanes",
    body: "Turn the evidence into plausible next-step directions instead of one vague job-title guess \u2014 then generate a resume reframed for each lane.",
  },
  {
    title: "Network",
    body: "Map advisors and warm connections against the ideal-work profile before anyone asks for a referral.",
  },
  {
    title: "Follow Up",
    body: "Review the queue: who to talk to now, park, revisit, or remove \u2014 and capture what each conversation confirms or weakens.",
  },
  {
    title: "Employers",
    body: "Research organizations and hiring environments that fit the lane, geography, and work preferences.",
  },
  {
    title: "Opportunities",
    body: "Compare real roles against the profile, evidence, salary needs, and missing proof.",
  },
  {
    title: "Briefing",
    body: "Summarize what was learned each week and feed it back into the next pass \u2014 then generate a fresh report.",
  },
];

const outcomes = [
  "A clearer career lane hypothesis",
  "Better questions for advisors and warm contacts",
  "A watched-employer and opportunity research queue",
  "A final report with evidence status and next actions",
];
---

<Layout
  title="Career Intelligence Platform"
  description="A private career intelligence workspace for turning uncertain career transitions into advisory-ready plans."
>
  <main class="cip-page-shell">
    <section class="relative isolate min-h-[calc(100vh-4.25rem)] overflow-hidden">
      <img
        src="/images/hero-workspace.jpg"
        alt="A thoughtful workspace conversation"
        class="absolute inset-0 -z-20 h-full w-full object-cover"
        width="1800"
        height="1200"
      />
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(251,248,241,0.96),rgba(251,248,241,0.82)_44%,rgba(251,248,241,0.24))] dark:bg-[linear-gradient(90deg,rgba(22,26,23,0.97),rgba(22,26,23,0.82)_48%,rgba(22,26,23,0.32))]"></div>
      <div class="mx-auto flex min-h-[calc(100vh-4.25rem)] w-full max-w-7xl items-center px-5 py-14">
        <div class="max-w-3xl">
          <p class="inline-flex items-center gap-2 rounded-md bg-[var(--accent-soft)] px-3 py-1 text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">
            <Icon name="spark" class="h-3.5 w-3.5" strokeWidth={2} />
            Private career intelligence workspace
          </p>
          <h1 class="mt-5 max-w-3xl text-4xl leading-[1.06] md:text-6xl" style="font-family: var(--headline-font);">
            Turn career uncertainty into an advisory-ready plan.
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-7 text-[var(--foreground)] md:text-lg md:leading-8">
            CIP helps people in complex career transitions gather evidence, test next-step role lanes, prepare better advisor conversations, and produce a report they can actually act on.
          </p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <a class="cip-fancy-button" href="/login">
              <span class="flex items-center gap-2">
                <Icon name="arrow-right" class="h-4 w-4" strokeWidth={2.2} />
                Create your private workspace
              </span>
            </a>
            <a class="cip-fancy-button cip-fancy-button-secondary" href="/workbench">
              <span>Open workbench</span>
            </a>
          </div>
          <p class="mt-4 max-w-xl text-sm leading-6 text-[var(--muted)]">
            Sign-in starts before intake because this work involves resumes, salary goals, network context, and private career questions.
          </p>
        </div>
      </div>
    </section>

    <section class="border-y border-[var(--line)] bg-[var(--panel)]">
      <div class="mx-auto grid w-full max-w-7xl gap-8 px-5 py-14 lg:grid-cols-[0.85fr_1.15fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">The real problem</p>
          <h2 class="mt-2 text-3xl md:text-4xl" style="font-family: var(--headline-font);">Most career advice starts with a question that is too big.</h2>
        </div>
        <div class="grid gap-5 text-base leading-7 text-[var(--muted)]">
          <p>
            Asking someone what job you should pursue next is a heavy ask. They need your history, your proof, your constraints, the market context, and the difference between what sounds interesting and what is credible now.
          </p>
          <p>
            CIP narrows that question. It helps you bring advisors a short, evidence-backed brief: the lanes you are testing, what each lane has going for it, what feels risky, and who else you should talk to next.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-[var(--background)]">
      <div class="mx-auto w-full max-w-7xl px-5 py-14">
        <div class="grid gap-8 lg:grid-cols-[1fr_0.85fr] lg:items-center">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">A guided process</p>
            <h2 class="mt-2 text-3xl md:text-4xl" style="font-family: var(--headline-font);">Eight pieces, one career intelligence loop.</h2>
            <p class="mt-4 max-w-2xl text-base leading-7 text-[var(--muted)]">
              The app is not trying to answer everything in one pass. It turns scattered data into a working model that can be improved through evidence, conversations, employer research, and role comparison.
            </p>
          </div>
          <img
            src="/images/intake-coach.jpg"
            alt="A focused coaching conversation"
            class="aspect-[4/3] w-full rounded-lg border border-[var(--line)] object-cover shadow-[var(--shadow-card)]"
            width="900"
            height="675"
          />
        </div>

        <div class="mt-9 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
          {processSteps.map((step, index) => (
            <article class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-5 shadow-[var(--shadow-card)]">
              <span class="flex h-8 w-8 items-center justify-center rounded-full border border-[var(--line)] text-xs font-bold text-[var(--accent-strong)]">
                {index + 1}
              </span>
              <h3 class="mt-4 text-lg font-semibold">{step.title}</h3>
              <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{step.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y border-[var(--line)] bg-[var(--surface-wash)]">
      <div class="mx-auto grid w-full max-w-7xl gap-8 px-5 py-14 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
        <img
          src="/images/report-cover.jpg"
          alt="Printed career report on a desk"
          class="aspect-[5/4] w-full rounded-lg border border-[var(--line)] object-cover shadow-[var(--shadow-card)]"
          width="900"
          height="720"
        />
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">What you get</p>
          <h2 class="mt-2 text-3xl md:text-4xl" style="font-family: var(--headline-font);">A report that makes the next conversation easier.</h2>
          <p class="mt-4 text-base leading-7 text-[var(--muted)]">
            The final report is meant to be a working artifact, not a fortune-telling document. It shows the current model, the evidence behind it, what still needs validation, and the next practical moves.
          </p>
          <ul class="mt-6 grid gap-3">
            {outcomes.map((item) => (
              <li class="flex gap-3 text-sm leading-6 text-[var(--muted)]">
                <Icon name="check-circle" class="mt-0.5 h-5 w-5 shrink-0 text-[var(--accent-strong)]" strokeWidth={1.9} />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="bg-[var(--panel)]">
      <div class="mx-auto grid w-full max-w-7xl gap-8 px-5 py-14 lg:grid-cols-[1.05fr_0.95fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">Why sign-in comes first</p>
          <h2 class="mt-2 text-3xl md:text-4xl" style="font-family: var(--headline-font);">This is private work, so the app starts with a private workspace.</h2>
        </div>
        <div class="grid gap-4 text-sm leading-6 text-[var(--muted)]">
          <p>
            CIP may store resume text, salary targets, private constraints, network names, advisor feedback, and generated reports. That data needs an account boundary before the workflow begins.
          </p>
          <p>
            The public site explains the method. The signed-in workbench is where the app saves progress, builds the model, and keeps the report tied to the person it belongs to.
          </p>
          <div class="pt-2">
            <a class="cip-fancy-button" href="/login">
              <span>Start with sign-in</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
