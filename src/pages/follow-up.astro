---
import Layout from "../layouts/Layout.astro";
import type { NetworkAnalysis, NetworkContact, NetworkContactMatch } from "../lib/cip/network-intelligence";
import { createServer } from "../lib/supabase/server";

type QueuePerson = {
  contact: NetworkContact;
  match?: NetworkContactMatch;
  latestFeedback?: SavedFeedback;
  history?: SavedFeedback[];
};

// Decisions that take a person out of the active queue. They are not deleted —
// they move to a recoverable "Removed / not pursuing" section.
const EXCLUDED_DECISIONS = new Set(["remove", "deceased", "no_memory", "retired", "ethical_concern"]);

type SavedFeedback = {
  contactName: string;
  feedbackType: string;
  note: string;
  conversationStatus?: string;
  followUpDate?: string;
  followUpIntent?: string;
  decisionReason?: string;
  marketSignals?: string;
  newLeads?: string;
  laneImpact?: string;
  createdAt: string;
};

const decisionOptions = [
  { value: "use_now", label: "Use now" },
  { value: "follow_up", label: "Follow up" },
  { value: "park", label: "Park for now" },
  { value: "active_relationship", label: "Active relationship" },
  { value: "too_cold", label: "Too cold" },
  { value: "no_memory", label: "Do not remember" },
  { value: "retired", label: "Retired / stale" },
  { value: "ethical_concern", label: "Sensitive / concern" },
  { value: "remove", label: "Remove" },
  { value: "context", label: "Context only" },
];

const conversationStatuses = [
  "To contact",
  "Awaiting reply",
  "Scheduled",
  "Met",
  "Follow-up",
  "Intro offered",
  "Parked",
  "Removed",
];

// A follow-up date that has passed and the person is not yet met or shelved
// means the user owes them a nudge.
const TODAY = new Date().toISOString().slice(0, 10);
const NUDGE_DONE = new Set(["Met", "Parked", "Removed"]);
function needsNudge(saved?: SavedFeedback) {
  if (!saved?.followUpDate) return false;
  if (NUDGE_DONE.has(saved.conversationStatus ?? "")) return false;
  return saved.followUpDate < TODAY;
}

function hasConversationContent(saved?: SavedFeedback) {
  return Boolean(saved && (saved.marketSignals || saved.newLeads || saved.laneImpact || saved.note));
}

// Sort each person into at most one action bucket so the worklist shows who
// needs attention now, without repeating people across buckets.
function actionBucket(person: QueuePerson): "nudge" | "notes" | "week" | "awaiting" | null {
  const saved = person.latestFeedback;
  if (needsNudge(saved)) return "nudge";
  if (saved?.conversationStatus === "Met" && !hasConversationContent(saved)) return "notes";
  if (saved?.conversationStatus === "Scheduled" || saved?.conversationStatus === "Intro offered") return "week";
  if (saved?.conversationStatus === "Awaiting reply") return "awaiting";
  return null;
}

const followUpIntents = [
  "Market read",
  "Role translation",
  "Employer context",
  "Warm intro",
  "Reconnection",
  "Referral later",
  "Thank-you",
  "Research later",
];

let signedIn = false;
let loadError = "";
let queue: QueuePerson[] = [];
let excludedQueue: QueuePerson[] = [];
let latestAnalysisAt: string | null = null;
let latestImportAt: string | null = null;
let importedContactCount = 0;
let analysisContactCount = 0;
let feedbackCount = 0;
let conversationNoteCount = 0;

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();
    signedIn = Boolean(user);

    if (user) {
      const [
        { data: analysisRows, error: analysisError },
        { data: importRows, error: importError },
        { data: feedbackRows, error: feedbackError },
        { count: notesCount },
      ] = await Promise.all([
        supabase
          .from("career_sources")
          .select("extracted_text, created_at")
          .eq("user_id", user.id)
          .eq("source_type", "network_analysis")
          .order("created_at", { ascending: false })
          .limit(12),
        supabase
          .from("career_sources")
          .select("extracted_text, created_at")
          .eq("user_id", user.id)
          .eq("source_type", "network_import")
          .order("created_at", { ascending: false })
          .limit(12),
        supabase
          .from("career_sources")
          .select("extracted_text, created_at")
          .eq("user_id", user.id)
          .eq("source_type", "network_feedback")
          .order("created_at", { ascending: false })
          .limit(300),
        supabase
          .from("career_sources")
          .select("id", { count: "exact", head: true })
          .eq("user_id", user.id)
          .eq("source_type", "conversation_outcome"),
      ]);

      if (analysisError) loadError = analysisError.message;
      if (importError) loadError = importError.message;
      if (feedbackError) loadError = feedbackError.message;

      const analyses = (analysisRows ?? [])
        .map((row) => parseNetworkAnalysis(row.extracted_text ?? null))
        .filter(Boolean) as NetworkAnalysis[];
      const importedContacts = (importRows ?? []).flatMap((row) => parseNetworkImportContacts(row.extracted_text ?? null));
      const feedback = (feedbackRows ?? [])
        .map((row) => parseSavedFeedback(row.extracted_text, row.created_at))
        .filter(Boolean) as SavedFeedback[];

      latestAnalysisAt = analysisRows?.[0]?.created_at ?? null;
      latestImportAt = importRows?.[0]?.created_at ?? null;
      importedContactCount = dedupeContacts(importedContacts.filter(isFollowUpImportContact)).length;
      analysisContactCount = dedupeContacts(analyses.flatMap((analysis) => analysis.contactMatches.map((match) => match.contact))).length;
      feedbackCount = feedback.length;
      conversationNoteCount = notesCount ?? 0;
      const built = buildQueue(importedContacts, analyses, feedback);
      queue = built.active;
      excludedQueue = built.excluded;
    }
  } catch (error) {
    loadError = error instanceof Error ? error.message : "Unable to load follow-up queue.";
  }
}

function parseNetworkAnalysis(value: string | null): NetworkAnalysis | null {
  if (!value) return null;
  try {
    const parsed = JSON.parse(value);
    return parsed?.analysis ?? null;
  } catch {
    return null;
  }
}

function parseNetworkImportContacts(value: string | null): NetworkContact[] {
  if (!value) return [];
  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed?.contacts) ? parsed.contacts : [];
  } catch {
    return [];
  }
}

function parseSavedFeedback(value: string | null, createdAt: string): SavedFeedback | null {
  if (!value) return null;
  try {
    const parsed = JSON.parse(value);
    const feedback = parsed?.feedback;
    if (!feedback?.contactName) return null;
    return {
      contactName: String(feedback.contactName),
      feedbackType: String(feedback.feedbackType || "context"),
      note: String(feedback.note || ""),
      conversationStatus: stringOrUndefined(feedback.conversationStatus),
      followUpDate: stringOrUndefined(feedback.followUpDate),
      followUpIntent: stringOrUndefined(feedback.followUpIntent),
      decisionReason: stringOrUndefined(feedback.decisionReason),
      marketSignals: stringOrUndefined(feedback.marketSignals),
      newLeads: stringOrUndefined(feedback.newLeads),
      laneImpact: stringOrUndefined(feedback.laneImpact),
      createdAt,
    };
  } catch {
    return null;
  }
}

function stringOrUndefined(value: unknown) {
  return typeof value === "string" && value.trim() ? value.trim() : undefined;
}

function buildQueue(contacts: NetworkContact[], analyses: NetworkAnalysis[], feedback: SavedFeedback[]) {
  // feedback arrives newest-first; keep every record per contact as history and
  // treat the first (newest) as the current decision.
  const historyByName = new Map<string, SavedFeedback[]>();
  for (const item of feedback) {
    const key = normalize(item.contactName);
    if (!key) continue;
    const list = historyByName.get(key);
    if (list) list.push(item);
    else historyByName.set(key, [item]);
  }

  const matches = analyses.flatMap((analysis) => analysis.contactMatches ?? []);
  const matchByName = new Map<string, NetworkContactMatch>();
  const byName = new Map<string, QueuePerson>();

  const attach = (key: string, contact: NetworkContact, match?: NetworkContactMatch) => {
    const history = historyByName.get(key);
    return { contact, match, latestFeedback: history?.[0], history };
  };

  for (const match of matches) {
    const key = normalize(match.contact.name);
    if (!key || matchByName.has(key) || !isLikelyPersonName(match.contact.name)) continue;
    matchByName.set(key, match);
    byName.set(key, attach(key, match.contact, match));
  }

  for (const contact of contacts.filter(isFollowUpImportContact)) {
    const key = normalize(contact.name);
    if (!key || byName.has(key) || !isLikelyPersonName(contact.name)) continue;
    byName.set(key, attach(key, contact, matchByName.get(key)));
  }

  const everyone = [...byName.values()]
    .filter((person) => isLikelyPersonName(person.contact.name))
    .sort((a, b) => {
      const scoreDelta = (b.match?.score ?? 0) - (a.match?.score ?? 0);
      if (scoreDelta) return scoreDelta;
      return a.contact.name.localeCompare(b.contact.name);
    });

  const excluded = everyone.filter((person) => EXCLUDED_DECISIONS.has(person.latestFeedback?.feedbackType ?? ""));
  const active = everyone.filter((person) => !EXCLUDED_DECISIONS.has(person.latestFeedback?.feedbackType ?? "")).slice(0, 80);
  return { active, excluded };
}

function isFollowUpImportContact(contact: NetworkContact) {
  return contact.source === "Structured warm connections";
}

function isLikelyPersonName(value: string) {
  const name = value.trim();
  if (!name || name.length > 80) return false;
  if (/[.!?;:|()[\]{}]/.test(name)) return false;
  if (/^(the|what|but|and|or|if|when|where|why|how|this|that|these|those|there|you|i)\b/i.test(name)) return false;

  const words = name.split(/\s+/).filter(Boolean);
  if (words.length < 2 || words.length > 5) return false;
  return words.every((word) => /^[A-Z][A-Za-z'.-]*$/.test(word) || /^[A-Z]\.$/.test(word));
}

function dedupeContacts(contacts: NetworkContact[]) {
  const byName = new Map<string, NetworkContact>();
  for (const contact of contacts) {
    const key = normalize(contact.name);
    if (!key || byName.has(key)) continue;
    byName.set(key, contact);
  }
  return [...byName.values()];
}

function normalize(value: string) {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, " ").trim();
}

function slug(value: string) {
  return normalize(value).replace(/\s+/g, "-") || "contact";
}

function selected(value: string | undefined, option: string) {
  return value === option;
}

const worklistBuckets = [
  { key: "nudge", label: "Nudge due", hint: "A follow-up date has passed. You owe these people a reply or a check-in.", items: queue.filter((p) => actionBucket(p) === "nudge") },
  { key: "notes", label: "Met — capture notes", hint: "You talked but have not logged it yet. Capture the conversation before it fades.", items: queue.filter((p) => actionBucket(p) === "notes") },
  { key: "week", label: "Active this week", hint: "Scheduled, or an introduction was offered. Keep these moving.", items: queue.filter((p) => actionBucket(p) === "week") },
  { key: "awaiting", label: "Awaiting reply", hint: "Sent and waiting. Leave these alone unless a nudge comes due.", items: queue.filter((p) => actionBucket(p) === "awaiting") },
].filter((bucket) => bucket.items.length);

const worklistCount = worklistBuckets.reduce((total, bucket) => total + bucket.items.length, 0);
---

<Layout title="CIP Follow Up">
  <main class="mx-auto w-full max-w-6xl px-5 py-8">
    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Follow Up</p>
      <h1 class="mt-2 max-w-4xl text-3xl font-semibold">Turn the network list into reviewed relationship intelligence.</h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        This is where the people Network suggested become a working queue. Set each person's connection status, decide whether to use, park, or remove them, and after a conversation, write down what you learned. Those notes are the point: market reality on pay, titles, hiring, and new leads flows from here into your employer and role research and into the next weekly pass.
      </p>
      <div class="mt-5 grid gap-3 md:grid-cols-2 lg:grid-cols-6">
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">People in queue</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{queue.length}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Imported people</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{importedContactCount}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Analysis matches</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{analysisContactCount}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Saved reviews</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{feedbackCount}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Conversation notes</p>
          <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{conversationNoteCount}</p>
        </div>
        <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
          <p class="text-xs font-semibold uppercase text-[var(--muted)]">Latest source</p>
          <p class="mt-2 text-sm font-semibold text-[var(--foreground)]">
            {latestAnalysisAt ? new Date(latestAnalysisAt).toLocaleDateString() : latestImportAt ? new Date(latestImportAt).toLocaleDateString() : "No network run yet"}
          </p>
        </div>
      </div>
      {!signedIn ? (
        <p class="mt-4 rounded-md border border-[var(--line)] bg-[var(--accent-soft)] p-3 text-sm font-semibold text-[var(--accent-strong)]">
          Sign in before saving follow-up reviews.
        </p>
      ) : null}
      {loadError ? (
        <p class="mt-4 rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-800">{loadError}</p>
      ) : null}
    </section>

    <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Weekly relationship queue</p>
          <h2 class="mt-1 text-2xl font-semibold">Review, update, and capture what changed.</h2>
        </div>
        <div class="flex flex-wrap gap-2">
          <a class="cip-fancy-button cip-fancy-button-secondary" href="/network"><span>Back to Network</span></a>
          <a class="cip-fancy-button cip-fancy-button-secondary" href="/employers"><span>Next: Employers</span></a>
        </div>
      </div>

      {queue.length ? (
        <>
        {worklistCount ? (
          <div class="mt-5 grid gap-3">
            {worklistBuckets.map((bucket) => (
              <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
                <div class="flex flex-wrap items-center justify-between gap-2">
                  <h3 class={`text-sm font-semibold ${bucket.key === "nudge" ? "text-[var(--warning)]" : "text-[var(--foreground)]"}`}>{bucket.label}</h3>
                  <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-0.5 text-xs font-semibold text-[var(--muted)]">{bucket.items.length}</span>
                </div>
                <p class="mt-1 text-xs leading-5 text-[var(--muted)]">{bucket.hint}</p>
                <ul class="mt-3 grid gap-2">
                  {bucket.items.map((person) => {
                    const id = slug(person.contact.name);
                    return (
                      <li class="flex flex-wrap items-center justify-between gap-2 rounded-md border border-[var(--line)] bg-[var(--panel)] px-3 py-2">
                        <a class="text-sm font-semibold text-[var(--accent-strong)] hover:underline" href={`#follow-up-${id}`}>{person.contact.name}</a>
                        <span class="text-xs text-[var(--muted)]">
                          {[person.contact.title, person.contact.company].filter(Boolean).join(" at ") || "Needs review"}
                          {person.latestFeedback?.followUpDate ? ` · due ${person.latestFeedback.followUpDate}` : ""}
                        </span>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))}
          </div>
        ) : (
          <p class="mt-5 rounded-md border border-[var(--line)] bg-[var(--background)] p-4 text-sm leading-6 text-[var(--muted)]">
            Nothing needs action right now. As you set connection statuses and follow-up dates below, the people who need attention this week will surface here.
          </p>
        )}

        <div class="mt-8 flex items-center justify-between gap-3">
          <h3 class="text-sm font-semibold uppercase text-[var(--accent-strong)]">All connections</h3>
          <span class="text-xs text-[var(--muted)]">Set status inline, or open a card for a deeper dive.</span>
        </div>
        <div class="mt-3 overflow-hidden rounded-md border border-[var(--line)]">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="bg-[var(--background)] text-left text-xs font-semibold uppercase text-[var(--muted)]">
                <th class="px-4 py-3">Connection</th>
                <th class="px-4 py-3">Current decision</th>
                <th class="px-4 py-3">Connection status</th>
              </tr>
            </thead>
            <tbody>
              {queue.map((person) => {
                const id = slug(person.contact.name);
                const saved = person.latestFeedback;
                return (
                  <tr class="border-t border-[var(--line)] align-middle">
                    <td class="px-4 py-3">
                      <a class="font-semibold text-[var(--accent-strong)] hover:underline" href={`#follow-up-${id}`}>{person.contact.name}</a>
                      {needsNudge(saved) ? (
                        <span class="ml-2 rounded-md bg-[var(--warning)] px-1.5 py-0.5 text-xs font-semibold text-white">Nudge due</span>
                      ) : null}
                      <p class="mt-0.5 text-xs text-[var(--muted)]">{[person.contact.title, person.contact.company].filter(Boolean).join(" at ") || "Needs review"}</p>
                    </td>
                    <td class="px-4 py-3 text-xs text-[var(--muted)]">
                      {saved?.feedbackType ? saved.feedbackType.replace("_", " ") : "Not set"}
                    </td>
                    <td class="px-4 py-3">
                      <form class="flex items-center gap-2" hx-post="/api/network/feedback" hx-target={`#roster-result-${id}`} hx-swap="innerHTML">
                        <input type="hidden" name="contact_name" value={person.contact.name} />
                        <select name="conversation_status" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-1.5 text-xs">
                          {conversationStatuses.map((status) => <option value={status} selected={selected(saved?.conversationStatus, status)}>{status}</option>)}
                        </select>
                        <button class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold hover:bg-black/5 dark:hover:bg-white/10" type="submit" disabled={!signedIn}>Set</button>
                        <span id={`roster-result-${id}`} class="text-xs text-[var(--muted)]" aria-live="polite"></span>
                      </form>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        <div class="mt-6 grid gap-4">
          {queue.map((person) => {
            const id = slug(person.contact.name);
            const saved = person.latestFeedback;
            return (
              <details id={`follow-up-${id}`} class="scroll-mt-24 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
                <summary class="cursor-pointer list-none">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div>
                    <h3 class="text-lg font-semibold">{person.contact.name}</h3>
                    <p class="mt-1 text-sm leading-6 text-[var(--muted)]">
                      {[person.contact.title, person.contact.company].filter(Boolean).join(" at ") || "Company/title needs review"}
                    </p>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {person.match ? (
                        <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--accent-strong)]">
                          {person.match.score}% {person.match.confidence}
                        </span>
                      ) : null}
                      {person.contact.source ? (
                        <span class="rounded-md border border-[var(--line)] bg-[var(--panel)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">{person.contact.source}</span>
                      ) : null}
                      {saved ? (
                        <span class="rounded-md border border-[var(--line)] bg-[var(--accent-soft)] px-2 py-1 text-xs font-semibold text-[var(--accent-strong)]">
                          Last saved: {saved.feedbackType.replace("_", " ")}
                        </span>
                      ) : null}
                      {needsNudge(saved) ? (
                        <span class="rounded-md bg-[var(--warning)] px-2 py-1 text-xs font-semibold text-white">
                          Nudge due since {saved?.followUpDate}
                        </span>
                      ) : null}
                    </div>
                  </div>
                  {person.contact.profileUrl ? (
                    <a class="text-sm font-semibold text-[var(--accent-strong)] hover:underline" href={person.contact.profileUrl} target="_blank" rel="noreferrer">
                      Open link
                    </a>
                  ) : null}
                </div>
                </summary>
                <div class="mt-4">

                {person.match?.recommendedFirstAsk ? (
                  <p class="mt-4 rounded-md border border-[var(--line)] bg-[var(--panel)] p-3 text-sm leading-6 text-[var(--muted)]">
                    <span class="font-semibold text-[var(--foreground)]">Suggested first ask:</span> {person.match.recommendedFirstAsk}
                  </p>
                ) : null}
                {person.contact.notes || person.match?.matchReasons?.length ? (
                  <div class="mt-3 grid gap-3 lg:grid-cols-2">
                    {person.contact.notes ? (
                      <p class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-3 text-sm leading-6 text-[var(--muted)]">
                        <span class="font-semibold text-[var(--foreground)]">Known context:</span> {person.contact.notes}
                      </p>
                    ) : null}
                    {person.match?.matchReasons?.length ? (
                      <ul class="rounded-md border border-[var(--line)] bg-[var(--panel)] p-3 text-sm leading-6 text-[var(--muted)]">
                        {person.match.matchReasons.slice(0, 3).map((reason) => <li>{reason}</li>)}
                      </ul>
                    ) : null}
                  </div>
                ) : null}

                <div class="mt-4 rounded-md border border-[var(--line)] bg-[var(--panel)] p-3">
                  <form class="flex flex-wrap items-end gap-2" hx-post="/api/network/draft-message" hx-target={`#draft-result-${id}`} hx-swap="innerHTML" hx-indicator={`#draft-loading-${id}`}>
                    <input type="hidden" name="contact_name" value={person.contact.name} />
                    <input type="hidden" name="contact_title" value={person.contact.title ?? ""} />
                    <input type="hidden" name="contact_company" value={person.contact.company ?? ""} />
                    <input type="hidden" name="contact_notes" value={person.contact.notes ?? ""} />
                    <input type="hidden" name="first_ask" value={person.match?.recommendedFirstAsk ?? ""} />
                    <label class="grid gap-1">
                      <span class="text-xs font-semibold uppercase text-[var(--muted)]">Draft an outreach note</span>
                      <select name="intent" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-2 text-sm">
                        {followUpIntents.map((intent) => <option value={intent} selected={selected(saved?.followUpIntent, intent)}>{intent}</option>)}
                      </select>
                    </label>
                    <button class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" type="submit" disabled={!signedIn}>Draft note</button>
                    <span id={`draft-loading-${id}`} class="htmx-indicator text-xs font-semibold text-[var(--accent-strong)]">Drafting...</span>
                  </form>
                  <div id={`draft-result-${id}`} class="mt-3 text-sm" aria-live="polite"></div>
                </div>

                {person.history?.length ? (
                  <details class="mt-4 rounded-md border border-[var(--line)] bg-[var(--panel)] p-3">
                    <summary class="cursor-pointer text-sm font-semibold text-[var(--foreground)]">Interaction history ({person.history.length})</summary>
                    <ol class="mt-3 grid gap-2">
                      {person.history.map((entry) => (
                        <li class="rounded-md border border-[var(--line)] bg-[var(--background)] p-2 text-xs leading-5 text-[var(--muted)]">
                          <span class="font-semibold text-[var(--foreground)]">{new Date(entry.createdAt).toLocaleString()}</span>
                          {" — "}{(entry.feedbackType ?? "").replace("_", " ")}{entry.conversationStatus ? ` · ${entry.conversationStatus}` : ""}
                          {entry.note ? <p class="mt-1">{entry.note}</p> : null}
                        </li>
                      ))}
                    </ol>
                  </details>
                ) : null}

                <form class="mt-4 grid gap-3 rounded-md border border-[var(--line)] bg-[var(--panel)] p-4" hx-post="/api/network/feedback" hx-target={`#follow-up-result-${id}`} hx-swap="innerHTML">
                  <input type="hidden" name="contact_name" value={person.contact.name} />
                  <div class="grid gap-3 md:grid-cols-3">
                    <label class="grid gap-1">
                      <span class="text-xs font-semibold uppercase text-[var(--muted)]">Decision</span>
                      <select name="feedback_type" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-2 text-sm">
                        {decisionOptions.map((option) => <option value={option.value} selected={selected(saved?.feedbackType, option.value)}>{option.label}</option>)}
                      </select>
                    </label>
                    <label class="grid gap-1">
                      <span class="text-xs font-semibold uppercase text-[var(--muted)]">Conversation status</span>
                      <select name="conversation_status" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-2 text-sm">
                        {conversationStatuses.map((status) => <option value={status} selected={selected(saved?.conversationStatus, status)}>{status}</option>)}
                      </select>
                    </label>
                    <label class="grid gap-1">
                      <span class="text-xs font-semibold uppercase text-[var(--muted)]">Intent</span>
                      <select name="follow_up_intent" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-2 text-sm">
                        {followUpIntents.map((intent) => <option value={intent} selected={selected(saved?.followUpIntent, intent)}>{intent}</option>)}
                      </select>
                    </label>
                    <label class="grid gap-1">
                      <span class="text-xs font-semibold uppercase text-[var(--muted)]">Follow-up date</span>
                      <input name="follow_up_date" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-2 text-sm" type="date" value={saved?.followUpDate ?? ""} />
                    </label>
                    <label class="grid gap-1 md:col-span-2">
                      <span class="text-xs font-semibold uppercase text-[var(--muted)]">Reason for decision</span>
                      <input name="decision_reason" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-2 text-sm" value={saved?.decisionReason ?? ""} placeholder="Why use, park, remove, or revisit this person?" />
                    </label>
                  </div>
                  <div class="rounded-md border border-[var(--accent)] bg-[var(--background)] p-4">
                    <p class="text-sm font-semibold text-[var(--foreground)]">Capture the conversation</p>
                    <p class="mt-1 text-xs leading-5 text-[var(--muted)]">
                      Fill this in after you talk. When the connection status is Met, Follow-up, or Intro offered, what you record here is saved as first-hand market evidence and feeds the next network and evidence re-analysis.
                    </p>
                    <div class="mt-3 grid gap-3 lg:grid-cols-2">
                      <label class="grid gap-1">
                        <span class="text-xs font-semibold uppercase text-[var(--muted)]">Market signals captured</span>
                        <textarea name="market_signals" class="min-h-24 rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" placeholder="Salary, remote/hybrid, title reality, hiring process, proof points">{saved?.marketSignals ?? ""}</textarea>
                      </label>
                      <label class="grid gap-1">
                        <span class="text-xs font-semibold uppercase text-[var(--muted)]">New leads</span>
                        <textarea name="new_leads" class="min-h-24 rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" placeholder="People, employers, teams, roles, or communities they mentioned">{saved?.newLeads ?? ""}</textarea>
                      </label>
                      <label class="grid gap-1">
                        <span class="text-xs font-semibold uppercase text-[var(--muted)]">Lane impact</span>
                        <textarea name="lane_impact" class="min-h-24 rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" placeholder="What this strengthens, weakens, or redirects">{saved?.laneImpact ?? ""}</textarea>
                      </label>
                      <label class="grid gap-1">
                        <span class="text-xs font-semibold uppercase text-[var(--muted)]">Conversation notes / next step</span>
                        <textarea name="feedback_note" class="min-h-24 rounded-md border border-[var(--line)] bg-[var(--panel)] p-2 text-sm" placeholder="What was said, reply details, what you agreed, or why this should wait">{saved?.note ?? ""}</textarea>
                      </label>
                    </div>
                  </div>
                  <div class="flex flex-wrap items-center gap-3">
                    <button class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" type="submit" disabled={!signedIn}>
                      Save follow-up review
                    </button>
                    <div id={`follow-up-result-${id}`} class="text-sm" aria-live="polite"></div>
                  </div>
                </form>
                </div>
              </details>
            );
          })}
        </div>

        {excludedQueue.length ? (
          <details class="mt-8 rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <summary class="cursor-pointer text-sm font-semibold text-[var(--foreground)]">Removed / not pursuing ({excludedQueue.length})</summary>
            <p class="mt-2 text-xs leading-5 text-[var(--muted)]">
              These people are kept out of the active queue and out of future network analysis. Nothing is deleted — restore anyone here if that changes.
            </p>
            <div class="mt-3 grid gap-2">
              {excludedQueue.map((person) => {
                const id = slug(person.contact.name);
                const saved = person.latestFeedback;
                return (
                  <div class="flex flex-wrap items-center justify-between gap-2 rounded-md border border-[var(--line)] bg-[var(--panel)] px-3 py-2">
                    <div>
                      <p class="text-sm font-semibold">{person.contact.name}</p>
                      <p class="text-xs text-[var(--muted)]">
                        {(saved?.feedbackType ?? "removed").replace("_", " ")}
                        {saved?.decisionReason ? ` · ${saved.decisionReason}` : saved?.note ? ` · ${saved.note}` : ""}
                      </p>
                    </div>
                    <form class="flex items-center gap-2" hx-post="/api/network/feedback" hx-target={`#restore-result-${id}`} hx-swap="innerHTML">
                      <input type="hidden" name="contact_name" value={person.contact.name} />
                      <select name="feedback_type" class="rounded-md border border-[var(--line)] bg-[var(--background)] p-1.5 text-xs">
                        <option value="context">Restore as: context only</option>
                        <option value="use_now">Use now</option>
                        <option value="follow_up">Follow up</option>
                        <option value="park">Park for now</option>
                      </select>
                      <button class="rounded-md border border-[var(--line)] px-2 py-1 text-xs font-semibold hover:bg-black/5 dark:hover:bg-white/10" type="submit" disabled={!signedIn}>Restore</button>
                      <span id={`restore-result-${id}`} class="text-xs text-[var(--muted)]" aria-live="polite"></span>
                    </form>
                  </div>
                );
              })}
            </div>
          </details>
        ) : null}
        </>
      ) : (
        <div class="mt-5 rounded-md border border-[var(--line)] bg-[var(--background)] p-5">
          <p class="text-sm leading-6 text-[var(--muted)]">
            No relationship queue is available yet. Run Network analysis or add warm connections first, then return here to triage and work the follow-up list.
          </p>
          <a class="mt-4 inline-flex rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold hover:bg-black/5 dark:hover:bg-white/10" href="/network">Open Network</a>
        </div>
      )}
    </section>
  </main>

  <script>
    // Auto-open the collapsed card a roster or worklist link points at.
    function openTargetCard() {
      const id = decodeURIComponent(location.hash.slice(1));
      if (!id) return;
      const target = document.getElementById(id);
      if (target && target.tagName.toLowerCase() === "details") {
        (target as HTMLDetailsElement).open = true;
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }
    window.addEventListener("hashchange", openTargetCard);
    openTargetCard();
  </script>
</Layout>
