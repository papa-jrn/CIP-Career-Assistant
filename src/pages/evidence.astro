---
import Layout from "../layouts/Layout.astro";
import { navItems } from "../lib/cip/data";
import { buildEvidenceCards, renderEvidenceCardsHtml, type EvidenceResponsePayload } from "../lib/cip/evidence-builder";
import { calculateEvidenceSufficiency } from "../lib/cip/evidence-sufficiency";
import { sourceAnalysesToEvidence, type SourceAnalysisItem } from "../lib/cip/source-analysis";
import type { AdvisorAnalysis } from "../lib/cip/advisor";
import { createServer } from "../lib/supabase/server";

type IntakeSource = {
  intake?: Record<string, unknown>;
  draft?: { evidenceChecklist?: string[]; nextQuestions?: string[] };
  advisor?: Partial<AdvisorAnalysis>;
};

let latestSource: IntakeSource | null = null;
let latestAnalysisAdvisor: Partial<AdvisorAnalysis> | null = null;
let latestAnalysisCreatedAt: string | null = null;
let savedAt: string | null = null;
let latestEvidenceAt: string | null = null;
let evidenceResponses: EvidenceResponsePayload[] = [];
let sourceEvidenceResponses: EvidenceResponsePayload[] = [];
let sourceCounts = {
  intake: 0,
  evidence: 0,
  source: 0,
  sourceItems: 0,
  analysis: 0,
  review: 0,
};
let loadState: "ready" | "signin" | "local" | "error" = "local";

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();

    if (user) {
      const { data: intakeData } = await supabase
        .from("career_sources")
        .select("extracted_text, created_at")
        .eq("user_id", user.id)
        .eq("source_type", "resume_intake")
        .order("created_at", { ascending: false })
        .limit(1)
        .maybeSingle();

      const { data: responseData } = await supabase
        .from("career_sources")
        .select("extracted_text, created_at")
        .eq("user_id", user.id)
        .eq("source_type", "evidence_response")
        .order("created_at", { ascending: false })
        .limit(40);

      const { data: analysisData } = await supabase
        .from("career_sources")
        .select("extracted_text, created_at")
        .eq("user_id", user.id)
        .eq("source_type", "evidence_analysis")
        .order("created_at", { ascending: false })
        .limit(1)
        .maybeSingle();

      const { data: sourceData } = await supabase
        .from("career_sources")
        .select("extracted_text, created_at")
        .eq("user_id", user.id)
        .eq("source_type", "source_analysis")
        .order("created_at", { ascending: false })
        .limit(5);

      const [{ count: intakeCount }, { count: evidenceCount }, { count: sourceCount }, { count: analysisCount }, { count: reviewCount }] = await Promise.all([
        supabase
          .from("career_sources")
          .select("id", { count: "exact", head: true })
          .eq("user_id", user.id)
          .eq("source_type", "resume_intake"),
        supabase
          .from("career_sources")
          .select("id", { count: "exact", head: true })
          .eq("user_id", user.id)
          .eq("source_type", "evidence_response"),
        supabase
          .from("career_sources")
          .select("id", { count: "exact", head: true })
          .eq("user_id", user.id)
          .eq("source_type", "source_analysis"),
        supabase
          .from("career_sources")
          .select("id", { count: "exact", head: true })
          .eq("user_id", user.id)
          .eq("source_type", "evidence_analysis"),
        supabase
          .from("career_sources")
          .select("id", { count: "exact", head: true })
          .eq("user_id", user.id)
          .eq("source_type", "analysis_review"),
      ]);

      latestSource = intakeData?.extracted_text ? JSON.parse(intakeData.extracted_text) : null;
      latestAnalysisAdvisor = parseAnalysisAdvisor(analysisData?.extracted_text ?? null);
      latestAnalysisCreatedAt = analysisData?.created_at ?? null;
      savedAt = intakeData?.created_at ?? null;
      latestEvidenceAt = responseData?.[0]?.created_at ?? null;
      sourceCounts = {
        intake: intakeCount ?? 0,
        evidence: evidenceCount ?? 0,
        source: sourceCount ?? 0,
        sourceItems: 0,
        analysis: analysisCount ?? 0,
        review: reviewCount ?? 0,
      };
      evidenceResponses = (responseData ?? [])
        .map((row) => parseEvidencePayload(row.extracted_text))
        .filter(Boolean)
        .map((item) => item as EvidenceResponsePayload);
      sourceEvidenceResponses = sourceAnalysesToEvidence(
        (sourceData ?? []).flatMap((row) => parseSourceAnalysisItems(row.extracted_text)),
      ) as EvidenceResponsePayload[];
      sourceCounts.sourceItems = sourceEvidenceResponses.length;
      loadState = latestSource ? "ready" : "local";
    } else {
      loadState = "signin";
    }
  } catch {
    loadState = "error";
  }
}

const scoredEvidenceResponses = [...sourceEvidenceResponses, ...evidenceResponses];
const evidenceSufficiency = calculateEvidenceSufficiency(latestSource?.intake ?? {}, scoredEvidenceResponses, {
  evidenceRound: sourceCounts.analysis,
  sourceEvidenceCount: sourceCounts.sourceItems,
});
const readyForOpportunityMapping = evidenceSufficiency.phase === "complete";
const isEnhancementRound = evidenceSufficiency.phase === "enhancement";
const cards = latestSource
  ? buildEvidenceCards(latestSource.intake ?? {}, latestSource.draft, latestAnalysisAdvisor ?? latestSource.advisor, {
      phase: evidenceSufficiency.phase,
    })
  : [];
const latestPositioning = Array.isArray(latestAnalysisAdvisor?.positioning) ? latestAnalysisAdvisor.positioning : [];
const latestSkillGaps = Array.isArray(latestAnalysisAdvisor?.skillGaps) ? latestAnalysisAdvisor.skillGaps : [];

function parseEvidencePayload(value: string | null) {
  if (!value) return null;
  try {
    const parsed = JSON.parse(value);
    return parsed?.response ?? null;
  } catch {
    return null;
  }
}

function parseAnalysisAdvisor(value: string | null) {
  if (!value) return null;
  try {
    const parsed = JSON.parse(value);
    return parsed?.advisor ?? null;
  } catch {
    return null;
  }
}

function parseSourceAnalysisItems(value: string | null): SourceAnalysisItem[] {
  if (!value) return [];
  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed?.items) ? parsed.items : [];
  } catch {
    return [];
  }
}

---

<Layout title="CIP Evidence Builder">
  <main class="mx-auto w-full max-w-6xl px-5 py-8">
    <nav class="mb-8 flex flex-wrap gap-2">
      {navItems.map((item) => (
        <a class="rounded-md border border-[var(--line)] px-3 py-2 text-sm font-semibold text-[var(--muted)] hover:text-[var(--foreground)]" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <section class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Evidence Builder</p>
      <h1 class="mt-2 text-3xl font-semibold">Turn proof gaps into usable career evidence</h1>
      <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
        Answer these one at a time. The point is not polished resume copy yet; it is to capture honest source material, confidence, and proof that the advisor can use later.
      </p>
      <div class="mt-4 rounded-md border border-[var(--line)] bg-[var(--background)] px-3 py-2 text-sm font-semibold text-[var(--muted)]">
        {loadState === "ready" && savedAt ? `Built from the latest saved intake from ${new Date(savedAt).toLocaleString()}.` : ""}
        {loadState === "signin" ? "Sign in and save an intake before building evidence." : ""}
        {loadState === "local" ? "Save an intake first so the Evidence Builder can generate targeted questions." : ""}
        {loadState === "error" ? "The latest intake could not be loaded. Check Supabase configuration and saved intake data." : ""}
      </div>
      <div class="mt-5 flex flex-wrap items-center gap-3">
        <a class="cip-fancy-button cip-fancy-button-secondary" href="/api/evidence/export" target="_blank" rel="noreferrer">
          <span>Download evidence backup</span>
        </a>
        <p class="text-sm leading-6 text-[var(--muted)]">
          Exports saved intake versions and evidence answers from your signed-in Supabase session.
        </p>
      </div>
    </section>

    <section class="mt-6 grid gap-4 md:grid-cols-4">
      <div class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-5">
        <p class="text-xs font-semibold uppercase text-[var(--muted)]">Saved intake versions</p>
        <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{sourceCounts.intake}</p>
        <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
          {savedAt ? `Newest: ${new Date(savedAt).toLocaleString()}` : "No saved intake found for this signed-in session."}
        </p>
      </div>
      <div class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-5">
        <p class="text-xs font-semibold uppercase text-[var(--muted)]">Saved evidence answers</p>
        <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{sourceCounts.evidence}</p>
        <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
          {latestEvidenceAt ? `Newest: ${new Date(latestEvidenceAt).toLocaleString()}` : "No evidence answers found yet."}
        </p>
      </div>
      <div class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-5">
        <p class="text-xs font-semibold uppercase text-[var(--muted)]">Evidence score</p>
        <p class="mt-2 text-3xl font-semibold text-[var(--accent-strong)]">{evidenceSufficiency.score}</p>
        <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
          {evidenceSufficiency.usefulEvidenceCount} useful items / {evidenceSufficiency.scoreYears} scored career years.
          {sourceCounts.sourceItems ? ` Includes ${sourceCounts.sourceItems} analyzed linked source items.` : ""}
        </p>
      </div>
      <div class="rounded-lg border border-[var(--line)] bg-[var(--panel)] p-5">
        <p class="text-xs font-semibold uppercase text-[var(--muted)]">Version safety</p>
        <p class="mt-2 text-lg font-semibold">Additive saves</p>
        <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
          Intake and evidence saves create new source records. Older rows are preserved for history.
        </p>
      </div>
    </section>

    {isEnhancementRound ? (
      <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--accent-soft)] p-6">
        <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Final enhancement round</p>
        <h2 class="mt-1 text-2xl font-semibold">The evidence base is strong enough</h2>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
          The evidence score is {evidenceSufficiency.score}. Standard proof gathering is now diminishing returns. Answer only the final enhancement questions that sharpen the strongest positioning angles, then run one last analysis and move into opportunity mapping.
        </p>
      </section>
    ) : null}

    {readyForOpportunityMapping ? (
      <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--accent-soft)] p-6">
        <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Ready for opportunity mapping</p>
        <h2 class="mt-1 text-2xl font-semibold">Great work gathering this evidence</h2>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
          The profile now has enough source material to move from proof gathering into opportunity mapping. Evidence score: {evidenceSufficiency.score}. Next, turn this analysis into target roles, compensation goals, geography and remote preferences, employer categories, and career assets.
        </p>
      </section>
    ) : null}

    {readyForOpportunityMapping && latestAnalysisAdvisor ? (
      <section class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Latest evidence analysis</p>
            <h2 class="mt-1 text-2xl font-semibold">Current readout</h2>
          </div>
          {latestAnalysisCreatedAt ? (
            <span class="rounded-md border border-[var(--line)] bg-[var(--background)] px-2 py-1 text-xs font-semibold text-[var(--muted)]">
              {new Date(latestAnalysisCreatedAt).toLocaleString()}
            </span>
          ) : null}
        </div>
        <p class="mt-4 text-sm leading-6 text-[var(--muted)]">{latestAnalysisAdvisor.summary}</p>
        <div class="mt-5 grid gap-4 lg:grid-cols-2">
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">Positioning</h3>
            {latestPositioning.length ? (
              <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
                {latestPositioning.slice(0, 6).map((item) => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="mt-3 text-sm text-[var(--muted)]">No positioning notes saved yet.</p>
            )}
          </div>
          <div class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
            <h3 class="text-sm font-semibold">Remaining gaps</h3>
            {latestSkillGaps.length ? (
              <ul class="mt-3 space-y-2 text-sm leading-6 text-[var(--muted)]">
                {latestSkillGaps.slice(0, 6).map((item) => <li>{item}</li>)}
              </ul>
            ) : (
              <p class="mt-3 text-sm text-[var(--muted)]">No remaining gaps saved yet.</p>
            )}
          </div>
        </div>
        <div class="mt-5 rounded-md border border-[var(--line)] bg-[var(--accent-soft)] p-5">
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Next steps</p>
          <h3 class="mt-1 text-xl font-semibold">Now go look for the right opportunities</h3>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
            This evidence phase has done its job: it gives the app a stronger read on your background. The next step is to map that readout against roles, employers, pay expectations, location/remote preferences, and the assets you will use to make the case.
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a class="cip-fancy-button" href="/#pathway">
              <span>Open action plan</span>
            </a>
            <a class="cip-fancy-button cip-fancy-button-secondary" href="/assets">
              <span>Prepare career assets</span>
            </a>
            <a class="cip-fancy-button cip-fancy-button-secondary" href="/opportunities">
              <span>Research roles</span>
            </a>
          </div>
        </div>
      </section>
    ) : null}

    <details class={readyForOpportunityMapping ? "mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6" : "contents"} open={!readyForOpportunityMapping}>
      {readyForOpportunityMapping ? (
        <summary class="text-lg font-semibold text-[var(--accent-strong)]">Add more information for analysis</summary>
      ) : null}

      <section class={readyForOpportunityMapping ? "mt-5 rounded-lg border border-[var(--line)] bg-[var(--background)] p-5" : "mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6"}>
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Source evidence</p>
          <h2 class="mt-1 text-2xl font-semibold">Analyze GitHub repos, articles, and project links</h2>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
            This fetches saved URLs from intake and evidence answers, reads available project/article text, and turns those links into structured career evidence before the advisor re-analyzes your profile.
          </p>
          <p class="mt-3 text-sm font-semibold text-[var(--muted)]">Saved source-analysis runs: {sourceCounts.source}. Linked source items scored: {sourceCounts.sourceItems}.</p>
        </div>
        <form hx-post="/api/evidence/analyze-sources" hx-target="#source-analysis-result" hx-swap="innerHTML" hx-indicator="#source-analysis-loading">
          <button class="cip-fancy-button" type="submit" disabled={sourceCounts.intake === 0}>
            <span>Analyze linked sources</span>
          </button>
        </form>
      </div>
      <div id="source-analysis-loading" class="htmx-indicator cip-thinking-panel mt-5" role="status" aria-live="polite">
        <div class="cip-thinking-orbit" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Source analysis in progress</p>
          <div class="cip-thinking-lines" aria-hidden="true">
            <span>Finding GitHub, article, and project URLs...</span>
            <span>Fetching public source pages and READMEs...</span>
            <span>Extracting technologies, domains, and project signals...</span>
            <span>Separating proven work from assumptions...</span>
            <span>Saving structured source evidence...</span>
          </div>
          <p class="sr-only">Analyzing linked project sources.</p>
          <div class="cip-thinking-bar" aria-hidden="true"><span></span></div>
        </div>
      </div>
      <div id="source-analysis-result" class="mt-5" aria-live="polite"></div>
      </section>

      <section class={readyForOpportunityMapping ? "mt-5 rounded-lg border border-[var(--line)] bg-[var(--background)] p-5" : "mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6"}>
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Next advisor pass</p>
          <h2 class="mt-1 text-2xl font-semibold">Re-analyze with saved evidence</h2>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
            This takes the latest intake plus saved evidence answers and asks the advisor to update the ledger, proof gaps, exploration lanes, and positioning. The new analysis is saved as another source record.
          </p>
          <p class="mt-3 text-sm font-semibold text-[var(--muted)]">Saved re-analysis runs: {sourceCounts.analysis}</p>
        </div>
        <form hx-post="/api/evidence/analyze" hx-target="#evidence-analysis-result" hx-swap="innerHTML" hx-indicator="#evidence-analysis-loading">
          <button class="cip-fancy-button" type="submit" disabled={sourceCounts.evidence === 0 || sourceCounts.intake === 0}>
            <span>Re-analyze evidence</span>
          </button>
        </form>
      </div>
      <div id="evidence-analysis-loading" class="htmx-indicator cip-thinking-panel mt-5" role="status" aria-live="polite">
        <div class="cip-thinking-orbit" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Evidence analysis in progress</p>
          <div class="cip-thinking-lines" aria-hidden="true">
            <span>Loading saved intake and evidence answers...</span>
            <span>Separating strong claims from weak proof...</span>
            <span>Updating proof gaps and exploration lanes...</span>
            <span>Rebuilding the advisor evidence ledger...</span>
            <span>Saving the new analysis artifact...</span>
          </div>
          <p class="sr-only">Re-reading saved evidence and updating the advisor analysis.</p>
          <div class="cip-thinking-bar" aria-hidden="true"><span></span></div>
        </div>
      </div>
      <div id="evidence-analysis-result" class="mt-5" aria-live="polite"></div>
      </section>

      <section class={readyForOpportunityMapping ? "mt-5 rounded-lg border border-[var(--line)] bg-[var(--background)] p-5" : "mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6"}>
      <div>
        <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Strategic partner layer</p>
        <h2 class="mt-1 text-2xl font-semibold">Ask the questions the analysis must answer</h2>
        <p class="mt-3 max-w-3xl text-sm leading-6 text-[var(--muted)]">
          Use this for the specific things you still need the advisor to resolve. The review will answer from saved intake, evidence answers, and the latest re-analysis, then label what is proven, partial, unsupported, or needs a sharper follow-up.
        </p>
      </div>
      <form class="mt-5 grid gap-4" hx-post="/api/evidence/review" hx-target="#strategic-review-result" hx-swap="innerHTML" hx-indicator="#strategic-review-loading">
        <label class="grid gap-2">
          <span class="text-sm font-semibold">Strategic questions</span>
          <textarea
            name="strategic_questions"
            required
            class="min-h-36 rounded-md border border-[var(--line)] bg-[var(--background)] p-3 text-sm"
            placeholder={`One question per line.\nExample: What roles should I stop considering?\nExample: What is the strongest $120K+ positioning angle?\nExample: What part of my story still lacks proof?`}
          ></textarea>
        </label>
        <div class="flex flex-wrap items-center gap-3">
          <button class="cip-fancy-button" type="submit" disabled={sourceCounts.evidence === 0 || sourceCounts.intake === 0}>
            <span>Review strategic questions</span>
          </button>
          <span class="text-sm text-[var(--muted)]">Answers are saved as a new analysis review record.</span>
        </div>
        <p class="text-sm font-semibold text-[var(--muted)]">Saved strategic reviews: {sourceCounts.review}</p>
      </form>
      <div id="strategic-review-loading" class="htmx-indicator cip-thinking-panel mt-5" role="status" aria-live="polite">
        <div class="cip-thinking-orbit" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold uppercase text-[var(--accent-strong)]">Strategic review in progress</p>
          <div class="cip-thinking-lines" aria-hidden="true">
            <span>Reading your specific questions...</span>
            <span>Checking saved evidence against each question...</span>
            <span>Separating answered questions from open gaps...</span>
            <span>Writing direct answers with caveats...</span>
            <span>Saving the strategic review artifact...</span>
          </div>
          <p class="sr-only">Reviewing strategic questions against saved evidence.</p>
          <div class="cip-thinking-bar" aria-hidden="true"><span></span></div>
        </div>
      </div>
      <div id="strategic-review-result" class="mt-5" aria-live="polite"></div>
      </section>

      <section id="evidence-question-cards" hx-swap-oob="true">
        {cards.length ? <Fragment set:html={renderEvidenceCardsHtml(cards)} /> : null}
      </section>
    </details>

    <aside class="mt-6 rounded-lg border border-[var(--line)] bg-[var(--panel)] p-6">
      <h2 class="text-xl font-semibold">Recently saved evidence</h2>
      {evidenceResponses.length ? (
        <div class="mt-4 grid gap-3">
          {evidenceResponses.map((response) => (
            <article class="rounded-md border border-[var(--line)] bg-[var(--background)] p-4">
              <p class="text-sm font-semibold">{response.question}</p>
              <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{response.answer}</p>
              <p class="mt-3 text-xs font-semibold uppercase text-[var(--accent-strong)]">{response.confidence.replaceAll("_", " ")}</p>
            </article>
          ))}
        </div>
      ) : (
        <p class="mt-3 text-sm leading-6 text-[var(--muted)]">No evidence answers saved yet. Start with one card and keep it rough.</p>
      )}
    </aside>
  </main>
</Layout>
