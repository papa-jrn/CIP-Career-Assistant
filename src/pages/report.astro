---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import { createServer } from "../lib/supabase/server";
import {
  buildCareerReport,
  loadLatestSavedReport,
  formatReportRegions,
  type CareerReport,
  type ConfidenceLabel,
} from "../lib/cip/career-report";

let signedIn = false;
let report: CareerReport | null = null;
let savedAt: string | null = null;
let loadError = "";

if (import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY) {
  try {
    const supabase = createServer(Astro.cookies);
    const {
      data: { user },
    } = await supabase.auth.getUser();
    signedIn = Boolean(user);

    if (user) {
      // Show the most recently saved report if one exists; otherwise build a live
      // preview so the user sees honest state (ready / needs analysis / needs intake).
      const saved = await loadLatestSavedReport(supabase, user.id);
      report = saved.report ?? (await buildCareerReport(supabase, user.id));
      savedAt = saved.savedAt;
    }
  } catch (error) {
    loadError = error instanceof Error ? error.message : "Unable to load the report.";
  }
}

// Confidence label → display + tone (honest status, never disguised).
const confidenceMeta: Record<ConfidenceLabel, { label: string; cls: string }> = {
  verified: { label: "Verified", cls: "bg-[var(--accent-soft)] text-[var(--accent-strong)]" },
  stated: { label: "Stated by you", cls: "bg-[var(--accent-soft)] text-[var(--accent-strong)]" },
  inferred: { label: "Inferred", cls: "bg-[var(--warning-soft)] text-[var(--warning)]" },
  needs_confirmation: { label: "Needs confirmation", cls: "bg-[var(--warning-soft)] text-[var(--warning)]" },
  insufficient: { label: "Insufficient evidence", cls: "bg-[var(--danger-soft)] text-[var(--danger)]" },
};

function sufficiencyPercent(score: number): number {
  // Cap the gauge visually at 100; the raw score can exceed it.
  return Math.max(0, Math.min(100, score));
}

const sufficiencyPhaseLabel: Record<string, string> = {
  building: "Evidence building",
  strengthening: "Strengthening",
  enhancement: "Final enhancement",
  complete: "Evidence complete",
};

const laneIcon: Record<string, string> = {
  "Primary lane": "check-circle",
  "Strong alternate": "arrow-up-right",
  "Research lane": "spark",
};

const reportReady = report?.status === "ready";
const generatedLabel = savedAt
  ? `Saved ${new Date(savedAt).toLocaleString()}`
  : report?.analysisAt
    ? `From analysis ${new Date(report.analysisAt).toLocaleString()}`
    : "";
---

<Layout
  title="Career Intelligence Report — CIP"
  description="Your deterministic, evidence-backed career intelligence deliverable."
>
  <main class="cip-page-shell mx-auto w-full max-w-5xl px-5 py-8">
    <!-- ============ COVER BANNER ============ -->
    <div class="relative mb-6 overflow-hidden rounded-xl border border-[var(--line)] shadow-[var(--shadow-card)]">
      <img
        src="/images/report-cover.jpg"
        alt=""
        aria-hidden="true"
        class="h-44 w-full object-cover md:h-56"
        width="1400"
        height="700"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[rgba(31,68,56,0.82)] via-[rgba(31,68,56,0.45)] to-transparent"></div>
      <div class="absolute inset-0 flex flex-col justify-center px-6 md:px-10">
        <p class="text-xs font-semibold uppercase tracking-wide text-[var(--ink-on-sage)]/85">Career Intelligence Platform</p>
        <h1 class="mt-1 max-w-xl text-2xl text-[var(--ink-on-sage)] md:text-4xl" style="font-family: var(--headline-font); font-weight: 620; letter-spacing: -0.02em;">
          Career Intelligence Report
        </h1>
        <p class="mt-2 hidden max-w-md text-sm leading-6 text-[var(--ink-on-sage)]/85 md:block">
          A proof-backed dossier, not a generated brochure. Every claim carries its evidence status.
        </p>
      </div>
    </div>
    <!-- ============ HEADER ============ -->
    <section class="rounded-xl border border-[var(--line)] bg-[var(--panel)] p-6 shadow-[var(--shadow-card)] md:p-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">Capstone deliverable</p>
          <h2 class="mt-2 text-2xl md:text-3xl" style="font-family: var(--headline-font); font-weight: 620; letter-spacing: -0.02em;">
            How this report is built
          </h2>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-[var(--muted)] md:text-base">
            This report assembles what CIP genuinely knows about your career from saved, additive analysis. Every claim keeps its evidence status — it never invents findings. Think of it as a proof-backed dossier, not a generated brochure.
          </p>
          {reportReady && generatedLabel ? (
            <p class="mt-3 flex items-center gap-1.5 text-xs font-medium text-[var(--muted)]">
              <Icon name="file" class="h-3.5 w-3.5" strokeWidth={1.9} />
              {generatedLabel}
              {report?.analysisMode ? ` · analysis mode: ${report.analysisMode}` : ""}
            </p>
          ) : null}
        </div>
        <div class="flex flex-col items-stretch gap-2 sm:items-end">
          <form hx-post="/api/report/generate" hx-target="#report-result" hx-swap="innerHTML" hx-indicator="#report-loading">
            <button class="cip-fancy-button" type="submit" disabled={!signedIn}>
              <span class="flex items-center gap-2">
                <Icon name="sparkles" class="h-4 w-4" strokeWidth={2} />
                {reportReady ? "Regenerate report" : "Generate report"}
              </span>
            </button>
          </form>
          {reportReady ? (
            <button type="button" onclick="window.print()" class="cip-no-print inline-flex items-center justify-center gap-2 rounded-md border border-[var(--line)] px-4 py-2 text-sm font-semibold text-[var(--foreground)] hover:bg-black/5 dark:hover:bg-white/10">
              <Icon name="printer" class="h-4 w-4" strokeWidth={1.9} />
              Print / Save as PDF
            </button>
          ) : null}
        </div>
      </div>

      <!-- Thinking animation while generating -->
      <div id="report-loading" class="htmx-indicator cip-thinking-panel mt-6" role="status" aria-live="polite">
        <div class="cip-thinking-orbit" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent-strong)]">Assembling your report</p>
          <div class="cip-thinking-lines" aria-hidden="true">
            <span>Loading your latest saved analysis...</span>
            <span>Pulling the evidence ledger and role lanes...</span>
            <span>Computing the Evidence Sufficiency score...</span>
            <span>Attaching confidence status to each claim...</span>
            <span>Preparing the career intelligence deliverable...</span>
          </div>
          <p class="sr-only">Building a deterministic report from your saved analysis. No new content is generated.</p>
          <div class="cip-thinking-bar" aria-hidden="true"><span></span></div>
        </div>
      </div>
      <div id="report-result" class="mt-5" aria-live="polite"></div>

      {loadError ? (
        <p class="mt-5 rounded-lg border border-[var(--danger-soft)] bg-[var(--danger-soft)] p-4 text-sm text-[var(--danger)]">{loadError}</p>
      ) : null}

      {!signedIn ? (
        <p class="mt-5 rounded-lg border border-[var(--line)] bg-[var(--background)] p-4 text-sm text-[var(--muted)]">
          <a class="font-semibold text-[var(--accent-strong)] underline" href="/login">Sign in</a> to build and save your report.
        </p>
      ) : null}
    </section>

    {report && signedIn ? (
      <div class="cip-report-reveal mt-6 grid gap-6">
        <!-- ============ NOT-READY STATE (honest) ============ -->
        {!reportReady ? (
          <section class="rounded-xl border border-[var(--warning-soft)] bg-[var(--panel)] p-6 shadow-[var(--shadow-card)] md:p-8">
            <div class="flex items-start gap-3">
              <Icon name="alert" class="mt-0.5 h-6 w-6 shrink-0 text-[var(--warning)]" strokeWidth={1.9} />
              <div>
                <h2 class="text-xl" style="font-family: var(--headline-font);">
                  {report.status === "needs_intake" ? "Start with intake" : "Not enough analysis yet"}
                </h2>
                <p class="mt-2 max-w-2xl text-sm leading-7 text-[var(--muted)]">
                  {report.summary}
                </p>
                <a class="cip-fancy-button mt-5" href={report.nextStepHref}>
                  <span class="flex items-center gap-2">
                    {report.nextStepLabel}
                    <Icon name="arrow-right" class="h-4 w-4" strokeWidth={2.1} />
                  </span>
                </a>
              </div>
            </div>
          </section>
        ) : null}

        <!-- ============ EXECUTIVE SUMMARY ============ -->
        {reportReady ? (
          <section class="cip-report-section rounded-xl border border-[var(--line)] bg-[var(--panel)] p-6 pt-7 shadow-[var(--shadow-card)] md:p-8 md:pt-9">
            <div class="flex items-center gap-2">
              <Icon name="briefing" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
              <h2 class="text-xl" style="font-family: var(--headline-font);">Executive summary</h2>
            </div>
            <p class="mt-3 text-base leading-8 text-[var(--foreground)]">{report.summary}</p>
          </section>
        ) : null}

        <!-- ============ EVIDENCE SUFFICIENCY GAUGE ============ -->
        {reportReady && report.sufficiency ? (
          <section class="cip-report-section rounded-xl border border-[var(--line)] bg-[var(--panel)] p-6 pt-7 shadow-[var(--shadow-card)] md:p-8 md:pt-9">
            <div class="flex items-center gap-2">
              <Icon name="gauge" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
              <h2 class="text-xl" style="font-family: var(--headline-font);">Evidence sufficiency</h2>
            </div>
            <div class="mt-4 grid items-center gap-6 sm:grid-cols-[auto_1fr]">
              <div class="relative h-28 w-28 shrink-0">
                <svg viewBox="0 0 120 120" class="h-28 w-28 -rotate-90">
                  <circle cx="60" cy="60" r="52" fill="none" stroke="var(--accent-soft)" stroke-width="12"></circle>
                  <circle
                    cx="60" cy="60" r="52" fill="none" stroke="var(--brass)" stroke-width="12"
                    stroke-linecap="round"
                    stroke-dasharray={`${(sufficiencyPercent(report.sufficiency.score) / 100) * 327} 327`}
                  ></circle>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                  <span class="text-2xl font-bold text-[var(--foreground)]" style="font-family: var(--headline-font);">{report.sufficiency.score}</span>
                  <span class="text-[10px] font-semibold uppercase tracking-wide text-[var(--muted)]">of 100</span>
                </div>
              </div>
              <div>
                <p class="text-sm font-semibold text-[var(--brass)]">
                  {sufficiencyPhaseLabel[report.sufficiency.phase] ?? "Phase"}
                </p>
                <p class="mt-1 text-sm leading-6 text-[var(--muted)]">{report.sufficiency.reason}</p>
                <p class="mt-2 text-xs leading-5 text-[var(--muted)]">
                  {report.sufficiency.usefulEvidenceCount} useful evidence items across {report.sufficiency.scoreYears} scored career years.
                </p>
              </div>
            </div>
          </section>
        ) : null}

        <!-- ============ ROLE LANES ============ -->
        {reportReady && report.lanes.length ? (
          <section class="cip-report-section rounded-xl border border-[var(--line)] bg-[var(--panel)] p-6 pt-7 shadow-[var(--shadow-card)] md:p-8 md:pt-9">
            <div class="flex items-center gap-2">
              <Icon name="opportunities" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
              <h2 class="text-xl" style="font-family: var(--headline-font);">Role lanes</h2>
            </div>
            <div class="mt-4 grid gap-4 md:grid-cols-3">
              {report.lanes.map((lane) => (
                <article class="flex flex-col rounded-lg border border-[var(--line)] bg-[var(--background)] p-5">
                  <div class="flex items-center justify-between">
                    <span class="text-xs font-semibold uppercase tracking-wide text-[var(--brass)]">{lane.label}</span>
                    <Icon name={laneIcon[lane.label] ?? "file"} class="h-4 w-4 text-[var(--accent-strong)]" strokeWidth={1.9} />
                  </div>
                  <h3 class="mt-2 text-base font-semibold" style="font-family: var(--headline-font);">{lane.role}</h3>
                  <p class="mt-2 text-sm leading-6 text-[var(--muted)]">{lane.rationale}</p>
                  <p class="mt-3 border-t border-[var(--line)] pt-3 text-xs leading-5 text-[var(--warning)]">
                    <span class="font-semibold">Still needed:</span> {lane.missing}
                  </p>
                </article>
              ))}
            </div>
          </section>
        ) : null}

        <!-- ============ EVIDENCE LEDGER (confidence-labeled) ============ -->
        {reportReady && report.ledger.length ? (
          <section class="cip-report-section rounded-xl border border-[var(--line)] bg-[var(--panel)] p-6 pt-7 shadow-[var(--shadow-card)] md:p-8 md:pt-9">
            <div class="flex items-center gap-2">
              <Icon name="evidence" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
              <h2 class="text-xl" style="font-family: var(--headline-font);">Evidence ledger</h2>
            </div>
            <p class="mt-2 text-sm leading-6 text-[var(--muted)]">
              Every claim below is labeled with its evidence status. This is what lets you defend each point in an interview — and what tells CIP what still needs proof.
            </p>
            <div class="mt-4 divide-y divide-[var(--line)]">
              {report.ledger.map((entry) => (
                <article class="py-4 first:pt-0 last:pb-0">
                  <div class="flex flex-wrap items-start justify-between gap-2">
                    <h3 class="text-base font-semibold">{entry.claim}</h3>
                    <span class={`shrink-0 rounded-full px-2.5 py-1 text-xs font-semibold ${confidenceMeta[entry.confidence].cls}`}>
                      {confidenceMeta[entry.confidence].label}
                    </span>
                  </div>
                  <p class="mt-1 text-sm leading-6 text-[var(--muted)]">{entry.evidence}</p>
                  {entry.whyItMatters ? <p class="mt-1 text-sm leading-6 text-[var(--foreground)]"><span class="font-semibold">Why it matters:</span> {entry.whyItMatters}</p> : null}
                  {entry.nextValidationStep ? <p class="mt-1 text-xs leading-5 text-[var(--warning)]"><span class="font-semibold">Next validation:</span> {entry.nextValidationStep}</p> : null}
                </article>
              ))}
            </div>
          </section>
        ) : null}

        <!-- ============ POSITIONING ============ -->
        {reportReady && report.positioning.length ? (
          <section class="cip-report-section rounded-xl border border-[var(--line)] bg-[var(--panel)] p-6 pt-7 shadow-[var(--shadow-card)] md:p-8 md:pt-9">
            <div class="flex items-center gap-2">
              <Icon name="spark" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
              <h2 class="text-xl" style="font-family: var(--headline-font);">Positioning angles</h2>
            </div>
            <ul class="mt-4 space-y-3">
              {report.positioning.map((point, index) => (
                <li class="flex gap-3">
                  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[var(--accent-soft)] text-xs font-semibold text-[var(--accent-strong)]">{index + 1}</span>
                  <span class="pt-0.5 text-sm leading-6 text-[var(--foreground)]">{point}</span>
                </li>
              ))}
            </ul>
          </section>
        ) : null}

        <!-- ============ OPPORTUNITY SNAPSHOT ============ -->
        {reportReady && report.opportunity ? (
          <section class="cip-report-section rounded-xl border border-[var(--line)] bg-[var(--panel)] p-6 pt-7 shadow-[var(--shadow-card)] md:p-8 md:pt-9">
            <div class="flex items-center gap-2">
              <Icon name="map-pin" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
              <h2 class="text-xl" style="font-family: var(--headline-font);">Opportunity snapshot</h2>
            </div>
            <div class="mt-4 grid gap-4 sm:grid-cols-3">
              <div class="rounded-lg border border-[var(--line)] bg-[var(--background)] p-4 text-center">
                <p class="text-3xl font-bold text-[var(--accent-strong)]" style="font-family: var(--headline-font);">{report.opportunity.watchedEmployerCount}</p>
                <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">Watched employers</p>
              </div>
              <div class="rounded-lg border border-[var(--line)] bg-[var(--background)] p-4 text-center">
                <p class="text-3xl font-bold text-[var(--accent-strong)]" style="font-family: var(--headline-font);">{report.opportunity.opportunityMatchCount}</p>
                <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">Opportunity matches</p>
              </div>
              <div class="rounded-lg border border-[var(--line)] bg-[var(--background)] p-4 text-center">
                <p class="text-3xl font-bold text-[var(--accent-strong)]" style="font-family: var(--headline-font);">{report.opportunity.regionFocus.length}</p>
                <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">Regions in focus</p>
              </div>
            </div>
            {report.opportunity.regionFocus.length ? (
              <p class="mt-4 text-sm leading-6 text-[var(--muted)]">
                <span class="font-semibold text-[var(--foreground)]">Regions:</span> {formatReportRegions(report.opportunity.regionFocus).join(", ")}
              </p>
            ) : null}
          </section>
        ) : null}

        <!-- ============ EXPLORATION AREAS + CLAIM SAFETY ============ -->
        {reportReady && (report.explorationAreas.length || report.claimSafetyNotes.length) ? (
          <section class="cip-report-section rounded-xl border border-[var(--line)] bg-[var(--panel)] p-6 pt-7 shadow-[var(--shadow-card)] md:p-8 md:pt-9">
            <div class="grid gap-6 md:grid-cols-2">
              {report.explorationAreas.length ? (
                <div>
                  <div class="flex items-center gap-2">
                    <Icon name="sparkles" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
                    <h2 class="text-lg" style="font-family: var(--headline-font);">Exploration areas</h2>
                  </div>
                  <div class="mt-3 space-y-4">
                    {report.explorationAreas.map((area) => (
                      <article>
                        <h3 class="text-sm font-semibold">{area.area}</h3>
                        <p class="mt-1 text-sm leading-6 text-[var(--muted)]">{area.whyExplore}</p>
                        {area.firstExperiment ? <p class="mt-1 text-xs leading-5 text-[var(--brass)]"><span class="font-semibold">First experiment:</span> {area.firstExperiment}</p> : null}
                      </article>
                    ))}
                  </div>
                </div>
              ) : null}
              {report.claimSafetyNotes.length ? (
                <div>
                  <div class="flex items-center gap-2">
                    <Icon name="shield" class="h-5 w-5 text-[var(--warning)]" strokeWidth={1.9} />
                    <h2 class="text-lg" style="font-family: var(--headline-font);">Claim-safety notes</h2>
                  </div>
                  <ul class="mt-3 space-y-2">
                    {report.claimSafetyNotes.map((note) => (
                      <li class="flex gap-2 text-sm leading-6 text-[var(--muted)]">
                        <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--warning)]"></span>
                        <span>{note}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ) : null}
            </div>
          </section>
        ) : null}

        <!-- ============ WEEKLY ACTION CADENCE ============ -->
        {reportReady && report.actionCadence.length ? (
          <section class="cip-report-section rounded-xl border border-[var(--line)] bg-[var(--panel)] p-6 pt-7 shadow-[var(--shadow-card)] md:p-8 md:pt-9">
            <div class="flex items-center gap-2">
              <Icon name="followup" class="h-5 w-5 text-[var(--accent-strong)]" strokeWidth={1.9} />
              <h2 class="text-xl" style="font-family: var(--headline-font);">Weekly action cadence</h2>
            </div>
            <ol class="mt-4 space-y-3">
              {report.actionCadence.map((action, index) => (
                <li class="flex gap-3">
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[var(--accent)] text-xs font-bold text-[var(--ink-on-sage)]">{index + 1}</span>
                  <span class="pt-1 text-sm leading-6 text-[var(--foreground)]">{action}</span>
                </li>
              ))}
            </ol>
            <div class="mt-6 flex flex-wrap gap-3">
              <a class="cip-fancy-button" href={report.nextStepHref}>
                <span class="flex items-center gap-2">
                  {report.nextStepLabel}
                  <Icon name="arrow-right" class="h-4 w-4" strokeWidth={2.1} />
                </span>
              </a>
              <a class="cip-fancy-button cip-fancy-button-secondary" href="/briefing">
                <span>Open weekly briefing</span>
              </a>
            </div>
          </section>
        ) : null}

        <!-- ============ INTEGRITY FOOTER ============ -->
        {reportReady ? (
          <section class="rounded-xl border border-[var(--line)] bg-[var(--surface-wash)] p-5 text-xs leading-5 text-[var(--muted)]">
            <div class="flex items-start gap-2">
              <Icon name="shield" class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent-strong)]" strokeWidth={1.9} />
              <p>
                <span class="font-semibold text-[var(--foreground)]">How this report is built:</span> assembled deterministically from your saved analysis — no new content is generated for it. Every claim keeps its evidence status (Verified, Stated, Inferred, Needs confirmation, or Insufficient). The optional AI executive summary, if any, is labeled separately. This is the integrity rule CIP is built on.
              </p>
            </div>
          </section>
        ) : null}
      </div>
    ) : null}
  </main>
</Layout>
