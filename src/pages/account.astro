---
import Layout from "../layouts/Layout.astro";
import { createServer } from "../lib/supabase/server";

const supabase = createServer(Astro.cookies);
const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect("/login");
}

const checkout = Astro.url.searchParams.get("checkout");
const checkoutSessionId = Astro.url.searchParams.get("session_id");
let checkoutMessage: { tone: "success" | "pending"; text: string } | null = null;

if (checkout === "success" && checkoutSessionId) {
  const { data: payment } = await supabase
    .from("payments")
    .select("stripe_checkout_session_id")
    .eq("stripe_checkout_session_id", checkoutSessionId)
    .maybeSingle();

  checkoutMessage = payment
    ? {
        tone: "success",
        text: "Payment completed and verified. Thank you.",
      }
    : {
        tone: "pending",
        text: "Payment is processing. Refresh in a moment if it does not appear yet.",
      };
}
---

<Layout title="Account - Career Intelligence Platform">
  <div
    class="mx-auto flex min-h-full max-w-lg flex-1 flex-col justify-center px-4 py-16"
  >
    <h1 class="text-2xl font-semibold tracking-tight">Account</h1>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
      Signed in as{" "}
      <span class="font-medium text-foreground">{user.email}</span>
    </p>
    {
      checkoutMessage?.tone === "success" ? (
        <p class="mt-4 rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950 dark:text-emerald-100">
          {checkoutMessage.text}
        </p>
      ) : null
    }
    {
      checkoutMessage?.tone === "pending" ? (
        <p class="mt-4 rounded-lg border border-sky-200 bg-sky-50 px-3 py-2 text-sm text-sky-900 dark:border-sky-900 dark:bg-sky-950 dark:text-sky-100">
          {checkoutMessage.text}
        </p>
      ) : null
    }
    {
      checkout === "cancel" ? (
        <p class="mt-4 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-900 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-100">
          Checkout canceled. No charge was made.
        </p>
      ) : null
    }
    <div class="mt-8 space-y-6">
      <div>
        <h2 class="text-sm font-medium text-zinc-500">Billing</h2>
        <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
          One-time test payment via Stripe Checkout. Enable PayPal (and other
          methods) in the Stripe Dashboard.
        </p>
        <div id="checkout-err" class="mt-2 min-h-[1.25rem] text-sm"></div>
        <button
          type="button"
          class="mt-3 rounded-lg bg-foreground px-4 py-2 text-sm font-medium text-background transition hover:opacity-90 htmx-request:opacity-50"
          hx-post="/api/checkout"
          hx-target="#checkout-err"
          hx-swap="innerHTML"
        >
          Pay with Stripe Checkout
        </button>
      </div>
    </div>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
      <form hx-post="/api/auth/logout" hx-swap="none">
        <button
          type="submit"
          class="rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium transition hover:bg-zinc-50 dark:border-zinc-600 dark:hover:bg-zinc-900 htmx-request:opacity-50"
        >
          Sign out
        </button>
      </form>
      <a
        href="/"
        class="text-center text-sm font-medium text-foreground underline-offset-4 hover:underline sm:text-left"
        >Home</a
      >
      <a
        href="/set-password"
        class="text-center text-sm font-medium text-foreground underline-offset-4 hover:underline sm:text-left"
        >Change password</a
      >
    </div>
  </div>
</Layout>
