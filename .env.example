# App URL (no trailing slash). Used by auth redirects and Stripe return URLs.
# Astro dev default: http://localhost:4321
PUBLIC_SITE_URL=http://localhost:4321

# Supabase: Project Settings > API
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Optional: enables deeper intake advisor analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: comma-separated public job board slugs for labor-market ingestion.
# Greenhouse example format: companyslug
# Lever example format: companyslug
LABOR_MARKET_GREENHOUSE_BOARDS=
LABOR_MARKET_LEVER_COMPANIES=

# Optional: Stripe webhook signing secret. Required for /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=

# Optional: service role. Webhook records payments and bypasses RLS. Server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe: API keys (never expose sk_ to the client)
STRIPE_SECRET_KEY=

# Stripe: Product > Price ID (price_...)
STRIPE_PRICE_ID=

# Optional: pk_ for future Stripe.js / Payment Element
PUBLIC_STRIPE_PUBLISHABLE_KEY=
